@page "/login"

@attribute [AllowAnonymous]

@inject IKullaniciService KullaniciService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Giriş Yap</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center" Style="min-height:calc(100vh - 120px);padding:12px;">
    <RadzenColumn Size="12" SizeMD="6" SizeLG="4" Style="max-width:420px;margin-top:-50px;">
        <RadzenCard class="p-4" Style="border-radius:16px;border:1px solid #e7ecf5;box-shadow:0 10px 28px rgba(15,23,42,0.08);background:#ffffff;">
            <RadzenText TextStyle="TextStyle.H4" class="mb-3" Style="display:block;text-align:center;color:#334155;">Giriş Yap</RadzenText>
            <RadzenDivider Style="margin:0 0 1rem 0;" />

            <EditForm Model="@model" OnValidSubmit="HandleLogin" OnInvalidSubmit="HandleInvalidSubmit">
                <DataAnnotationsValidator />

                <RadzenStack Gap="1rem">
                    <RadzenFormField Text="Mail" Style="width:100%;">
                        <RadzenTextBox Name="Mail" @bind-Value="model.Mail" Style="width:100%;" />
                    </RadzenFormField>
                    <RadzenRequiredValidator Component="Mail"
                                             Text="Mail alanı zorunludur."
                                             Popup="true" />

                    <RadzenFormField Text="Şifre" Style="width:100%;">
                        <RadzenPassword Name="Sifre" @bind-Value="model.Sifre" Style="width:100%;" />
                    </RadzenFormField>
                    <RadzenRequiredValidator Component="Sifre"
                                             Text="Şifre alanı zorunludur."
                                             Popup="true" />

                    <RadzenButton Text="Giriş Yap"
                                  Icon="login"
                                  ButtonType="ButtonType.Submit"
                                  Style="width:100%;border-radius:10px;background:#4f46e5;border:none;" />
                </RadzenStack>
            </EditForm>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    private LoginModel model = new();

    private async Task HandleLogin()
    {
        try
        {
            var status = await JS.InvokeAsync<int>("EMutabakatAuth.postJsonStatus", "api/auth/login", model);
            if (status == 200)
            {
                NavigationManager.NavigateTo("/", true);
                return;
            }

            if (status == 401)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Hata", "Mail veya şifre hatalı.");
                return;
            }

            NotificationService.Notify(NotificationSeverity.Error, "Hata", $"Giriş başarısız. Durum kodu: {status}");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", $"Giriş sırasında hata oluştu: {ex.Message}");
        }
    }

    private void HandleInvalidSubmit(EditContext editContext)
    {
        var messages = editContext.GetValidationMessages().Distinct().ToList();

        if (messages.Count == 0)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Lütfen form alanlarını kontrol ediniz.");
            return;
        }

        foreach (var message in messages)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", message);
        }
    }
}








