@page "/login"

@attribute [AllowAnonymous]

@inject IKullaniciService KullaniciService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject IJSRuntime JS

<PageTitle>Giriş Yap</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" class="mt-5">
    <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
        <RadzenCard class="p-4">
            <RadzenText TextStyle="TextStyle.H4" class="mb-3">Giriş Yap</RadzenText>

            <EditForm Model="@model" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <RadzenStack Gap="1rem">
                    <RadzenFormField Text="Mail" Style="width:100%;">
                        <RadzenTextBox @bind-Value="model.Mail" Style="width:100%;" />
                    </RadzenFormField>

                    <RadzenFormField Text="Şifre" Style="width:100%;">
                        <RadzenPassword @bind-Value="model.Sifre" Style="width:100%;" />
                    </RadzenFormField>

                    <RadzenButton Text="Giriş Yap"
                                  Icon="login"
                                  ButtonType="ButtonType.Submit"
                                  Style="width:100%;" />
                </RadzenStack>
            </EditForm>
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    private LoginModel model = new();

    private async Task HandleLogin()
    {
        var status = await JS.InvokeAsync<int>("EMutabakatAuth.postJsonStatus", "api/auth/login", model);
        if (status == 200)
        {
            NavigationManager.NavigateTo("/", true);
            return;
        }

        if (status == 401)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", "Mail veya şifre hatalı.");
            return;
        }

        NotificationService.Notify(NotificationSeverity.Error, "Hata", "Giriş sırasında hata oluştu.");
    }
}