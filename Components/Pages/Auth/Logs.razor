@page "/auth/logs"
@attribute [Authorize]

@inject ILogService LogService
@inject IKullaniciService KullaniciService
@inject NotificationService NotificationService
@inject DialogService DialogService

<PageTitle>Loglar</PageTitle>

@if (!canView)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">Bu sayfaya erişim yetkiniz bulunmamaktadır.</RadzenAlert>
}
else
{
    <RadzenStack Gap="1rem" class="p-4">
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenText TextStyle="TextStyle.H4">Sistem Logları</RadzenText>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6" class="rz-text-align-end">
                <RadzenStack Orientation="Orientation.Horizontal"
                             Gap="8px"
                             AlignItems="AlignItems.Center"
                             JustifyContent="JustifyContent.End">

                    @if (canClear)
                    {
                        <RadzenButton Text="Logları temizle"
                                      Icon="delete"
                                      Style="font-size:15px;"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Click="@ClearLogs" />
                    }

                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>

        <RadzenCard>
            <RadzenDataGrid @ref="grid"
                            Data="@logs"
                            TItem="AppLog"
                            AllowPaging="true"
                            AllowSorting="true"
                            AllowFiltering="true"
                            PageSize="20"
                            EmptyText="Kayıt bulunamadı"
                            ExpandMode="DataGridExpandMode.Single"
                            RowExpand="@(log => expandedLog = log)"
                            RowCollapse="@(log => { if (expandedLog?.Id == log.Id) expandedLog = null; })">

                <Template Context="log">
                    @{
                        var changes = ParseDetails(log.Details);
                    }
                    @if (changes != null && changes.Count > 0)
                    {
                        <div style="padding:10px 16px 14px 16px;">
                            <table style="width:100%; border-collapse:collapse; font-size:13px;">
                                <thead>
                                    <tr style="background:#f5f5f5;">
                                        <th style="text-align:left; padding:6px 12px; border-bottom:1px solid #e0e0e0; width:25%; color:#555;">Alan</th>
                                        <th style="text-align:left; padding:6px 12px; border-bottom:1px solid #e0e0e0; width:37.5%; color:#c0392b;">Eski Değer</th>
                                        <th style="text-align:left; padding:6px 12px; border-bottom:1px solid #e0e0e0; width:37.5%; color:#27ae60;">Yeni Değer</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var change in changes)
                                    {
                                        <tr style="border-bottom:1px solid #f0f0f0;">
                                            <td style="padding:6px 12px; font-weight:600; color:#444;">@change.Field</td>
                                            <td style="padding:6px 12px; color:#c0392b; word-break:break-word;">@(change.OldValue ?? "(boş)")</td>
                                            <td style="padding:6px 12px; color:#27ae60; word-break:break-word;">@(change.NewValue ?? "(boş)")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div style="padding:10px 16px; font-size:13px; color:#999;">
                            Bu kayıt için değişiklik detayı bulunmuyor.
                        </div>
                    }
                </Template>

                <Columns>
                    <RadzenDataGridColumn TItem="AppLog"
                                          Property="Id"
                                          Title="ID"
                                          Width="80px" />

                    <RadzenDataGridColumn TItem="AppLog"
                                          Property="CreatedAt"
                                          Title="Tarih"
                                          Width="200px">
                        <Template Context="item">
                            @item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AppLog"
                                          Property="Level"
                                          Title="Seviye"
                                          Width="150px">
                        <Template Context="item">
                            @if ((item.Level ?? string.Empty).Equals("Hata", StringComparison.OrdinalIgnoreCase) ||
                                 (item.Level ?? string.Empty).Equals("Error", StringComparison.OrdinalIgnoreCase))
                            {
                                <RadzenBadge Text="@item.Level" BadgeStyle="BadgeStyle.Danger" />
                            }
                            else if ((item.Level ?? string.Empty).Equals("Uyarı", StringComparison.OrdinalIgnoreCase) ||
                                     (item.Level ?? string.Empty).Equals("Warning", StringComparison.OrdinalIgnoreCase))
                            {
                                <RadzenBadge Text="@item.Level" BadgeStyle="BadgeStyle.Warning" />
                            }
                            else
                            {
                                <RadzenBadge Text="@item.Level" BadgeStyle="BadgeStyle.Success" />
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="AppLog"
                                          Property="Source"
                                          Title="Kaynak"
                                          Width="180px" />

                    <RadzenDataGridColumn TItem="AppLog"
                                          Property="UserEmail"
                                          Title="Kullanıcı"
                                          Width="250px" />

                    <RadzenDataGridColumn TItem="AppLog"
                                          Property="Message"
                                          Title="Mesaj">
                        <Template Context="item">
                            <span style="white-space:normal; word-break:break-word;">@item.Message</span>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>

    </RadzenStack>
}

@code {
    private List<AppLog> logs = new();
    private bool canView;
    private bool canClear;
    private AppLog? expandedLog;
    private RadzenDataGrid<AppLog> grid = default!;

    protected override async Task OnInitializedAsync()
    {
        var yetki = await KullaniciService.GetCurrentUserYetkiAsync();
        var isSeed = await KullaniciService.IsCurrentUserSeedAsync();

        if (isSeed)
        {
            canView = canClear = true;
        }
        else if (yetki != null)
        {
            canView = yetki.LogYetki;
            canClear = yetki.LogYetki;
        }

        if (!canView)
            return;

        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        logs = await LogService.GetRecentAsync(500);
    }

    private List<FieldChangeDisplay>? ParseDetails(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return null;

        try
        {
            return JsonSerializer.Deserialize<List<FieldChangeDisplay>>(json);
        }
        catch
        {
            return null;
        }
    }

    private class FieldChangeDisplay
    {
        public string Field { get; set; } = string.Empty;
        public string? OldValue { get; set; }
        public string? NewValue { get; set; }
    }

    private async Task ClearLogs()
    {
        var result = await DialogService.OpenAsync<ClearLogsDialog>(
            "Logları Temizle",
            null,
            new DialogOptions
            {
                Width = "430px",
                Height = "auto",
                Resizable = false,
                Draggable = true
            });

        if (result is not ClearLogsDialog.ClearLogsDialogResult clearResult)
            return;

        if (clearResult.ClearType == "All")
        {
            var confirmed = await DialogService.Confirm(
                "Tüm log kayıtlarını silmek istediğinize emin misiniz?",
                "Tüm Logları Sil",
                new ConfirmOptions
                {
                    OkButtonText = "Evet, tümünü sil",
                    CancelButtonText = "Vazgeç"
                });

            if (confirmed != true)
                return;

            await LogService.DeleteAllAsync();
            await LoadLogs();

            NotificationService.Notify(
                NotificationSeverity.Success,
                "Başarılı",
                "Tüm log kayıtları silindi.");

            return;
        }

        if (clearResult.DayCount <= 0)
            return;

        var confirmedLastDays = await DialogService.Confirm(
            $"Son {clearResult.DayCount} günün log kayıtlarını silmek istediğinize emin misiniz?",
            "Logları Sil",
            new ConfirmOptions
            {
                OkButtonText = "Evet, sil",
                CancelButtonText = "Vazgeç"
            });

        if (confirmedLastDays != true)
            return;

        await LogService.DeleteLastDaysAsync(clearResult.DayCount);
        await LoadLogs();

        NotificationService.Notify(
            NotificationSeverity.Success,
            "Başarılı",
            $"Son {clearResult.DayCount} günün log kayıtları silindi.");
    }
}