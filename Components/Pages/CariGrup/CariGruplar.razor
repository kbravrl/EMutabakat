@page "/current-groups"

@attribute [Authorize]

@inject ICariGrupService CariGrupService
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Cari Gruplar</PageTitle>

<RadzenStack Gap="1rem" class="p-4">
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText TextStyle="TextStyle.H4">Cari Grup Listesi</RadzenText>
        </RadzenColumn>

        <RadzenColumn Size="12" SizeMD="6" class="rz-text-align-end">
            <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End">
                <RadzenButton Text="Excel İçe Aktar"
                          Icon="file_upload"
                          Click="OpenImportDialog" />
                <RadzenButton Text="Yeni Cari Grup Ekle"
                          Icon="add_circle"
                          Click="@GoToCreatePage" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    <RadzenCard>
        <RadzenDataGrid Data="@cariGruplar"
                        TItem="CariGrup"
                        AllowPaging="true"
                        AllowSorting="true"
                        AllowFiltering="true"
                        PageSize="10"
                        EmptyText="Kayıt bulunamadı">
            <Columns>
                <RadzenDataGridColumn TItem="CariGrup" Property="CariGrupId" Title="ID" />
                <RadzenDataGridColumn TItem="CariGrup" Property="CariGrupAdi" Title="Cari Grup Adı" />
                <RadzenDataGridColumn TItem="CariGrup" Title="Firma">
                    <Template Context="item">
                        @item.Firma?.FirmaAdi
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="CariGrup"
                                      Property="CariGrupAktifPasif"
                                      Title="Durum"
                                      FilterOperator="FilterOperator.Equals"
                                      FilterValue="@aktifDurumFiltre">
                    <Template Context="item">
                        @if (item.CariGrupAktifPasif == 1)
                        {
                            <RadzenBadge Text="Aktif" BadgeStyle="BadgeStyle.Success" />
                        }
                        else
                        {
                            <RadzenBadge Text="Pasif" BadgeStyle="BadgeStyle.Danger" />
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="CariGrup" Title="İşlemler" Sortable="false" Filterable="false" Width="220px">
                    <Template Context="item">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenButton Icon="edit"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          Click="@(() => GoToEditPage(item.CariGrupId))" />

                            <RadzenButton Icon="delete"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Disabled="@isSubmitting"
                                          Click="@(() => DeleteCariGrup(item.CariGrupId, item.CariGrupAdi))" />
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
</RadzenStack>

@code {
    private List<CariGrup> cariGruplar = new();
    private bool isSubmitting;
    private int aktifDurumFiltre = 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadCariGruplarAsync();
    }

    private async Task LoadCariGruplarAsync()
    {
        cariGruplar = await CariGrupService.GetAllAsync();
    }

    private void GoToCreatePage()
    {
        NavigationManager.NavigateTo("/current-groups/add");
    }

    private void GoToEditPage(string id)
    {
        NavigationManager.NavigateTo($"/current-groups/edit/{Uri.EscapeDataString(id)}");
    }

    private async Task DeleteCariGrup(string id, string cariGrupAdi)
    {
        var confirmed = await DialogService.Confirm(
            $"'{cariGrupAdi}' kaydını silmek istediğinize emin misiniz?",
            "Silme Onayı",
            new ConfirmOptions
            {
                OkButtonText = "Evet",
                CancelButtonText = "Vazgeç"
            });

        if (confirmed == true)
        {
            if (isSubmitting) return;
            isSubmitting = true;
            try
            {
                var result = await CariGrupService.DeleteAsync(id);

                if (result)
                {
                    NotificationService.Notify(
                        NotificationSeverity.Success,
                        "Başarılı",
                        "Cari grup kaydı silindi.");

                    await LoadCariGruplarAsync();
                }
                else
                {
                    NotificationService.Notify(
                        NotificationSeverity.Warning,
                        "Uyarı",
                        "Cari grup kaydı bulunamadı.");
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Uyarı",
                    ex.Message);
            }
            finally
            {
                isSubmitting = false;
            }
        }
    }

    private async Task OpenImportDialog()
    {
        var parameters = new Dictionary<string, object?>();
        var result = await DialogService.OpenAsync("Excel İçe Aktar", typeof(Components.Pages.CariGrup.CariGrupImportDialog), parameters, new DialogOptions { Width = "600px" });
        if (result == true)
        {
            await LoadCariGruplarAsync();
        }
    }
}
