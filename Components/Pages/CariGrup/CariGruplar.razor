@page "/current-groups"

@attribute [Authorize]

@inject ICariGrupService CariGrupService
@inject IFirmaService FirmaService
@inject IKullaniciService KullaniciService
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject NotificationService NotificationService

@inject IJSRuntime JS

<PageTitle>Cari Gruplar</PageTitle>

    <RadzenStack Gap="1rem" class="p-4">
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenText TextStyle="TextStyle.H4">Cari Grup Listesi</RadzenText>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6" class="rz-text-align-end">
                <div style="display:flex; align-items:center; gap:15px; justify-content:flex-end; width:100%;">

                    @if (canExport)
                    {
                        <img src="/images/excel-export.png"
                             title="Excel Dışa Aktar"
                             @onclick="ExportToExcel"
                             style="width:48px; height:48px; cursor:pointer;" />
                    }

                    @if (canImport)
                    {
                        <img src="/images/excel-import.png"
                             title="Excel İçe Aktar"
                             @onclick="OpenImportDialog"
                             style="width:48px; height:48px; cursor:pointer;" />
                    }

                    @if (canAdd)
                    {
                        <RadzenButton Text="Yeni cari grup ekle"
                                      Icon="add_circle"
                                      Style="font-size:15px;"
                                      Click="@GoToCreatePage" />
                    }

                </div>
            </RadzenColumn>
        </RadzenRow>

        <RadzenCard>
            <div style="display:flex; align-items:center; gap:8px; flex-wrap:nowrap; width:100%; margin-bottom:1rem;">

                <RadzenTextBox Style="width:340px;"
                               Placeholder="ID/ Cari Grup adı ara"
                               @bind-Value="searchText" />

                <RadzenDropDown TValue="int?"
                                Style="width:220px;"
                                Placeholder="Firma seç"
                                Data="@firmaOptions"
                                TextProperty="FirmaAdi"
                                ValueProperty="FirmaId"
                                @bind-Value="selectedFirmaId"
                                AllowClear="true" />

                <RadzenDropDown TValue="int?"
                                Style="width:200px;"
                                Placeholder="Durum"
                                Data="@durumOptions"
                                TextProperty="Text"
                                ValueProperty="Value"
                                @bind-Value="selectedDurum"
                                AllowClear="true" />

                <RadzenButton Text="Temizle"
                              Style="height:36px; white-space:nowrap; font-size:15px;"
                              Icon="filter_alt_off"
                              ButtonStyle="ButtonStyle.Light"
                              Click="@ClearFilters" />

            </div>

            <RadzenDataGrid Data="@filteredCariGruplar"
                            TItem="CariGrup"
                            AllowPaging="true"
                            AllowSorting="true"
                            AllowFiltering="false"
                            PageSize="10"
                            EmptyText="Kayıt bulunamadı">
                <Columns>
                    <RadzenDataGridColumn TItem="CariGrup"
                                          Property="CariGrupId"
                                          Title="ID"
                                          Width="90px" />

                    <RadzenDataGridColumn TItem="CariGrup"
                                          Property="CariGrupAdi"
                                          Title="Cari Grup Adı" />

                    <RadzenDataGridColumn TItem="CariGrup" Title="Firma">
                        <Template Context="item">
                            @item.Firma?.FirmaAdi
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="CariGrup"
                                          Property="CariGrupAktifPasif"
                                          Title="Durum">
                        <Template Context="item">
                            @if (item.CariGrupAktifPasif == 1)
                            {
                                <RadzenBadge Text="Aktif" BadgeStyle="BadgeStyle.Success" />
                            }
                            else
                            {
                                <RadzenBadge Text="Pasif" BadgeStyle="BadgeStyle.Danger" />
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="CariGrup"
                                          Title="İşlemler"
                                          Sortable="false"
                                          Filterable="false"
                                          Width="220px">
                        <Template Context="item">
                            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                                @if (canEdit)
                                {
                                    <RadzenButton Icon="edit"
                                                  Size="ButtonSize.Small"
                                                  Variant="Variant.Flat"
                                                  Title="Düzenle"
                                                  Click="@(() => GoToEditPage(item.CariGrupId, item.FirmaId))" />
                                }

                                @if (canDelete)
                                {
                                    <RadzenButton Icon="delete"
                                                  Size="ButtonSize.Small"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Danger"
                                                  Title="Sil"
                                                  Disabled="@isSubmitting"
                                                  Click="@(() => DeleteCariGrup(item.CariGrupId, item.FirmaId, item.CariGrupAdi))" />
                                }
                            </RadzenStack>
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenStack>

@code {
    private List<CariGrup> cariGruplar = new();
    private List<Firma> firmaOptions = new();
    private List<CariGrup> grupAdiOptions = new();

    private bool isSubmitting;
    private bool canView;
    private bool canAdd;
    private bool canEdit;
    private bool canDelete;
    private bool canImport;
    private bool canExport;

    private string? searchText;
    private int? selectedFirmaId;
    private string? selectedGrupAdi;
    private int? selectedDurum = 1;

    private List<FilterOption<int?>> durumOptions = new()
    {
        new() { Text = "Aktif", Value = 1 },
        new() { Text = "Pasif", Value = 0 }
    };

    private List<CariGrup> filteredCariGruplar =>
        cariGruplar
            .Where(x =>
                string.IsNullOrWhiteSpace(searchText) ||
                ((x.CariGrupId?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false)
                 || (x.CariGrupAdi?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false)))
            .Where(x =>
                !selectedFirmaId.HasValue || x.FirmaId == selectedFirmaId.Value)
            .Where(x =>
                string.IsNullOrWhiteSpace(selectedGrupAdi) || x.CariGrupAdi == selectedGrupAdi)
            .Where(x =>
                !selectedDurum.HasValue || x.CariGrupAktifPasif == selectedDurum.Value)
            .OrderByDescending(x => x.CariGrupAktifPasif)
            .ThenBy(x => GetCariGrupSortValue(x.CariGrupId))
            .ThenBy(x => x.CariGrupAdi)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        var yetki = await KullaniciService.GetCurrentUserYetkiAsync();
        var isSeed = await KullaniciService.IsCurrentUserSeedAsync();

        if (isSeed)
        {
            canView = canAdd = canEdit = canDelete = canImport = canExport = true;
        }
        else if (yetki != null)
        {
            canView   = yetki.CariGruplar >= YetkiSeviyesi.Giris;
            canAdd    = yetki.CariGruplar == YetkiSeviyesi.TamYetki;
            canEdit   = yetki.CariGruplar >= YetkiSeviyesi.GirisDuzeltme;
            canDelete = yetki.CariGruplar == YetkiSeviyesi.TamYetki;
            canImport = yetki.ImportYetki;
            canExport = yetki.ExportYetki;
        }

        if (!canView)
            return;

        await LoadCariGruplarAsync();
    }

    private async Task LoadCariGruplarAsync()
    {
        cariGruplar = await CariGrupService.GetAllAsync();
        firmaOptions = await FirmaService.GetAllAsync();

        grupAdiOptions = cariGruplar
            .Where(x => !string.IsNullOrWhiteSpace(x.CariGrupAdi))
            .GroupBy(x => x.CariGrupAdi)
            .Select(g => g.First())
            .OrderBy(x => x.CariGrupAdi)
            .ToList();
    }

    private void ClearFilters()
    {
        searchText = null;
        selectedFirmaId = null;
        selectedGrupAdi = null;
        selectedDurum = 1;
    }

    private int GetCariGrupSortValue(string? cariGrupId)
    {
        var id = cariGrupId ?? "";

        if (int.TryParse(id, out var n))
            return n;

        var match = System.Text.RegularExpressions.Regex.Match(id, @"\d+");

        if (int.TryParse(match.Value, out var m))
            return m;

        return int.MaxValue;
    }

    private void GoToCreatePage()
    {
        NavigationManager.NavigateTo("/current-groups/add");
    }

    private void GoToEditPage(string id, int firmaId)
    {
        NavigationManager.NavigateTo($"/current-groups/edit/{Uri.EscapeDataString(id)}/{firmaId}");
    }

    private async Task DeleteCariGrup(string id, int firmaId, string cariGrupAdi)
    {
        var confirmed = await DialogService.Confirm(
            $"'{cariGrupAdi}' kaydını silmek istediğinize emin misiniz?",
            "Silme Onayı",
            new ConfirmOptions
            {
                OkButtonText = "Evet",
                CancelButtonText = "Vazgeç"
            });

        if (confirmed == true)
        {
            if (isSubmitting) return;

            isSubmitting = true;
            try
            {
                var result = await CariGrupService.DeleteAsync(id, firmaId);

                if (result)
                {
                    NotificationService.Notify(
                        NotificationSeverity.Success,
                        "Başarılı",
                        "Cari grup kaydı silindi.");

                    await LoadCariGruplarAsync();
                }
                else
                {
                    NotificationService.Notify(
                        NotificationSeverity.Warning,
                        "Uyarı",
                        "Cari grup kaydı bulunamadı.");
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Uyarı",
                    ex.Message);
            }
            finally
            {
                isSubmitting = false;
            }
        }
    }

    private async Task ExportToExcel()
    {
        try
        {
            var bytes = await CariGrupService.ExportToExcelAsync(filteredCariGruplar);
            var base64 = Convert.ToBase64String(bytes);

            var fileName = "Cari_Gruplar_Listesi.xlsx";

            await JS.InvokeVoidAsync(
                "downloadFileFromBase64",
                fileName,
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                base64
            );

            NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Cari gruplar Excel olarak indirildi.");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", ex.Message);
        }
    }

    private async Task OpenImportDialog()
    {
        var parameters = new Dictionary<string, object?>();
        var result = await DialogService.OpenAsync(
            "Excel İçe Aktar",
            typeof(Components.Pages.CariGrup.CariGrupImportDialog),
            parameters,
            new DialogOptions { Width = "600px" });

        if (result == true)
        {
            await LoadCariGruplarAsync();
        }
    }

    public class FilterOption<T>
    {
        public string Text { get; set; } = string.Empty;
        public T? Value { get; set; }
    }
}