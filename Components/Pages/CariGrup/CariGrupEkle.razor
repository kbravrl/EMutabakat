@page "/current-groups/add"

@attribute [Authorize]

@inject ICariGrupService CariGrupService
@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Cari Grup Ekle</PageTitle>

<RadzenCard Class="p-4" Style="max-width:900px;margin-left:auto;margin-right:auto;">
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="8px">
        <RadzenText TextStyle="TextStyle.H4">Yeni Cari Grup Ekle</RadzenText>
    </RadzenStack>
    <RadzenDivider />
    <EditForm Model="@cariGrup" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <RadzenFieldset Text="Genel Bilgiler" Style="margin-bottom:16px">
            <RadzenRow Gap="16px">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Firma" Style="width:100%;">
                        <RadzenDropDown Data="@firmalar"
                                        TextProperty="FirmaAdi"
                                        ValueProperty="FirmaId"
                                        @bind-Value="cariGrup.FirmaId"
                                        Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Cari Grup Adı" Style="width:100%;">
                        <RadzenTextBox @bind-Value="cariGrup.CariGrupAdi" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" JustifyContent="JustifyContent.End" Class="mt-3">
                        <RadzenButton Text="İptal" Icon="close" ButtonStyle="ButtonStyle.Secondary" Click="@Cancel" Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px;" />
                        <RadzenButton Text="Kaydet" Icon="save" ButtonType="ButtonType.Submit" Style="background:#eaf2ff;color:#0b57d0;border:1px solid #d7e6ff;border-radius:8px;padding:8px 14px;" />
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>
    </EditForm>
</RadzenCard>

@code {
    private CariGrup cariGrup = new();
    private List<Firma> firmalar = new();

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
    }

    private async Task HandleValidSubmit()
    {
        await CariGrupService.AddAsync(cariGrup);

        NotificationService.Notify(
            NotificationSeverity.Success,
            "Başarılı",
            "Cari grup kaydı eklendi.");

        NavigationManager.NavigateTo("/current-groups");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/current-groups");
    }
}