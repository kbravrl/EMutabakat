@page "/cari-grup/ekle"

@inject ICariGrupService CariGrupService
@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Cari Grup Ekle</PageTitle>

<RadzenCard class="p-4">
    <RadzenText TextStyle="TextStyle.H4" class="mb-3">Yeni Cari Grup Ekle</RadzenText>

    <EditForm Model="@cariGrup" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <RadzenRow Gap="16px">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Firma" Style="width:100%;">
                    <RadzenDropDown Data="@firmalar"
                                    TextProperty="FirmaAdi"
                                    ValueProperty="FirmaId"
                                    @bind-Value="cariGrup.FirmaId"
                                    Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Cari Grup Adı" Style="width:100%;">
                    <RadzenTextBox @bind-Value="cariGrup.CariGrupAdi" Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" class="mt-3">
                    <RadzenButton Text="Kaydet" Icon="save" ButtonType="ButtonType.Submit" />
                    <RadzenButton Text="İptal" Icon="close" ButtonStyle="ButtonStyle.Secondary" Click="@Cancel" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    </EditForm>
</RadzenCard>

@code {
    private CariGrup cariGrup = new();
    private List<Firma> firmalar = new();

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
    }

    private async Task HandleValidSubmit()
    {
        await CariGrupService.AddAsync(cariGrup);

        NotificationService.Notify(
            NotificationSeverity.Success,
            "Başarılı",
            "Cari grup kaydı eklendi.");

        NavigationManager.NavigateTo("/cari-gruplar");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/cari-gruplar");
    }
}