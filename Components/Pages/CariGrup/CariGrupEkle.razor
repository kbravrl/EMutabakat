@page "/current-groups/add"

@attribute [Authorize]

@using EMutabakat.Models
@using EMutabakat.Services.Interfaces
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Radzen

@inject ICariGrupService CariGrupService
@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Cari Grup Ekle</PageTitle>

<RadzenCard Class="p-4" Style="max-width:900px;margin-left:auto;margin-right:auto;">
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="8px">
        <RadzenText TextStyle="TextStyle.H4">Yeni Cari Grup Ekle</RadzenText>
    </RadzenStack>

    <RadzenDivider />

    <EditForm Model="@cariGrup" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />
 
        <RadzenFieldset Text="Genel Bilgiler" Style="margin-bottom:16px">
            <RadzenRow Gap="16px">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Cari Grup ID *" Style="width:100%;" />
                    <RadzenTextBox Name="CariGrupId"
                                   @bind-Value="cariGrup.CariGrupId"
                                   Placeholder="Cari grup ID giriniz"
                                   Style="width:100%;" />
                    <RadzenRequiredValidator Component="CariGrupId"
                                             Text="Cari grup ID zorunludur."
                                             Popup="true" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Firma *" Style="width:100%;" />
                        <RadzenDropDown Name="FirmaId"
                                        Data="@firmalar"
                                        TextProperty="FirmaAdi"
                                        ValueProperty="FirmaId"
                                        @bind-Value="cariGrup.FirmaId"
                                        Placeholder="Firma seçiniz"
                                        Style="width:100%;" />
                    <RadzenRequiredValidator Component="FirmaId"
                                             Text="Firma seçimi zorunludur."
                                             Popup="true" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Cari Grup Adı *" Style="width:100%;" />
                        <RadzenTextBox Name="CariGrupAdi"
                                       @bind-Value="cariGrup.CariGrupAdi"
                                       Placeholder="Cari grup adı giriniz"
                                       Style="width:100%;" />
                    <RadzenRequiredValidator Component="CariGrupAdi"
                                             Text="Cari grup adı zorunludur."
                                             Popup="true" />
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenStack Orientation="Orientation.Horizontal"
                                 Gap="10px"
                                 JustifyContent="JustifyContent.End"
                                 Class="mt-3">
                        <RadzenButton Text="İptal"
                                      Icon="close"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      Click="@Cancel"
                                      Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px;" />

                        <RadzenButton Text="Kaydet"
                                      Icon="save"
                                      ButtonType="ButtonType.Submit"
                                      Style="background:#eaf2ff;color:#0b57d0;border:1px solid #d7e6ff;border-radius:8px;padding:8px 14px;" />
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>
    </EditForm>
</RadzenCard>

@code {
    private CariGrup cariGrup = new();
    private List<Firma> firmalar = new();

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
        cariGrup.CariGrupId = await CariGrupService.GenerateNextCariGrupIdAsync();
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            await CariGrupService.AddAsync(cariGrup);

            NotificationService.Notify(
                NotificationSeverity.Success,
                "Başarılı",
                "Cari grup kaydı eklendi.");

            NavigationManager.NavigateTo("/current-groups");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Warning,
                "Uyarı",
                ex.Message);
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/current-groups");
    }
}