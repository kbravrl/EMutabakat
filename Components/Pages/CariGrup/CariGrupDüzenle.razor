@page "/current-groups/edit/{id}"

@attribute [Authorize]

@inject ICariGrupService CariGrupService
@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Cari Grup Düzenle</PageTitle>

@if (cariGrup == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Kayıt bulunamadı.</RadzenAlert>
}
else
{
    <RadzenCard Class="p-4" Style="max-width:900px;margin-left:auto;margin-right:auto;">
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="8px">
            <RadzenText TextStyle="TextStyle.H4">Cari Grup Düzenle</RadzenText>
        </RadzenStack>

        <RadzenDivider />

        <EditForm Model="@cariGrup" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />

            <RadzenFieldset Text="Genel Bilgiler" Style="margin-bottom:16px">
                <RadzenRow Gap="16px">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Cari Grup ID *" Style="width:100%;" />
                        <RadzenTextBox Name="CariGrupId"
                                       @bind-Value="cariGrup.CariGrupId"
                                       Style="width:100%;" />

                        <RadzenRequiredValidator Component="CariGrupId" Text="Cari grup ID zorunludur." Popup="true" />
                        <ValidationMessage For="@(() => cariGrup.CariGrupId)" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Firma *" Style="width:100%;" />
                            <RadzenDropDown Name="FirmaId"
                                            Data="@firmalar"
                                            TextProperty="FirmaAdi"
                                            ValueProperty="FirmaId"
                                            @bind-Value="cariGrup.FirmaId"
                                            Style="width:100%;" />

                            <RadzenRequiredValidator Component="FirmaId" Text="Firma seçimi zorunludur." Popup="true" />
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Cari Grup Adı *" Style="width:100%;" />
                            <RadzenTextBox Name="CariGrupAdi"
                                           @bind-Value="cariGrup.CariGrupAdi"
                                           Style="width:100%;" />

                            <RadzenRequiredValidator Component="CariGrupAdi" Text="Cari grup adı zorunludur." Popup="true" />
                        <ValidationMessage For="@(() => cariGrup.CariGrupAdi)" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Durum *" Style="width:100%;" />
                        <RadzenDropDown Name="CariGrupAktifPasif"
                                        Data="@durumlar"
                                        TextProperty="Text"
                                        ValueProperty="Value"
                                        @bind-Value="cariGrup.CariGrupAktifPasif"
                                        Style="width:100%;" />

                        <RadzenRequiredValidator Component="CariGrupAktifPasif" Text="Aktif/Pasif bilgisi zorunludur." Popup="true" />
                    </RadzenColumn>
                    <RadzenColumn Size="12">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" JustifyContent="JustifyContent.End" Class="mt-3">
                            <RadzenButton Text="İptal" Icon="close" ButtonStyle="ButtonStyle.Secondary" Click="@Cancel" Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px; font-size:15px;" />
                            <RadzenButton Text="Güncelle" Icon="save" ButtonType="ButtonType.Submit" Style="background:#eaf2ff;color:#0b57d0;border:1px solid #d7e6ff;border-radius:8px;padding:8px 14px; font-size:15px;" />
                        </RadzenStack>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenFieldset>
        </EditForm>
    </RadzenCard>
}

@code {
    [Parameter] public string id { get; set; } = string.Empty;

    private CariGrup? cariGrup;
    private List<Firma> firmalar = new();
    private List<DurumOption> durumlar = new()
    {
        new() { Text = "Aktif", Value = 1 },
        new() { Text = "Pasif", Value = 0 }
    };

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
        cariGrup = await CariGrupService.GetByIdAsync(id);
        if (cariGrup != null)
        {
            cariGrup.OriginalCariGrupId = cariGrup.CariGrupId;
        }
    }

    private async Task HandleValidSubmit()
    {
        if (cariGrup == null)
            return;

        try
        {
            var result = await CariGrupService.UpdateAsync(cariGrup);

            if (result != null)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Cari grup kaydı güncellendi.");
                NavigationManager.NavigateTo("/current-groups");
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Hata", "Cari grup kaydı güncellenemedi.");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", ex.Message);
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/current-groups");
    }

    private class DurumOption
    {
        public string Text { get; set; } = string.Empty;
        public int Value { get; set; }
    }
}