@page "/cari-grup/düzenle/{id:int}"

@inject ICariGrupService CariGrupService
@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Cari Grup Düzenle</PageTitle>

@if (cariGrup == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Kayıt bulunamadı.</RadzenAlert>
}
else
{
    <RadzenCard class="p-4">
        <RadzenText TextStyle="TextStyle.H4" class="mb-3">Cari Grup Düzenle</RadzenText>

        <EditForm Model="@cariGrup" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <RadzenRow Gap="16px">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Firma" Style="width:100%;">
                        <RadzenDropDown Data="@firmalar"
                                        TextProperty="FirmaAdi"
                                        ValueProperty="FirmaId"
                                        @bind-Value="cariGrup.FirmaId"
                                        Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Cari Grup Adı" Style="width:100%;">
                        <RadzenTextBox @bind-Value="cariGrup.CariGrupAdi" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" class="mt-3">
                        <RadzenButton Text="Güncelle" Icon="save" ButtonType="ButtonType.Submit" />
                        <RadzenButton Text="İptal" Icon="close" ButtonStyle="ButtonStyle.Secondary" Click="@Cancel" />
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </EditForm>
    </RadzenCard>
}

@code {
    [Parameter] public int id { get; set; }

    private CariGrup? cariGrup;
    private List<Firma> firmalar = new();

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
        cariGrup = await CariGrupService.GetByIdAsync(id);
    }

    private async Task HandleValidSubmit()
    {
        if (cariGrup == null)
            return;

        var result = await CariGrupService.UpdateAsync(cariGrup);

        if (result != null)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Cari grup kaydı güncellendi.");
            NavigationManager.NavigateTo("/cari-grup");
        }
        else
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", "Cari grup kaydı güncellenemedi.");
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/cari-grup");
    }
}