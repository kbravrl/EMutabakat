@page "/"

@attribute [Authorize]

@using MutabakatModel = EMutabakat.Models.Mutabakat

@inject IFirmaService FirmaService
@inject ICariService CariService
@inject IMutabakatService MutabakatService
@inject IKullaniciService KullaniciService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Kontrol Paneli</PageTitle>

<RadzenStack Gap="1.5rem" class="p-4">
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenColumn Size="12" SizeMD="8">
            <RadzenText TextStyle="TextStyle.H4">Kontrol Paneli</RadzenText>
            <RadzenText TextStyle="TextStyle.Body2" Style="color:#666">Özet metrikler ve mutabakat performansı</RadzenText>
        </RadzenColumn>
    </RadzenRow>
    
    <RadzenRow Gap="16px">
        <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
            <RadzenCard Style="border-left:4px solid #4c6ef5;">
                <RadzenStack Gap="0.5rem">
                    <RadzenText TextStyle="TextStyle.Subtitle2" Style="color:#4c6ef5">Firmalar</RadzenText>
                    <RadzenText TextStyle="TextStyle.H4">@firmaCount</RadzenText>
                    <RadzenButton Text="Firmalara git" Icon="business" Style="font-size:14px;" ButtonStyle="ButtonStyle.Light" Click='@(() => NavigationManager.NavigateTo("/companies"))' />
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>

        <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
            <RadzenCard Style="border-left:4px solid #20c997;">
                <RadzenStack Gap="0.5rem">
                    <RadzenText TextStyle="TextStyle.Subtitle2" Style="color:#20c997">Cariler</RadzenText>
                    <RadzenText TextStyle="TextStyle.H4">@cariCount</RadzenText>
                    <RadzenButton Text="Carilere git" Icon="account_circle" Style="font-size:14px;" ButtonStyle="ButtonStyle.Light" Click='@(() => NavigationManager.NavigateTo("/currents"))' />
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>

        <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
            <RadzenCard Style="border-left:4px solid #f59f00;">
                <RadzenStack Gap="0.5rem">
                    <RadzenText TextStyle="TextStyle.Subtitle2" Style="color:#f59f00">Mutabakatlar</RadzenText>
                    <RadzenText TextStyle="TextStyle.H4">@mutabakatCount</RadzenText>
                    <RadzenButton Text="Mutabakatlara git" Icon="description" Style="font-size:14px;" ButtonStyle="ButtonStyle.Light" Click='@(() => NavigationManager.NavigateTo("/reconciliations"))' />
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <RadzenColumn Size="12" SizeMD="6" SizeLG="4">
                    <RadzenCard Style="border-left:4px solid #845ef7;">
                        <RadzenStack Gap="0.5rem">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color:#845ef7">Kullanıcılar</RadzenText>
                            <RadzenText TextStyle="TextStyle.H4">@kullaniciCount</RadzenText>
                            <RadzenButton Text="Kullanıcılara git" Icon="people" Style="font-size:14px;" ButtonStyle="ButtonStyle.Light" Click='@(() => NavigationManager.NavigateTo("/users"))' />
                        </RadzenStack>
                    </RadzenCard>
                </RadzenColumn>
            </Authorized>
        </AuthorizeView>
    </RadzenRow>

    <RadzenCard Style="background:linear-gradient(135deg,#5f3dc4,#7950f2);color:white;">
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenColumn Size="12" SizeMD="8">
                <RadzenText TextStyle="TextStyle.H5" Style="color:white">Özel Mutabakat Analizi</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color:rgba(255,255,255,0.8)">Dönem ve bakiye tipine göre analizleri inceleyin.</RadzenText>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4" Style="text-align:right">
                <RadzenButton ButtonStyle="ButtonStyle.Light"
                              Style="color:white;background:transparent;border:1px solid rgba(255,255,255,0.6); font-size:14px;"
                              Icon="search"
                              Text="Detaylı incele"
                              Click='@(() => NavigationManager.NavigateTo("/reconciliations"))' />
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>

    <RadzenCard>
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="mb-2">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenText TextStyle="TextStyle.H6">Özet Mutabakat Analizi</RadzenText>
                <RadzenText TextStyle="TextStyle.Body2" Style="color:#666">Seçili dönem ve bakiye tipine göre özet durum.</RadzenText>
            </RadzenColumn>
        </RadzenRow>

        <RadzenRow Gap="1rem" class="mb-3">
            <RadzenColumn Size="12" SizeMD="3">
                <RadzenDropDown TValue="string"
                                Style="width:100%"
                                Placeholder="Bakiye Tipi"
                                Data="bakiyeTipiOptions"
                                TextProperty="Text"
                                ValueProperty="Value"
                                @bind-Value="selectedBakiyeTipi"
                                AllowClear="true"
                                Disabled="@isAnalysisLoading"
                                Change="@(_ => OnFiltersChanged())" />
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="3">
                <RadzenDropDown TValue="string"
                                Style="width:100%"
                                Placeholder="Dönem"
                                Data="periodOptions"
                                TextProperty="Text"
                                ValueProperty="Value"
                                @bind-Value="selectedPeriod"
                                AllowClear="true"
                                Disabled="@isAnalysisLoading"
                                Change="@(_ => OnFiltersChanged())" />
            </RadzenColumn>
        </RadzenRow>

        @if (isAnalysisLoading)
        {
            <div style="min-height:340px;margin-top:15px;border-top:1px dashed #ddd;display:flex;align-items:center;justify-content:center">
                <RadzenStack AlignItems="AlignItems.Center" Gap="0.75rem">
                    <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate"
                                               ShowValue="false"
                                               Size="ProgressBarCircularSize.Large" />
                    <RadzenText TextStyle="TextStyle.Body2" Style="color:#666">Özet mutabakat analizi yükleniyor...</RadzenText>
                </RadzenStack>
            </div>
        }
        else
        {
            <div style="margin-top:15px;border-top:1px dashed #ddd;padding-top:15px">
                <RadzenRow Gap="16px">
                    <RadzenColumn Size="12" SizeMD="3">
                        <RadzenCard Style="text-align:center">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color:#666">İlk Gönderim</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:600">@(firstSendDate?.ToString("dd.MM.yyyy") ?? "---")</RadzenText>
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="3">
                        <RadzenCard Style="text-align:center">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color:#666">Tahmini Bitiş</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:600">@(estimatedEndDate?.ToString("dd.MM.yyyy") ?? "---")</RadzenText>
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="3">
                        <RadzenCard Style="text-align:center">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color:#666">Günlük Ortalama</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:600">@gunlukOrtalama</RadzenText>
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="3">
                        <RadzenCard Style="text-align:center">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color:#666">Kalan Gün</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body1" Style="font-weight:600">@kalanGun</RadzenText>
                        </RadzenCard>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow Gap="16px" style="margin-top:15px">
                    <RadzenColumn Size="12" SizeMD="3">
                        <RadzenCard Style="text-align:center">
                            <RadzenText TextStyle="TextStyle.H5" Style="color:#27ae60;font-weight:700">@mutabikCount</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="color:#666">Mutabık</RadzenText>
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="3">
                        <RadzenCard Style="text-align:center">
                            <RadzenText TextStyle="TextStyle.H5" Style="color:#f39c12;font-weight:700">@onayBekleyenCount</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="color:#666">Onay Bekleyen</RadzenText>
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="3">
                        <RadzenCard Style="text-align:center">
                            <RadzenText TextStyle="TextStyle.H5" Style="color:#e74c3c;font-weight:700">@gonderilmeyenCount</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="color:#666">Gönderilmeyen</RadzenText>
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="3">
                        <RadzenCard Style="text-align:center">
                            <RadzenText TextStyle="TextStyle.H5" Style="color:#4c6ef5;font-weight:700">@mutabakatCount</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="color:#666">Toplam</RadzenText>
                        </RadzenCard>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow Gap="16px" JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center" style="margin-top:15px">
                    <RadzenColumn Size="12" SizeMD="4" Style="text-align:center">
                        <RadzenCard>
                            <div style="display:flex;flex-direction:column;align-items:center;gap:6px">
                                <div style="width:90px;height:90px;border-radius:50%;border:8px solid #27ae60;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:20px;line-height:1;box-sizing:border-box;">
                                    @mutabikYuzde%
                                </div>
                                <div style="color:#27ae60;font-weight:700">Mutabık</div>
                                <div style="color:#888">@mutabikCount</div>
                            </div>
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="4" Style="text-align:center">
                        <RadzenCard>
                            <div style="display:flex;flex-direction:column;align-items:center;gap:6px">
                                <div style="width:90px;height:90px;border-radius:50%;border:8px solid #f39c12;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:20px;line-height:1;box-sizing:border-box;">
                                    @onayBekleyenYuzde%
                                </div>
                                <div style="color:#f39c12;font-weight:700">Onay Bekleyen</div>
                                <div style="color:#888">@onayBekleyenCount</div>
                            </div>
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="4" Style="text-align:center">
                        <RadzenCard>
                            <div style="display:flex;flex-direction:column;align-items:center;gap:6px">
                                <div style="width:90px;height:90px;border-radius:50%;border:8px solid #e74c3c;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:20px;line-height:1;box-sizing:border-box;">
                                    @gonderilmeyenYuzde%
                                </div>
                                <div style="color:#e74c3c;font-weight:700">Gönderilmeyen</div>
                                <div style="color:#888">@gonderilmeyenCount</div>
                            </div>
                        </RadzenCard>
                    </RadzenColumn>
                </RadzenRow>

                <RadzenRow Gap="16px" style="margin-top:20px">
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:600;margin-bottom:4px">Durum Dağılımı</RadzenText>
                            <table style="width:100%;border-collapse:collapse">
                                <thead>
                                    <tr>
                                        <th style="text-align:left;padding:8px;border-bottom:1px solid #ddd">Durum</th>
                                        <th style="text-align:right;padding:8px;border-bottom:1px solid #ddd">Toplam Adet</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in tableRows)
                                    {
                                        <tr>
                                            <td style="padding:6px;border-bottom:1px solid #f1f1f1">
                                                <div>
                                                    @row.Label
                                                </div>
                                            </td>
                                            <td style="padding:6px;border-bottom:1px solid #f1f1f1;text-align:right;font-weight:700">@row.Count</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </RadzenCard>
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenCard>
                            <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight:600;margin-bottom:4px">Döviz Bazlı Bakiye Dağılımı</RadzenText>
                            <table style="width:100%;border-collapse:collapse">
                                <thead>
                                    <tr>
                                        <th style="text-align:left;padding:8px;border-bottom:1px solid #ddd">Döviz</th>
                                        <th style="text-align:right;padding:8px;border-bottom:1px solid #ddd">Borç</th>
                                        <th style="text-align:right;padding:8px;border-bottom:1px solid #ddd">Alacak</th>
                                        <th style="text-align:right;padding:8px;border-bottom:1px solid #ddd">Toplam</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (currencyBalanceRows.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="4" style="padding:8px;border-bottom:1px solid #f1f1f1;color:#888">Kayıt bulunamadı.</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var row in currencyBalanceRows)
                                        {
                                            <tr>
                                                <td style="padding:6px;border-bottom:1px solid #f1f1f1">@row.Currency</td>
                                                <td style="padding:6px;border-bottom:1px solid #f1f1f1;text-align:right;font-weight:700">@row.Borc.ToString("N2")</td>
                                                <td style="padding:6px;border-bottom:1px solid #f1f1f1;text-align:right;font-weight:700">@row.Alacak.ToString("N2")</td>
                                                <td style="padding:6px;border-bottom:1px solid #f1f1f1;text-align:right;font-weight:700">@row.Total.ToString("N2")</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </RadzenCard>
                    </RadzenColumn>
                </RadzenRow>
            </div>
        }
    </RadzenCard>
</RadzenStack>

@code {
    private bool isAnalysisLoading = true;

    private int firmaCount;
    private int cariCount;
    private int mutabakatCount;
    private int kullaniciCount;

    private int mutabikCount;
    private int mutabikDegilCount;
    private int onayBekleyenCount;
    private int cevaplanmayanCount;
    private int okunmayanCount;
    private int gonderilmeyenCount;
    private int gonderildiCount;

    private int mutabikYuzde;
    private int onayBekleyenYuzde;
    private int gonderilmeyenYuzde;

    private int gunlukOrtalama;
    private int kalanGun;

    private List<MutabakatModel> allMutabakatlar = new();

    private string? selectedPeriod;
    private string? selectedBakiyeTipi;
    private DateTime? startDate;
    private DateTime? endDate;
    private DateTime? firstSendDate;
    private DateTime? estimatedEndDate;
    private int dayCount = 0;

    private List<DashboardRow> tableRows = new();
    private List<CurrencyBalanceRow> currencyBalanceRows = new();

    private List<FilterOption<int?>> statusOptions = new()
    {
        new() { Text = "Kaydedildi", Value = 1 },
        new() { Text = "Gönderildi", Value = 2 },
        new() { Text = "Hatırlatma", Value = 3 },
        new() { Text = "Mutabık", Value = 4 },
        new() { Text = "Mutabık Değil", Value = 5 }
    };

    private List<FilterOption<string>> bakiyeTipiOptions = new()
    {
        new() { Text = "Borç", Value = "B" },
        new() { Text = "Alacak", Value = "A" }
    };

    private List<FilterOption<string>> periodOptions = new();

    public class FilterOption<T>
    {
        public string Text { get; set; } = string.Empty;
        public T? Value { get; set; }
    }

    private class DashboardRow
    {
        public string Label { get; set; } = string.Empty;
        public string Color { get; set; } = "#3498db";
        public int Count { get; set; }
    }

    private class CurrencyBalanceRow
    {
        public string Currency { get; set; } = string.Empty;
        public decimal Borc { get; set; }
        public decimal Alacak { get; set; }
        public decimal Total { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private void OnFiltersChanged()
    {
        if (isAnalysisLoading)
            return;

        UpdateAnalysis();
        StateHasChanged();
    }

    private void ResetAnalysis()
    {
        firstSendDate = null;
        estimatedEndDate = null;
        gunlukOrtalama = 0;
        kalanGun = 0;
        dayCount = 0;

        mutabakatCount = 0;
        mutabikCount = 0;
        mutabikDegilCount = 0;
        onayBekleyenCount = 0;
        cevaplanmayanCount = 0;
        okunmayanCount = 0;
        gonderilmeyenCount = 0;
        gonderildiCount = 0;

        mutabikYuzde = 0;
        onayBekleyenYuzde = 0;
        gonderilmeyenYuzde = 0;

        tableRows = new List<DashboardRow>();
        currencyBalanceRows = new List<CurrencyBalanceRow>();
    }

    private void UpdateAnalysis()
    {
        try
        {
            var list = allMutabakatlar.AsEnumerable();

            if (string.IsNullOrWhiteSpace(selectedPeriod))
            {
                ResetAnalysis();
                return;
            }

            if (!string.IsNullOrWhiteSpace(selectedBakiyeTipi))
                list = list.Where(x => x.MutabakatBakiyeTipi == selectedBakiyeTipi);

            if (!string.IsNullOrWhiteSpace(selectedPeriod))
            {
                var parts = selectedPeriod.Split('.');
                if (parts.Length == 2 &&
                    int.TryParse(parts[0], out var mm) &&
                    int.TryParse(parts[1], out var yyyy))
                {
                    list = list.Where(x => x.MutabakatTarihi.Month == mm && x.MutabakatTarihi.Year == yyyy);
                }
            }

            if (startDate.HasValue)
                list = list.Where(x => x.MutabakatTarihi.Date >= startDate.Value.Date);

            if (endDate.HasValue)
                list = list.Where(x => x.MutabakatTarihi.Date <= endDate.Value.Date);

            var filtered = list.ToList();

            mutabakatCount = filtered.Count;
            mutabikCount = filtered.Count(x => (int)x.Status == 4);
            mutabikDegilCount = filtered.Count(x => (int)x.Status == 5);
            onayBekleyenCount = filtered.Count(x => (int)x.Status == 2 || (int)x.Status == 3);
            cevaplanmayanCount = onayBekleyenCount;
            okunmayanCount = filtered.Count(x => x.MutabakatGonderimTarihSaat == null);
            gonderilmeyenCount = filtered.Count(x => (int)x.Status == 1);
            gonderildiCount = filtered.Count(x => (int)x.Status == 2);

            tableRows = new List<DashboardRow>
            {
                new DashboardRow { Label = "Toplam", Color = "#3498db", Count = filtered.Count },
                new DashboardRow { Label = "Kaydedildi", Color = "#95a5a6", Count = gonderilmeyenCount },
                new DashboardRow { Label = "Gönderildi", Color = "#3498db", Count = gonderildiCount },
                new DashboardRow { Label = "Mutabık", Color = "#27ae60", Count = mutabikCount },
                new DashboardRow { Label = "Mutabık Değil", Color = "#e74c3c", Count = mutabikDegilCount }
            };

            currencyBalanceRows = filtered
                .GroupBy(x => string.IsNullOrWhiteSpace(x.MutabakatDovizKodu) ? "TL" : x.MutabakatDovizKodu)
                .Select(group =>
                {
                    var borc = group.Where(x => x.MutabakatBakiyeTipi == "B").Sum(x => x.MutabakatBakiye);
                    var alacak = group.Where(x => x.MutabakatBakiyeTipi == "A").Sum(x => x.MutabakatBakiye);
                    return new CurrencyBalanceRow
                    {
                        Currency = group.Key,
                        Borc = borc,
                        Alacak = alacak,
                        Total = borc + alacak
                    };
                })
                .OrderByDescending(x => x.Total)
                .ToList();

            if (filtered.Count > 0)
            {
                mutabikYuzde = (int)Math.Round((double)mutabikCount * 100 / filtered.Count);
                onayBekleyenYuzde = (int)Math.Round((double)onayBekleyenCount * 100 / filtered.Count);
                gonderilmeyenYuzde = (int)Math.Round((double)gonderilmeyenCount * 100 / filtered.Count);
            }
            else
            {
                mutabikYuzde = 0;
                onayBekleyenYuzde = 0;
                gonderilmeyenYuzde = 0;
            }

            firstSendDate = filtered
                .Where(x => x.MutabakatGonderimTarihSaat.HasValue)
                .OrderBy(x => x.MutabakatGonderimTarihSaat)
                .Select(x => x.MutabakatGonderimTarihSaat)
                .FirstOrDefault();

            dayCount = firstSendDate.HasValue
                ? Math.Max((DateTime.Today.Date - firstSendDate.Value.Date).Days + 1, 1)
                : 0;

            var sentCount = filtered.Count(x => x.MutabakatGonderimTarihSaat.HasValue);

            gunlukOrtalama = dayCount > 0
                ? (int)Math.Round((double)sentCount / dayCount)
                : sentCount;

            var today = DateTime.Today;

            var oneMonthAgo = today.AddMonths(-1);
            var twoMonthsAgo = today.AddMonths(-2);
            var threeMonthsAgo = today.AddMonths(-3);

            var x1 = filtered.Count(x =>
                x.MutabakatTarihi.Year == oneMonthAgo.Year &&
                x.MutabakatTarihi.Month == oneMonthAgo.Month);

            var x2 = filtered.Count(x =>
                x.MutabakatTarihi.Year == twoMonthsAgo.Year &&
                x.MutabakatTarihi.Month == twoMonthsAgo.Month);

            var x3 = filtered.Count(x =>
                x.MutabakatTarihi.Year == threeMonthsAgo.Year &&
                x.MutabakatTarihi.Month == threeMonthsAgo.Month);

            double weightedMonthlyAvg = (x1 * 3 + x2 * 2 + x3 * 1) / 6.0;
            double weightedDailyAvg = weightedMonthlyAvg / 30.0;

            var remainingCount = filtered.Count(x =>
                (int)x.Status != 4 && (int)x.Status != 5);

            if (weightedDailyAvg > 0 && remainingCount > 0)
            {
                var estimatedDays = (int)Math.Ceiling(remainingCount / weightedDailyAvg);
                estimatedEndDate = DateTime.Today.AddDays(estimatedDays);
            }
            else if (remainingCount == 0)
            {
                estimatedEndDate = DateTime.Today;
            }
            else
            {
                estimatedEndDate = null;
            }

            kalanGun = estimatedEndDate.HasValue
                ? Math.Max((estimatedEndDate.Value.Date - DateTime.Today.Date).Days, 0)
                : 0;
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", ex.Message);
        }
    }

    private async Task LoadDashboardAsync()
    {
        isAnalysisLoading = true;
        await Task.Yield();

        await Task.Delay(500);

        try
        {
            var firmalar = await FirmaService.GetAllAsync();
            var cariler = await CariService.GetAllAsync();
            var mutabakatlar = await MutabakatService.GetAllAsync();
            var kullanicilar = await KullaniciService.GetAllAsync();

            firmaCount = firmalar.Count;
            cariCount = cariler.Count;
            kullaniciCount = kullanicilar.Count;

            allMutabakatlar = mutabakatlar;

            periodOptions = allMutabakatlar
                .Select(x => new { Month = x.MutabakatTarihi.Month, Year = x.MutabakatTarihi.Year })
                .Distinct()
                .OrderByDescending(a => new DateTime(a.Year, a.Month, 1))
                .Select(a => new FilterOption<string>
                {
                    Value = $"{a.Month:00}.{a.Year}",
                    Text = $"{a.Month:00}.{a.Year}"
                })
                .ToList();

            selectedPeriod = periodOptions.FirstOrDefault()?.Value;

            UpdateAnalysis();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", ex.Message);
        }
        finally
        {
            isAnalysisLoading = false;
        }
    }
}
