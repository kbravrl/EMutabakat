@page "/currents/edit/{id:int}"

@attribute [Authorize]

@inject ICariService CariService
@inject IFirmaService FirmaService
@inject ICariGrupService CariGrupService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Cari Düzenle</PageTitle>

@if (cari == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Kayıt bulunamadı.</RadzenAlert>
}
else
{
    <RadzenCard Class="p-4" Style="max-width:900px;margin-left:auto;margin-right:auto;">
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="8px">
            <RadzenText TextStyle="TextStyle.H4">Cari Düzenle</RadzenText>
        </RadzenStack>

        <RadzenDivider />

        <EditForm Model="@cari" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />

            <RadzenFieldset Text="Genel Bilgiler" Style="margin-bottom:16px">
                <RadzenRow Gap="16px">

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Firma *" />
                        <RadzenDropDown Name="FirmaId"
                                        Data="@firmalar"
                                        TextProperty="FirmaAdi"
                                        ValueProperty="FirmaId"
                                        @bind-Value="cari.FirmaId"
                                        Change="@OnFirmaChanged"
                                        Style="width:100%;" />
                        <RadzenRequiredValidator Component="FirmaId" Text="Firma seçiniz." Popup="true" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Cari Grup *" />
                        <RadzenDropDown Name="CariGrupId"
                                        Data="@filteredCariGruplar"
                                        TextProperty="CariGrupAdi"
                                        ValueProperty="CariGrupId"
                                        @bind-Value="cari.CariGrupId"
                                        Style="width:100%;" />
                        <RadzenRequiredValidator Component="CariGrupId" Text="Cari grup seçiniz." Popup="true" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Cari Adı *" />
                        <RadzenTextBox Name="CariAdi" @bind-Value="cari.CariAdi" Style="width:100%;" />
                        <RadzenRequiredValidator Component="CariAdi" Text="Cari adı zorunludur." Popup="true" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Cari Unvan" />
                        <RadzenTextBox @bind-Value="cari.CariUnvan" Style="width:100%;" />
                    </RadzenColumn>

                    <RadzenColumn Size="12">
                        <RadzenLabel Text="Adres" />
                        <RadzenTextArea @bind-Value="cari.CariAdres" Style="width:100%;" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="İlçe" />
                        <RadzenTextBox @bind-Value="cari.CariIlce" Style="width:100%;" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="İl" />
                        <RadzenTextBox @bind-Value="cari.CariIl" Style="width:100%;" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Vergi Dairesi *" />
                        <RadzenTextBox Name="CariVergiDairesi" @bind-Value="cari.CariVergiDairesi" Style="width:100%;" />
                        <RadzenRequiredValidator Component="CariVergiDairesi" Text="Vergi dairesi zorunludur." Popup="true" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Vergi Numarası *" />
                        <RadzenTextBox Name="CariVergiNumarasi" @bind-Value="cari.CariVergiNumarasi" Style="width:100%;" />
                        <RadzenRequiredValidator Component="CariVergiNumarasi" Text="Vergi numarası zorunludur." Popup="true" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Web Adresi" />
                        <RadzenTextBox @bind-Value="cari.CariWebAdresi" Style="width:100%;" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Yetkili Adı Soyadı" />
                        <RadzenTextBox @bind-Value="cari.CariYetkiliAdiSoyadi" Style="width:100%;" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenLabel Text="Yetkili Telefon" />
                        <RadzenTextBox @bind-Value="cari.CariYetkiliTelefon" Style="width:100%;" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenLabel Text="Yetkili GSM" />
                        <RadzenTextBox @bind-Value="cari.CariYetkiliGsm" Style="width:100%;" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenLabel Text="Yetkili Mail *" />
                        <RadzenTextBox Name="CariYetkiliMail" @bind-Value="cari.CariYetkiliMail" Style="width:100%;" />
                        <RadzenRequiredValidator Component="CariYetkiliMail" Text="Yetkili mail zorunludur." Popup="true" />
                        <RadzenEmailValidator Component="CariYetkiliMail" Text="Geçerli bir mail adresi giriniz." Popup="true" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenLabel Text="Döviz Kodu" />
                        <RadzenDropDown Data="@dovizKodlari"
                                        TextProperty="Text"
                                        ValueProperty="Value"
                                        @bind-Value="cari.CariDovizKodu"
                                        Style="width:100%;" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="4">
                        <RadzenLabel Text="Aktif / Pasif *" />
                        <RadzenDropDown Name="CariAktifPasif"
                                        Data="@durumlar"
                                        TextProperty="Text"
                                        ValueProperty="Value"
                                        @bind-Value="cari.CariAktifPasif"
                                        Style="width:100%;" />
                        <RadzenRequiredValidator Component="CariAktifPasif" Text="Aktif/Pasif bilgisi zorunludur." Popup="true" />
                    </RadzenColumn>

                    <RadzenColumn Size="12">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" JustifyContent="JustifyContent.End" Class="mt-3">
                            <RadzenButton Text="İptal" Icon="close" ButtonStyle="ButtonStyle.Secondary" Click="@Cancel" />
                            <RadzenButton Text="Kaydet" Icon="save" ButtonType="ButtonType.Submit" />
                        </RadzenStack>
                    </RadzenColumn>

                </RadzenRow>
            </RadzenFieldset>
        </EditForm>
    </RadzenCard>
}

@code {
    [Parameter] public int id { get; set; }

    private Cari? cari;
    private List<Firma> firmalar = new();
    private List<CariGrup> cariGruplar = new();
    private List<CariGrup> filteredCariGruplar = new();

    private class DovizSecenek
    {
        public int Value { get; set; }
        public string Text { get; set; } = string.Empty;
    }

    private class DurumOption
    {
        public int Value { get; set; }
        public string Text { get; set; } = string.Empty;
    }

    private List<DovizSecenek> dovizKodlari = new()
    {
        new() { Value = 0, Text = "00 - TL" },
        new() { Value = 1, Text = "01 - USD" },
        new() { Value = 2, Text = "02 - EUR" }
    };

    private List<DurumOption> durumlar = new()
    {
        new() { Value = 1, Text = "Aktif" },
        new() { Value = 0, Text = "Pasif" }
    };

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
        cariGruplar = await CariGrupService.GetAllAsync();
        cari = await CariService.GetByIdAsync(id);

        if (cari != null)
        {
            filteredCariGruplar = cariGruplar
                .Where(x => x.FirmaId == cari.FirmaId)
                .ToList();
        }
    }

    private void OnFirmaChanged(object value)
    {
        if (cari == null)
            return;

        if (value is int firmaId)
        {
            filteredCariGruplar = cariGruplar
                .Where(x => x.FirmaId == firmaId)
                .ToList();

            cari.CariGrupId = string.Empty;
        }
    }

    private async Task HandleValidSubmit()
    {
        if (cari == null)
            return;

        try
        {
            var result = await CariService.UpdateAsync(cari);

            if (result == null)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Hata", "Cari kaydı bulunamadı.");
                return;
            }

            NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Cari kaydı güncellendi.");
            NavigationManager.NavigateTo("/currents");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", ex.Message);
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/currents");
    }
}