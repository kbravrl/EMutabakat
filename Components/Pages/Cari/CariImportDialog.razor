@using Components.Pages.Mutabakat
@inject ICariService CariService
@inject IFirmaService FirmaService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager

<div class="p-2">
    <RadzenText TextStyle="TextStyle.H6">Excel Dosyası Seç</RadzenText>

    <div class="my-3">
        <RadzenLabel Text="Firma *" Style="width:100%;" />
        <RadzenDropDown Data="@firmalar"
                        TextProperty="FirmaAdi"
                        ValueProperty="FirmaId"
                        @bind-Value="selectedFirmaId"
                        Placeholder="Firma seçiniz"
                        Style="width:100%;" />
    </div>

    <div class="my-4">
        <InputFile OnChange="HandleSelected" Accept=".xls,.xlsx" />
    </div>

    <div class="my-2">
        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
            Örnek Excel dosyasını aşağıdan indirip kullanabilirsiniz.
        </RadzenAlert>
    </div>

    <div class="rz-text-align-right">
        <RadzenButton Text="Örnek excel dosyası" Icon="download" Style="font-size:15px;" ButtonStyle="ButtonStyle.Success" Click="DownloadTemplate" />
        <RadzenButton Text="Yükle" Icon="file_upload" Style="font-size:15px;" Click="Upload" Disabled="@isUploading" />
        <RadzenButton Text="İptal" Icon="close" Style="font-size:15px;"  Click="Cancel" ButtonStyle="ButtonStyle.Secondary" />
    </div>
</div>

@code {
    private IBrowserFile? selectedFile;
    private bool isUploading = false;
    private int selectedFirmaId;
    private List<Firma> firmalar = new();

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
    }

    private void HandleSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }
    
    private void DownloadTemplate()
    {
        NavigationManager.NavigateTo("/templates/CariTemplate.xlsx", forceLoad: true);
    }

    private async Task Upload()
    {
        if (isUploading) return;
        if (selectedFile == null)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Lütfen bir dosya seçin.");
            return;
        }

        if (selectedFirmaId <= 0)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Lütfen bir firma seçin.");
            return;
        }

        isUploading = true;

        try
        {
            await using var ms = new MemoryStream();
            await selectedFile.OpenReadStream(50 * 1024 * 1024).CopyToAsync(ms);
            ms.Position = 0;

            var (createdCount, updatedCount, errors) = await CariService.ImportFromExcelAsync(ms, selectedFile.Name, selectedFirmaId);

            if (errors != null && errors.Count > 0)
            {
                var parameters = new Dictionary<string, object?> { ["Errors"] = errors };
                await DialogService.OpenAsync(string.Empty, typeof(ImportErrors), parameters, new DialogOptions { Width = "700px", Height = "400px" });
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Success, "Başarılı", $"Oluşturulan kayıt: {createdCount}, güncellenen kayıt: {updatedCount}");
            }

            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", ex.Message);
        }
        finally
        {
            isUploading = false;
        }
    }

    private void Cancel()
    {
        DialogService.Close(false);
    }
}
