@inject IKullaniciService KullaniciService
@inject IFirmaService FirmaService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject NavigationManager NavigationManager

<div class="p-2">
    <RadzenText TextStyle="TextStyle.H6">Excel Dosyası Seç</RadzenText>

    <div class="my-3">
        <RadzenLabel Text="Firmalar *" Style="width:100%;" />
        <RadzenDropDown Data="@firmalar"
                        TextProperty="FirmaAdi"
                        ValueProperty="FirmaId"
                        @bind-Value="selectedFirmaIds"
                        Multiple="true"
                        AllowClear="true"
                        Placeholder="Firma seçiniz"
                        Style="width:100%;" />
    </div>

    <div class="my-4">
        <InputFile OnChange="HandleSelected" Accept=".xls,.xlsx" />
    </div>

    <div class="my-2">
        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
            Örnek Excel dosyasını aşağıdan indirip kullanabilirsiniz.
        </RadzenAlert>
    </div>

    <div class="rz-text-align-right">
        <RadzenButton Text="Örnek Excel Dosyası"
                      Icon="download"
                      ButtonStyle="ButtonStyle.Success"
                      Click="DownloadTemplate" />

        <RadzenButton Text="Yükle"
                      Icon="file_upload"
                      Click="Upload"
                      Disabled="@isUploading" />

        <RadzenButton Text="İptal"
                      Icon="close"
                      Click="Cancel"
                      ButtonStyle="ButtonStyle.Secondary" />
    </div>
</div>

@code {
    private IBrowserFile? selectedFile;
    private bool isUploading = false;
    private IEnumerable<int> selectedFirmaIds = Enumerable.Empty<int>();
    private List<Firma> firmalar = new();

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
    }

    private void HandleSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private void DownloadTemplate()
    {
        NavigationManager.NavigateTo("/templates/KullaniciTemplate.xlsx", forceLoad: true);
    }

    private async Task Upload()
    {
        if (isUploading)
            return;

        if (selectedFile == null)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Lütfen bir dosya seçin.");
            return;
        }

        var firmaIdList = selectedFirmaIds?
            .Distinct()
            .ToList() ?? new List<int>();

        if (firmaIdList.Count == 0)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Lütfen en az bir firma seçin.");
            return;
        }

        isUploading = true;

        try
        {
            await using var ms = new MemoryStream();
            await selectedFile.OpenReadStream(50 * 1024 * 1024).CopyToAsync(ms);
            ms.Position = 0;

            var (createdCount, updatedCount, errors) =
                await KullaniciService.ImportFromExcelAsync(ms, selectedFile.Name, firmaIdList);

            if (errors != null && errors.Count > 0)
            {
                var parameters = new Dictionary<string, object?>
                {
                    ["Errors"] = errors
                };

                await DialogService.OpenAsync(
                    string.Empty,
                    typeof(ImportErrors),
                    parameters,
                    new DialogOptions { Width = "700px", Height = "400px" });
            }
            else
            {
                NotificationService.Notify(
                    NotificationSeverity.Success,
                    "Başarılı",
                    $"Oluşturulan kayıt: {createdCount}, güncellenen kayıt: {updatedCount}");
            }

            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", ex.Message);
        }
        finally
        {
            isUploading = false;
        }
    }

    private void Cancel()
    {
        DialogService.Close(false);
    }
}