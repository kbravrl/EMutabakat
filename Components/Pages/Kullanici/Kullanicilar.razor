@page "/users"

@attribute [Authorize]

@inject IKullaniciService KullaniciService
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject NotificationService NotificationService

@inject IJSRuntime JS

<PageTitle>Kullanıcılar</PageTitle>

<RadzenStack Gap="1rem" class="p-4">
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText TextStyle="TextStyle.H4">Kullanıcı Listesi</RadzenText>
        </RadzenColumn>

        <RadzenColumn Size="12" SizeMD="6" class="rz-text-align-end">    
            <div style="display:flex; align-items:center; gap:15px; justify-content:flex-end; width:100%;">
                <img src="/images/excel-export.png"
                     title="Excel Dışa Aktar"
                     @onclick="ExportExcel" 
                     style="width:48px; height:48px; cursor:pointer;" />

                <img src="/images/excel-import.png"
                     title="Excel İçe Aktar"
                     @onclick="OpenImportDialog"
                     style="width:48px; height:48px; cursor:pointer;" />

                <RadzenButton Text="Yeni kullanıcı ekle"
                              Icon="add_circle"
                              Style="font-size:15px;"
                              Click="@GoToCreatePage" />
            </div>
        </RadzenColumn>
    </RadzenRow>

    <RadzenCard>
        <div style="display:flex; align-items:center; gap:8px; flex-wrap:nowrap; width:100%; margin-bottom:1rem;">

            <RadzenTextBox Style="width:340px;"
                           Placeholder="ID/ Ad/ Soyad/ Mail ara"
                           @bind-Value="searchText"
                           Change="@(_ => ApplyFilters())" />

            <RadzenDropDown TValue="string"
                            Style="width:180px;"
                            Placeholder="Durum"
                            Data="@durumlar"
                            TextProperty="Text"
                            ValueProperty="Value"
                            @bind-Value="selectedDurum"
                            AllowClear="true"
                            Change="@(_ => ApplyFilters())" />

            <RadzenButton Text="Temizle"
                          Style="height:36px; white-space:nowrap; font-size:15px;"
                          Icon="filter_alt_off"
                          ButtonStyle="ButtonStyle.Light"
                          Click="@ClearFilters" />

        </div>

        <RadzenDataGrid Data="@filteredKullanicilar"
                        TItem="Kullanici"
                        AllowPaging="true"
                        AllowSorting="true"
                        AllowFiltering="false"
                        PageSize="10"
                        EmptyText="Kayıt bulunamadı">
            <Columns>
                <RadzenDataGridColumn TItem="Kullanici" Property="KullaniciId" Title="ID" Width="100px" />
                <RadzenDataGridColumn TItem="Kullanici" Property="KullaniciAdi" Title="Ad" />
                <RadzenDataGridColumn TItem="Kullanici" Property="KullaniciSoyadi" Title="Soyad" />
                <RadzenDataGridColumn TItem="Kullanici" Property="KullaniciMail" Title="Mail" />
                <RadzenDataGridColumn TItem="Kullanici" Property="KullaniciGsm" Title="GSM" />

                <RadzenDataGridColumn TItem="Kullanici" Title="Firmalar">
                    <Template Context="item">
                        @string.Join(", ",
                            item.Firmalar?
                                .Select(x => x.FirmaAdi)
                                .Where(x => !string.IsNullOrWhiteSpace(x))
                                .Distinct()
                                .ToList() ?? new List<string>())
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Kullanici"
                                      Property="KullaniciAktifPasif"
                                      Title="Durum"
                                      FilterOperator="FilterOperator.Equals"
                                      FilterValue="@aktifDurumFiltre">
                    <Template Context="item">
                        @if (item.KullaniciAktifPasif == "1")
                        {
                            <RadzenBadge Text="Aktif" BadgeStyle="BadgeStyle.Success" />
                        }
                        else
                        {
                            <RadzenBadge Text="Pasif" BadgeStyle="BadgeStyle.Danger" />
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Kullanici" Title="İşlemler" Sortable="false" Filterable="false" Width="220px">
                    <Template Context="item">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenButton Icon="edit"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          Title="Düzenle"
                                          Click="@(() => GoToEditPage(item.KullaniciId))" />

                            <RadzenButton Icon="delete"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Title="Sil"
                                          Click="@(() => DeleteKullanici(item.KullaniciId, item.KullaniciAdi, item.KullaniciSoyadi))" />
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
</RadzenStack>

@code {
    private List<Kullanici> kullanicilar = new();
    private List<Kullanici> filteredKullanicilar = new();

    private string? searchText;
    private string? selectedDurum = "1";
    private string aktifDurumFiltre = "1";

    private List<DurumOptionString> durumlar = new()
    {
        new() { Text = "Aktif", Value = "1" },
        new() { Text = "Pasif", Value = "0" }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadKullanicilarAsync();
    }

    private async Task LoadKullanicilarAsync()
    {
        kullanicilar = await KullaniciService.GetAllAsync();
        ApplyFilters();
    }

    private void GoToCreatePage()
    {
        NavigationManager.NavigateTo("/users/add");
    }

    private void GoToEditPage(string id)
    {
        NavigationManager.NavigateTo($"/users/edit/{id}");
    }

    private async Task DeleteKullanici(string id, string ad, string soyad)
    {
        var confirmed = await DialogService.Confirm(
            $"'{ad} {soyad}' kaydını silmek istediğinize emin misiniz?",
            "Silme Onayı",
            new ConfirmOptions
            {
                OkButtonText = "Evet",
                CancelButtonText = "Vazgeç"
            });

        if (confirmed == true)
        {
            try
            {
                var result = await KullaniciService.DeleteAsync(id);

                if (result)
                {
                    NotificationService.Notify(
                        NotificationSeverity.Success,
                        "Başarılı",
                        "Kullanıcı kaydı silindi.");

                    await LoadKullanicilarAsync();
                }
                else
                {
                    NotificationService.Notify(
                        NotificationSeverity.Warning,
                        "Uyarı",
                        "Kullanıcı kaydı bulunamadı.");
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Uyarı",
                    ex.Message);
            }
        }
    }

    private async Task OpenImportDialog()
    {
        var options = new DialogOptions() { Width = "600px" };
        var result = await DialogService.OpenAsync<KullaniciImportDialog>("Excel İçe Aktar", null, options);
        if (result == true)
        {
            await LoadKullanicilarAsync();
        }
    }

    private async Task ExportExcel()
    {
        try
        {
            var bytes = await KullaniciService.ExportToExcelAsync(kullanicilar);

            if (bytes == null || bytes.Length == 0)
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Uyarı",
                    "Export edilecek kullanıcı kaydı bulunamadı.");
                return;
            }

            var base64 = Convert.ToBase64String(bytes);

            await JS.InvokeVoidAsync(
                "downloadFileFromBase64",
                "Kullanicilar.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                base64);

            NotificationService.Notify(
                NotificationSeverity.Success,
                "Başarılı",
                "Kullanıcılar Excel olarak indirildi.");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Hata",
                ex.Message);
        }
    }

    private void ApplyFilters()
    {
        IEnumerable<Kullanici> query = kullanicilar;

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            var text = searchText.Trim().ToLower();

            query = query.Where(x =>
                (x.KullaniciId != null && x.KullaniciId.ToLower().Contains(text)) ||
                (!string.IsNullOrWhiteSpace(x.KullaniciAdi) && x.KullaniciAdi.ToLower().Contains(text)) ||
                (!string.IsNullOrWhiteSpace(x.KullaniciSoyadi) && x.KullaniciSoyadi.ToLower().Contains(text)) ||
                (!string.IsNullOrWhiteSpace(x.KullaniciMail) && x.KullaniciMail.ToLower().Contains(text)) ||
                (!string.IsNullOrWhiteSpace(x.KullaniciGsm) && x.KullaniciGsm.ToLower().Contains(text))
            );
        }

        if (!string.IsNullOrWhiteSpace(selectedDurum))
        {
            query = query.Where(x => x.KullaniciAktifPasif == selectedDurum);
        }

        aktifDurumFiltre = selectedDurum ?? string.Empty;

        filteredKullanicilar = query.OrderBy(x => x.KullaniciAdi).ToList();
    }

    private void ClearFilters()
    {
        searchText = null;
        selectedDurum = "1";
        ApplyFilters();
    }

    public class DurumOptionString
    {
        public string Value { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
    }
}