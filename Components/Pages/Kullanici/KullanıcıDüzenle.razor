@page "/users/edit/{id}"

@attribute [Authorize(Roles = "Admin")]

@inject IKullaniciService KullaniciService
@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Kullanıcı Düzenle</PageTitle>

@if (isLoading)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="height:6px;" />
}
else if (kullanici == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Kayıt bulunamadı.</RadzenAlert>
}
else
{
    <RadzenCard Class="p-4" Style="max-width:950px;margin-left:auto;margin-right:auto;">
        <RadzenStack AlignItems="AlignItems.Center"
                     JustifyContent="JustifyContent.SpaceBetween"
                     Gap="8px">
            <RadzenText TextStyle="TextStyle.H4">Kullanıcı Düzenle</RadzenText>
        </RadzenStack>

        <RadzenDivider />

        <EditForm Model="@kullanici" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />

            <RadzenFieldset Text="Kullanıcı Bilgileri" Style="margin-bottom:16px">
                <RadzenRow Gap="16px">

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Kullanıcı ID *" />
                        <RadzenTextBox @bind-Value="kullanici.KullaniciId"
                                       Style="width:100%;" />
                        <ValidationMessage For="@(() => kullanici.KullaniciId)" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Firmalar *" />
                        <RadzenDropDown Data="@firmalar"
                                        TextProperty="FirmaAdi"
                                        ValueProperty="FirmaId"
                                        @bind-Value="kullanici.FirmaIds"
                                        Placeholder="Firma seçiniz"
                                        Multiple="true"
                                        AllowClear="true"
                                        Style="width:100%;" />
                        <ValidationMessage For="@(() => kullanici.FirmaIds)" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Rol *" />
                        <RadzenDropDown Data="@roller"
                                        TextProperty="Text"
                                        ValueProperty="Value"
                                        @bind-Value="kullanici.Rol"
                                        Placeholder="Rol seçiniz"
                                        Style="width:100%;" />
                        <ValidationMessage For="@(() => kullanici.Rol)" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Durum *" />
                        <RadzenDropDown Data="@durumlar"
                                        TextProperty="Text"
                                        ValueProperty="Value"
                                        @bind-Value="kullanici.KullaniciAktifPasif"
                                        Placeholder="Durum seçiniz"
                                        Style="width:100%;" />
                        <ValidationMessage For="@(() => kullanici.KullaniciAktifPasif)" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Ad *" />
                        <RadzenTextBox @bind-Value="kullanici.KullaniciAdi"
                                       Placeholder="Ad giriniz"
                                       Style="width:100%;" />
                        <ValidationMessage For="@(() => kullanici.KullaniciAdi)" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Soyad *" />
                        <RadzenTextBox @bind-Value="kullanici.KullaniciSoyadi"
                                       Placeholder="Soyad giriniz"
                                       Style="width:100%;" />
                        <ValidationMessage For="@(() => kullanici.KullaniciSoyadi)" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Mail *" />
                        <RadzenTextBox @bind-Value="kullanici.KullaniciMail"
                                       Placeholder="Mail giriniz"
                                       Style="width:100%;" />
                        <ValidationMessage For="@(() => kullanici.KullaniciMail)" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="GSM" />
                        <RadzenTextBox @bind-Value="kullanici.KullaniciGsm"
                                       Placeholder="05XXXXXXXXX"
                                       Style="width:100%;" />
                        <ValidationMessage For="@(() => kullanici.KullaniciGsm)" />
                    </RadzenColumn>

                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenLabel Text="Yeni Şifre" />
                        <RadzenPassword TValue="string"
                                        Value="@kullanici.Sifre"
                                        ValueChanged="@OnPasswordChanged"
                                        Placeholder="Boş bırakırsanız değişmez"
                                        Style="width:100%;" />
                        <ValidationMessage For="@(() => kullanici.Sifre)" />
                    </RadzenColumn>

                </RadzenRow>
            </RadzenFieldset>

            <RadzenRow>
                <RadzenColumn Size="12">
                    <RadzenStack Orientation="Orientation.Horizontal"
                                 Gap="10px"
                                 JustifyContent="JustifyContent.End"
                                 Class="mt-3">
                        <RadzenButton Text="İptal"
                                      Icon="close"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      Click="@Cancel" />

                        <RadzenButton Text="Güncelle"
                                      Icon="save"
                                      ButtonType="ButtonType.Submit" />
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </EditForm>
    </RadzenCard>
}

@code {
    [Parameter] public string id { get; set; } = string.Empty;

    private Kullanici? kullanici;
    private bool isLoading = true;
    private List<Firma> firmalar = new();

    private List<RolOption> roller = new()
    {
        new() { Text = "Standart", Value = KullaniciRolleri.Standart },
        new() { Text = "Admin", Value = KullaniciRolleri.Admin }
    };

    private List<DurumOption> durumlar = new()
    {
        new() { Text = "Aktif", Value = "1" },
        new() { Text = "Pasif", Value = "0" }
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            firmalar = await FirmaService.GetAllAsync();
            kullanici = await KullaniciService.GetByIdAsync(id);

            if (kullanici != null)
            {
                kullanici.FirmaIds = kullanici.Firmalar?
                    .Select(x => x.FirmaId)
                    .Distinct()
                    .ToList() ?? new List<int>();

                // KRITIK: editte boş string değil null
                kullanici.Sifre = null;
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnPasswordChanged(string? value)
    {
        if (kullanici == null)
            return;

        kullanici.Sifre = string.IsNullOrWhiteSpace(value) ? null : value;
    }

    private async Task HandleValidSubmit()
    {
        if (kullanici == null)
            return;

        try
        {
            kullanici.KullaniciMail = (kullanici.KullaniciMail ?? string.Empty).Trim().ToLowerInvariant();
            kullanici.KullaniciGsm = string.IsNullOrWhiteSpace(kullanici.KullaniciGsm)
                ? null
                : kullanici.KullaniciGsm.Trim();

            kullanici.FirmaIds = kullanici.FirmaIds?.Distinct().ToList() ?? new List<int>();

            if (kullanici.FirmaIds.Count == 0)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "En az bir firma seçimi zorunludur.");
                return;
            }

            await KullaniciService.UpdateAsync(kullanici);

            NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Kullanıcı güncellendi.");
            NavigationManager.NavigateTo("/users");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", ex.Message);
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/users");
    }

    private class DurumOption
    {
        public string Text { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private class RolOption
    {
        public string Text { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }
}