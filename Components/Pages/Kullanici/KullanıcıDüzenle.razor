@page "/users/edit/{id:int}"

@attribute [Authorize]

@inject IKullaniciService KullaniciService
@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Kullanıcı Düzenle</PageTitle>

@if (kullanici == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Kayıt bulunamadı.</RadzenAlert>
}
else
{
    <RadzenCard class="p-4">
        <RadzenText TextStyle="TextStyle.H4" class="mb-3">Kullanıcı Düzenle</RadzenText>

        <EditForm Model="@kullanici" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <RadzenRow Gap="16px">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Firma" Style="width:100%;">
                        <RadzenDropDown Data="@firmalar"
                                        TextProperty="FirmaAdi"
                                        ValueProperty="FirmaId"
                                        @bind-Value="kullanici.FirmaId"
                                        Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Durum" Style="width:100%;">
                        <RadzenDropDown Data="@durumlar"
                                        @bind-Value="kullanici.KullaniciAktifPasif"
                                        Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Ad" Style="width:100%;">
                        <RadzenTextBox @bind-Value="kullanici.KullaniciAdi" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Soyad" Style="width:100%;">
                        <RadzenTextBox @bind-Value="kullanici.KullaniciSoyadi" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Mail" Style="width:100%;">
                        <RadzenTextBox @bind-Value="kullanici.KullaniciMail" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Yeni Şifre" Style="width:100%;">
                        <RadzenPassword @bind-Value="kullanici.Sifre" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="GSM" Style="width:100%;">
                        <RadzenTextBox @bind-Value="kullanici.KullaniciGsm" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" class="mt-3">
                        <RadzenButton Text="Güncelle" Icon="save" ButtonType="ButtonType.Submit" />
                        <RadzenButton Text="İptal" Icon="close" ButtonStyle="ButtonStyle.Secondary" Click="@Cancel" />
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </EditForm>
    </RadzenCard>
}

@code {
    [Parameter] public int id { get; set; }

    private Kullanici? kullanici;
    private List<Firma> firmalar = new();
    private List<string> durumlar = new() { "1", "0" };

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
        kullanici = await KullaniciService.GetByIdAsync(id);
    }

    private async Task HandleValidSubmit()
    {
        if (kullanici == null)
            return;

        var result = await KullaniciService.UpdateAsync(kullanici);

        if (result != null)
        {
            NotificationService.Notify(
                NotificationSeverity.Success,
                "Başarılı",
                "Kullanıcı kaydı güncellendi.");

            NavigationManager.NavigateTo("/users");
        }
        else
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Hata",
                "Kullanıcı kaydı güncellenemedi.");
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/users");
    }
}