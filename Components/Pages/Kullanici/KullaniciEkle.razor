@page "/kullanicilar/ekle"

@using EMutabakat.Models
@using EMutabakat.Services.Interfaces
@inject IKullaniciService KullaniciService
@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Kullanıcı Ekle</PageTitle>

<RadzenCard class="p-4">
    <RadzenText TextStyle="TextStyle.H4" class="mb-3">Yeni Kullanıcı Ekle</RadzenText>

    <EditForm Model="@kullanici" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <RadzenRow Gap="16px">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Firma" Style="width:100%;">
                    <RadzenDropDown Data="@firmalar"
                                    TextProperty="FirmaAdi"
                                    ValueProperty="FirmaId"
                                    @bind-Value="kullanici.FirmaId"
                                    Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Durum" Style="width:100%;">
                    <RadzenDropDown Data="@durumlar"
                                    @bind-Value="kullanici.KullaniciAktifPasif"
                                    Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Ad" Style="width:100%;">
                    <RadzenTextBox @bind-Value="kullanici.KullaniciAdi" Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Soyad" Style="width:100%;">
                    <RadzenTextBox @bind-Value="kullanici.KullaniciSoyadi" Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Mail" Style="width:100%;">
                    <RadzenTextBox @bind-Value="kullanici.KullaniciMail" Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="GSM" Style="width:100%;">
                    <RadzenTextBox @bind-Value="kullanici.KullaniciGsm" Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" class="mt-3">
                    <RadzenButton Text="Kaydet" Icon="save" ButtonType="ButtonType.Submit" />
                    <RadzenButton Text="İptal" Icon="close" ButtonStyle="ButtonStyle.Secondary" Click="@Cancel" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    </EditForm>
</RadzenCard>

@code {
    private Kullanici kullanici = new();
    private List<Firma> firmalar = new();
    private List<string> durumlar = new() { "1", "0" };

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
        kullanici.KullaniciAktifPasif = "1";
    }

    private async Task HandleValidSubmit()
    {
        await KullaniciService.AddAsync(kullanici);

        NotificationService.Notify(
            NotificationSeverity.Success,
            "Başarılı",
            "Kullanıcı kaydı eklendi.");

        NavigationManager.NavigateTo("/kullanicilar");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/kullanicilar");
    }
}