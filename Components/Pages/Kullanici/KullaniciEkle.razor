@page "/users/add"

@attribute [Authorize(Roles = "Admin")]

@inject IKullaniciService KullaniciService
@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Kullanıcı Ekle</PageTitle>

<RadzenCard Class="p-4" Style="max-width:950px;margin-left:auto;margin-right:auto;">
    <RadzenStack AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween"
                 Gap="8px">
        <RadzenText TextStyle="TextStyle.H4">Yeni Kullanıcı Ekle</RadzenText>
    </RadzenStack>

    <RadzenDivider />

    <EditForm Model="@kullanici" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />

        <RadzenFieldset Text="Kullanıcı Bilgileri" Style="margin-bottom:16px">
            <RadzenRow Gap="16px">

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Kullanıcı ID *" />
                    <RadzenTextBox Name="KullaniciId"
                                   @bind-Value="kullanici.KullaniciId"
                                   Style="width:100%;" />
                    <RadzenRequiredValidator Component="KullaniciId"
                                             Text="Kullanıcı ID zorunludur."
                                             Popup="true" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Firmalar *" />
                    <RadzenDropDown Name="FirmaIds"
                                    Data="@firmalar"
                                    TextProperty="FirmaAdi"
                                    ValueProperty="FirmaId"
                                    @bind-Value="selectedFirmaIds"
                                    Placeholder="Firma seçiniz"
                                    Multiple="true"
                                    AllowClear="true"
                                    Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Rol *" />
                    <RadzenDropDown Name="Rol"
                                    Data="@roller"
                                    TextProperty="Text"
                                    ValueProperty="Value"
                                    @bind-Value="kullanici.Rol"
                                    Placeholder="Rol seçiniz"
                                    Style="width:100%;" />
                    <RadzenRequiredValidator Component="Rol"
                                             Text="Rol seçimi zorunludur."
                                             Popup="true" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Durum *" />
                    <RadzenDropDown Name="KullaniciAktifPasif"
                                    Data="@durumlar"
                                    TextProperty="Text"
                                    ValueProperty="Value"
                                    @bind-Value="kullanici.KullaniciAktifPasif"
                                    Placeholder="Durum seçiniz"
                                    Style="width:100%;" />
                    <RadzenRequiredValidator Component="KullaniciAktifPasif"
                                             Text="Aktif/Pasif bilgisi zorunludur."
                                             Popup="true" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Ad *" />
                    <RadzenTextBox Name="KullaniciAdi"
                                   @bind-Value="kullanici.KullaniciAdi"
                                   Placeholder="Ad giriniz"
                                   Style="width:100%;" />
                    <RadzenRequiredValidator Component="KullaniciAdi"
                                             Text="Ad zorunludur."
                                             Popup="true" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Soyad *" />
                    <RadzenTextBox Name="KullaniciSoyadi"
                                   @bind-Value="kullanici.KullaniciSoyadi"
                                   Placeholder="Soyad giriniz"
                                   Style="width:100%;" />
                    <RadzenRequiredValidator Component="KullaniciSoyadi"
                                             Text="Soyad zorunludur."
                                             Popup="true" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Mail *" />
                    <RadzenTextBox Name="KullaniciMail"
                                   @bind-Value="kullanici.KullaniciMail"
                                   Placeholder="Mail giriniz"
                                   Style="width:100%;" />
                    <RadzenRequiredValidator Component="KullaniciMail"
                                             Text="Mail zorunludur."
                                             Popup="true" />
                    <RadzenEmailValidator Component="KullaniciMail"
                                          Text="Geçerli bir mail adresi giriniz."
                                          Popup="true" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="GSM" />
                    <RadzenTextBox Name="KullaniciGsm"
                                   @bind-Value="kullanici.KullaniciGsm"
                                   Placeholder="GSM giriniz"
                                   Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Şifre *" />
                    <RadzenPassword Name="Sifre"
                                    @bind-Value="kullanici.Sifre"
                                    Placeholder="Şifre giriniz"
                                    Style="width:100%;" />
                    <RadzenRequiredValidator Component="Sifre"
                                             Text="Şifre zorunludur."
                                             Popup="true" />
                </RadzenColumn>

            </RadzenRow>
        </RadzenFieldset>

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenStack Orientation="Orientation.Horizontal"
                             Gap="10px"
                             JustifyContent="JustifyContent.End"
                             Class="mt-3">
                    <RadzenButton Text="İptal"
                                  Icon="close"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  Click="@Cancel"
                                  Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px;" />

                    <RadzenButton Text="Kaydet"
                                  Icon="save"
                                  ButtonType="ButtonType.Submit"
                                  Style="background:#eaf2ff;color:#0b57d0;border:1px solid #d7e6ff;border-radius:8px;padding:8px 14px;" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    </EditForm>
</RadzenCard>

@code {
    private Kullanici kullanici = new()
    {
        Rol = KullaniciRolleri.Standart,
        KullaniciAktifPasif = "1"
    };

    private List<Firma> firmalar = new();
    private IEnumerable<int> selectedFirmaIds = Enumerable.Empty<int>();

    private List<RolOption> roller = new()
    {
        new() { Text = "Standart", Value = KullaniciRolleri.Standart },
        new() { Text = "Admin", Value = KullaniciRolleri.Admin }
    };

    private List<DurumOption> durumlar = new()
    {
        new() { Text = "Aktif", Value = "1" },
        new() { Text = "Pasif", Value = "0" }
    };

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
        kullanici.KullaniciId = await KullaniciService.GenerateNextKullaniciIdAsync();
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            var firmaIdList = selectedFirmaIds?
                .Distinct()
                .ToList() ?? new List<int>();

            if (firmaIdList.Count == 0)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "En az bir firma seçimi zorunludur.");
                return;
            }

            kullanici.FirmaIds = firmaIdList;

            await KullaniciService.AddAsync(kullanici);

            NotificationService.Notify(
                NotificationSeverity.Success,
                "Başarılı",
                "Kullanıcı kaydı eklendi.");

            NavigationManager.NavigateTo("/users");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Warning,
                "Uyarı",
                ex.Message);
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/users");
    }

    private class DurumOption
    {
        public string Text { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private class RolOption
    {
        public string Text { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }
}