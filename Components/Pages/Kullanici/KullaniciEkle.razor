@page "/users/add"

@attribute [Authorize]

@inject IKullaniciService KullaniciService
@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Kullan²c² Ekle</PageTitle>

<RadzenCard Class="p-4" Style="max-width:950px;margin-left:auto;margin-right:auto;">
    <RadzenStack AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween"
                 Gap="8px">
        <RadzenText TextStyle="TextStyle.H4">Yeni Kullan²c² Ekle</RadzenText>
    </RadzenStack>

    <RadzenDivider />

    <EditForm Model="@kullanici" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />

        <RadzenFieldset Text="Kullan²c² Bilgileri" Style="margin-bottom:16px">
            <RadzenRow Gap="16px">

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Kullan²c² ID *" />
                    <RadzenTextBox @bind-Value="kullanici.KullaniciId"
                                   Style="width:100%;" />
                    <ValidationMessage For="@(() => kullanici.KullaniciId)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Firmalar *" />
                    <RadzenDropDown Data="@firmalar"
                                    TextProperty="FirmaAdi"
                                    ValueProperty="FirmaId"
                                    @bind-Value="kullanici.FirmaIds"
                                    Placeholder="Firma seńiniz"
                                    Multiple="true"
                                    AllowClear="true"
                                    Style="width:100%;" />
                    <ValidationMessage For="@(() => kullanici.FirmaIds)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Durum *" />
                    <RadzenDropDown Data="@durumlar"
                                    TextProperty="Text"
                                    ValueProperty="Value"
                                    @bind-Value="kullanici.KullaniciAktifPasif"
                                    Placeholder="Durum seńiniz"
                                    Style="width:100%;" />
                    <ValidationMessage For="@(() => kullanici.KullaniciAktifPasif)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Ad *" />
                    <RadzenTextBox @bind-Value="kullanici.KullaniciAdi"
                                   Placeholder="Ad giriniz"
                                   Style="width:100%;" />
                    <ValidationMessage For="@(() => kullanici.KullaniciAdi)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Soyad *" />
                    <RadzenTextBox @bind-Value="kullanici.KullaniciSoyadi"
                                   Placeholder="Soyad giriniz"
                                   Style="width:100%;" />
                    <ValidationMessage For="@(() => kullanici.KullaniciSoyadi)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Mail *" />
                    <RadzenTextBox @bind-Value="kullanici.KullaniciMail"
                                   Placeholder="Mail giriniz"
                                   Style="width:100%;" />
                    <ValidationMessage For="@(() => kullanici.KullaniciMail)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="GSM" />
                    <RadzenTextBox Value="@kullanici.KullaniciGsm"
                                   ValueChanged="@OnGsmChanged"
                                   Placeholder="05XXXXXXXXX"
                                   MaxLength="11"
                                   Style="width:100%;" />
                    <ValidationMessage For="@(() => kullanici.KullaniciGsm)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="▐ifre *" />
                    <RadzenPassword TValue="string"
                                    Value="@kullanici.Sifre"
                                    ValueChanged="@OnPasswordChanged"
                                    Placeholder="▐ifre giriniz"
                                    Style="width:100%;" />
                    <ValidationMessage For="@(() => kullanici.Sifre)" />
                </RadzenColumn>

            </RadzenRow>
        </RadzenFieldset>

        <RadzenRow>
            <RadzenColumn Size="12">
                <RadzenFieldset Text="Kullan²c² Tan²mlar²" Style="margin-bottom:16px">
                    <RadzenRow Gap="16px">

                        @foreach (var modul in modulYetkileri)
                        {
                            <RadzenColumn Size="12">
                                <div style="display:flex;align-items:center;gap:24px;">
                                    <span style="width:120px;flex-shrink:0;">@modul.Ad</span>
                                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin:0;min-width:80px;">
                                        <RadzenCheckBox Value="@(modul.GetYetki() == YetkiSeviyesi.Giris)"
                                                        ValueChanged="@((bool v) => { if (v) modul.SetYetki(YetkiSeviyesi.Giris); })"
                                                        TValue="bool" />
                                        <span style="">Giri■</span>
                                    </label>
                                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin:0;min-width:160px;">
                                        <RadzenCheckBox Value="@(modul.GetYetki() == YetkiSeviyesi.GirisDuzeltme)"
                                                        ValueChanged="@((bool v) => { if (v) modul.SetYetki(YetkiSeviyesi.GirisDuzeltme); })"
                                                        TValue="bool" />
                                        <span style="">Giri■ + D³zeltme</span>
                                    </label>
                                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin:0;min-width:100px;">
                                        <RadzenCheckBox Value="@(modul.GetYetki() == YetkiSeviyesi.TamYetki)"
                                                        ValueChanged="@((bool v) => { if (v) modul.SetYetki(YetkiSeviyesi.TamYetki); })"
                                                        TValue="bool" />
                                        <span style="">Tam Yetki</span>
                                    </label>
                                </div>
                            </RadzenColumn>
                        }

                        <RadzenColumn Size="12">
                            <div style="display:flex;align-items:center;gap:24px;">
                                <span style="width:120px;flex-shrink:0;">Import</span>
                                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin:0;min-width:80px;">
                                    <RadzenCheckBox Value="@kullanici.Yetkileri.ImportYetki"
                                                    ValueChanged="@((bool v) => kullanici.Yetkileri.ImportYetki = v)"
                                                    TValue="bool" />
                                    <span style="">Yetkili</span>
                                </label>
                                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin:0;min-width:100px;">
                                    <RadzenCheckBox Value="@(!kullanici.Yetkileri.ImportYetki)"
                                                    ValueChanged="@((bool v) => kullanici.Yetkileri.ImportYetki = !v)"
                                                    TValue="bool" />
                                    <span style="">Yetkisiz</span>
                                </label>
                            </div>
                        </RadzenColumn>

                        <RadzenColumn Size="12">
                            <div style="display:flex;align-items:center;gap:24px;">
                                <span style="width:120px;flex-shrink:0;">Export</span>
                                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin:0;min-width:80px;">
                                    <RadzenCheckBox Value="@kullanici.Yetkileri.ExportYetki"
                                                    ValueChanged="@((bool v) => kullanici.Yetkileri.ExportYetki = v)"
                                                    TValue="bool" />
                                    <span style="">Yetkili</span>
                                </label>
                                <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin:0;min-width:100px;">
                                    <RadzenCheckBox Value="@(!kullanici.Yetkileri.ExportYetki)"
                                                    ValueChanged="@((bool v) => kullanici.Yetkileri.ExportYetki = !v)"
                                                    TValue="bool" />
                                    <span style="">Yetkisiz</span>
                                </label>
                            </div>
                        </RadzenColumn>

                    </RadzenRow>
                </RadzenFieldset>
                <RadzenStack Orientation="Orientation.Horizontal"
                             Gap="10px"
                             JustifyContent="JustifyContent.End"
                             Class="mt-3">
                    <RadzenButton Text="▌ptal"
                                  Icon="close"
                                  Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px; font-size:15px;"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  Click="@Cancel" />

                    <RadzenButton Text="Kaydet"
                                  Icon="save"
                                  Style="background:#eaf2ff;color:#0b57d0;border:1px solid #d7e6ff;border-radius:8px;padding:8px 14px; font-size:15px;"
                                  ButtonType="ButtonType.Submit" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    </EditForm>
</RadzenCard>

@code {
    private Kullanici kullanici = new()
    {
        KullaniciAktifPasif = "1",
        Yetkileri = new KullaniciYetki()
    };

    private List<Firma> firmalar = new();

    private List<ModulYetki> modulYetkileri = new();

    private List<DurumOption> durumlar = new()
    {
        new() { Text = "Aktif", Value = "1" },
        new() { Text = "Pasif", Value = "0" }
    };

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
        kullanici.KullaniciId = await KullaniciService.GenerateNextKullaniciIdAsync();
        kullanici.Sifre = null;

        modulYetkileri = new List<ModulYetki>
        {
            new("Cariler",       () => kullanici.Yetkileri.Cariler,       v => kullanici.Yetkileri.Cariler = v),
            new("Cari Gruplar",  () => kullanici.Yetkileri.CariGruplar,   v => kullanici.Yetkileri.CariGruplar = v),
            new("D÷viz Kodlar²", () => kullanici.Yetkileri.DovizKodlari,  v => kullanici.Yetkileri.DovizKodlari = v),
            new("Mutabakatlar",  () => kullanici.Yetkileri.Mutabakatlar,  v => kullanici.Yetkileri.Mutabakatlar = v),
            new("Firmalar",      () => kullanici.Yetkileri.Firmalar,      v => kullanici.Yetkileri.Firmalar = v),
            new("Kullan²c²lar",  () => kullanici.Yetkileri.Kullanicilar,  v => kullanici.Yetkileri.Kullanicilar = v),
            new("Loglar",        () => kullanici.Yetkileri.Loglar,        v => kullanici.Yetkileri.Loglar = v),
        };
    }

    private void OnPasswordChanged(string? value)
    {
        kullanici.Sifre = string.IsNullOrWhiteSpace(value) ? null : value;
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            kullanici.KullaniciMail = (kullanici.KullaniciMail ?? string.Empty).Trim().ToLowerInvariant();
            kullanici.KullaniciGsm = string.IsNullOrWhiteSpace(kullanici.KullaniciGsm)
                ? null
                : kullanici.KullaniciGsm.Trim();

            kullanici.FirmaIds = kullanici.FirmaIds?.Distinct().ToList() ?? new List<int>();

            if (string.IsNullOrWhiteSpace(kullanici.Sifre))
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Uyar²", "▐ifre zorunludur.");
                return;
            }

            if (kullanici.FirmaIds.Count == 0)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Uyar²", "En az bir firma seńimi zorunludur.");
                return;
            }

            await KullaniciService.AddAsync(kullanici);

            NotificationService.Notify(NotificationSeverity.Success, "Ba■ar²l²", "Kullan²c² kayd² eklendi.");
            NavigationManager.NavigateTo("/users");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyar²", ex.Message);
        }
    }

    private void OnGsmChanged(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            kullanici.KullaniciGsm = null;
            return;
        }

        value = value.Trim()
            .Replace(" ", "")
            .Replace("-", "")
            .Replace("(", "")
            .Replace(")", "");

        if (value.StartsWith("+90"))
            value = "0" + value.Substring(3);

        else if (value.StartsWith("90") && value.Length == 12)
            value = "0" + value.Substring(2);

        else if (value.StartsWith("5") && value.Length == 10)
            value = "0" + value;

        kullanici.KullaniciGsm = value;
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/users");
    }

    private class DurumOption
    {
        public string Text { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private class ModulYetki
    {
        public string Ad { get; }
        private readonly Func<YetkiSeviyesi> _getter;
        private readonly Action<YetkiSeviyesi> _setter;

        public ModulYetki(string ad, Func<YetkiSeviyesi> getter, Action<YetkiSeviyesi> setter)
        {
            Ad = ad;
            _getter = getter;
            _setter = setter;
        }

        public YetkiSeviyesi GetYetki() => _getter();
        public void SetYetki(YetkiSeviyesi seviye) => _setter(seviye);
    }
}