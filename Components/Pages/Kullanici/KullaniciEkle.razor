@page "/users/add"

@attribute [Authorize]

@inject IKullaniciService KullaniciService
@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Kullanıcı Ekle</PageTitle>

<RadzenCard Class="p-4" Style="max-width:900px;margin-left:auto;margin-right:auto;">
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="8px">
        <RadzenText TextStyle="TextStyle.H4">Yeni Kullanıcı Ekle</RadzenText>
    </RadzenStack>
    <RadzenDivider />
    <EditForm Model="@kullanici" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <RadzenFieldset Text="Genel Bilgiler" Style="margin-bottom:16px">
            <RadzenRow Gap="16px">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Firma" Style="width:100%;">
                    <RadzenDropDown Data="@firmalar"
                                    TextProperty="FirmaAdi"
                                    ValueProperty="FirmaId"
                                    @bind-Value="kullanici.FirmaId"
                                    Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Durum" Style="width:100%;">
                    <RadzenDropDown Data="@durumlar"
                                    @bind-Value="kullanici.KullaniciAktifPasif"
                                    Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Ad" Style="width:100%;">
                    <RadzenTextBox @bind-Value="kullanici.KullaniciAdi" Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Soyad" Style="width:100%;">
                    <RadzenTextBox @bind-Value="kullanici.KullaniciSoyadi" Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Mail" Style="width:100%;">
                    <RadzenTextBox @bind-Value="kullanici.KullaniciMail" Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="Şifre" Style="width:100%;">
                    <RadzenPassword @bind-Value="kullanici.Sifre" Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFormField Text="GSM" Style="width:100%;">
                    <RadzenTextBox @bind-Value="kullanici.KullaniciGsm" Style="width:100%;" />
                </RadzenFormField>
            </RadzenColumn>

            <RadzenColumn Size="12">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" JustifyContent="JustifyContent.End" Class="mt-3">
                    <RadzenButton Text="İptal" Icon="close" ButtonStyle="ButtonStyle.Secondary" Click="@Cancel" Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px;" />
                    <RadzenButton Text="Kaydet" Icon="save" ButtonType="ButtonType.Submit" Style="background:#eaf2ff;color:#0b57d0;border:1px solid #d7e6ff;border-radius:8px;padding:8px 14px;" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
        </RadzenFieldset>
    </EditForm>
</RadzenCard>

@code {
    private Kullanici kullanici = new();
    private List<Firma> firmalar = new();
    private List<string> durumlar = new() { "1", "0" };

    protected override async Task OnInitializedAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
        kullanici.KullaniciAktifPasif = "1";
    }

    private async Task HandleValidSubmit()
    {
        await KullaniciService.AddAsync(kullanici);

        NotificationService.Notify(
            NotificationSeverity.Success,
            "Başarılı",
            "Kullanıcı kaydı eklendi.");

        NavigationManager.NavigateTo("/users");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/users");
    }
}