@page "/currency-codes/add"

@attribute [Authorize]

@inject IDovizKoduService DovizKoduService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Döviz Kodu Ekle</PageTitle>

<RadzenCard Class="p-4" Style="max-width:700px;margin-left:auto;margin-right:auto;">
    <RadzenStack AlignItems="AlignItems.Center" Gap="8px">
        <RadzenText TextStyle="TextStyle.H4">Yeni Döviz Kodu</RadzenText>
    </RadzenStack>

    <RadzenDivider />

    <EditForm Model="@model" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />

        <RadzenRow Gap="16px">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenLabel Text="TCMB *" />
                <RadzenTextBox Name="TCMB" @bind-Value="model.TCMB" Style="width:100%;" />
                <ValidationMessage For="@(() => model.TCMB)" />
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenLabel Text="Ad *" />
                <RadzenTextBox Name="Name" @bind-Value="model.Name" Style="width:100%;" />
                <ValidationMessage For="@(() => model.Name)" />
            </RadzenColumn>

            <RadzenColumn Size="12">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" JustifyContent="JustifyContent.End" Class="mt-3">
                    <RadzenButton Text="İptal" Icon="close" Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px; font-size:12px;" ButtonStyle="ButtonStyle.Secondary" Click="@Cancel" />
                    <RadzenButton Text="Kaydet" Icon="save" Style="background:#eaf2ff;color:#0b57d0;border:1px solid #d7e6ff;border-radius:8px;padding:8px 14px; font-size:12px;" ButtonType="ButtonType.Submit" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    </EditForm>
</RadzenCard>

@code {
    private DovizKodu model = new();

    private async Task HandleValidSubmit()
    {
        try
        {
            await DovizKoduService.AddAsync(model);
            NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Döviz kodu eklendi.");
            NavigationManager.NavigateTo("/currency-codes");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", ex.Message);
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/currency-codes");
    }
}