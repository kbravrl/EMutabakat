@page "/currency-codes/add"

@attribute [Authorize]

@inject IDovizKoduService DovizKoduService
@inject IKullaniciService KullaniciService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Döviz Kodu Ekle</PageTitle>

@if (!canAdd)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">Bu sayfaya erişim yetkiniz bulunmamaktadır.</RadzenAlert>
}
else
{
    <RadzenCard Class="p-4" Style="max-width:700px;margin-left:auto;margin-right:auto;">
        <RadzenStack AlignItems="AlignItems.Center" Gap="8px">
            <RadzenText TextStyle="TextStyle.H4">Yeni Döviz Kodu</RadzenText>
        </RadzenStack>

        <RadzenDivider />

        <EditForm Model="@model" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />

            <RadzenRow Gap="16px">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="TCMB *" />
                    <RadzenTextBox Name="TCMB" @bind-Value="model.TCMB" Style="width:100%;" />
                    <ValidationMessage For="@(() => model.TCMB)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Ad *" />
                    <RadzenTextBox Name="Name" @bind-Value="model.Name" Style="width:100%;" />
                    <ValidationMessage For="@(() => model.Name)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Aktif / Pasif *" />
                    <RadzenDropDown Name="DovizKoduAktifPasif"
                                    Data="@durumlar"
                                    TextProperty="Text"
                                    ValueProperty="Value"
                                    @bind-Value="model.DovizKoduAktifPasif"
                                    Placeholder="Seçiniz"
                                    Style="width:100%;" />
                    <ValidationMessage For="@(() => model.DovizKoduAktifPasif)" />
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" JustifyContent="JustifyContent.End" Class="mt-3">
                        <RadzenButton Text="İptal" Icon="close" Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px; font-size:15px;" ButtonStyle="ButtonStyle.Secondary" Click="@Cancel" />
                        <RadzenButton Text="Kaydet" Icon="save" Style="background:#eaf2ff;color:#0b57d0;border:1px solid #d7e6ff;border-radius:8px;padding:8px 14px; font-size:15px;" ButtonType="ButtonType.Submit" />
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </EditForm>
    </RadzenCard>
}

@code {
    private DovizKodu model = new();
    private bool canAdd;

    private class DurumOption
    {
        public int Value { get; set; }
        public string Text { get; set; } = string.Empty;
    }

    private List<DurumOption> durumlar = new()
    {
        new() { Value = 1, Text = "Aktif" },
        new() { Value = 0, Text = "Pasif" }
    };

    protected override async Task OnInitializedAsync()
    {
        var yetki = await KullaniciService.GetCurrentUserYetkiAsync();
        var isSeed = await KullaniciService.IsCurrentUserSeedAsync();

        canAdd = isSeed || (yetki != null && yetki.DovizKodlari == YetkiSeviyesi.TamYetki);
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            await DovizKoduService.AddAsync(model);
            NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Döviz kodu eklendi.");
            NavigationManager.NavigateTo("/currency-codes");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", ex.Message);
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/currency-codes");
    }
}