@page "/currency-codes"

@attribute [Authorize]

@inject IDovizKoduService DovizKoduService
@inject IKullaniciService KullaniciService
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Döviz Kodları</PageTitle>

@if (!canView && !isLoading)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" class="m-4">Bu sayfaya giriş izniniz bulunmamaktadır.</RadzenAlert>
}
else
{
    <RadzenStack Gap="1rem" class="p-4">
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenText TextStyle="TextStyle.H4">Döviz Kodları</RadzenText>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6" class="rz-text-align-end">
                @if (canAdd)
                {
                    <RadzenButton Text="Yeni döviz kodu" Icon="add_circle" Style="font-size:15px;" Click="@GoToCreatePage" />
                }
            </RadzenColumn>
        </RadzenRow>

        <RadzenCard>
            <RadzenRow Gap="15px" class="mb-3">
                <RadzenColumn Size="12" SizeMD="2">
                    <RadzenDropDown Data="@tcmbOptions"
                                    @bind-Value="selectedTcmb"
                                    Placeholder="TCMB"
                                    AllowClear="true"
                                    Style="width:100%;"
                                    Change="@(_ => ApplyFilters())" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="2">
                    <RadzenDropDown Data="@nameOptions"
                                    @bind-Value="selectedName"
                                    Placeholder="Ad"
                                    AllowClear="true"
                                    Style="width:100%;"
                                    Change="@(_ => ApplyFilters())" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="2">
                    <RadzenDropDown TValue="int?"
                                    Data="@durumOptions"
                                    TextProperty="Text"
                                    ValueProperty="Value"
                                    @bind-Value="selectedDurum"
                                    Placeholder="Durum"
                                    Style="width:100%;"
                                    Change="@(_ => ApplyFilters())" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="1">
                    <RadzenButton Text="Temizle"
                                  Icon="restart_alt"
                                  ButtonStyle="ButtonStyle.Light"
                                  Style="width:100%; font-size:15px;"
                                  Click="ClearFilters" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenDataGrid Data="@filteredDovizKodlari"
                            TItem="DovizKodu"
                            AllowPaging="true"
                            AllowSorting="true"
                            AllowFiltering="true"
                            PageSize="10"
                            EmptyText="Kayıt bulunamadı">
                <Columns>
                    <RadzenDataGridColumn TItem="DovizKodu" Property="Id" Title="ID" Width="100px" Filterable="false" />
                    <RadzenDataGridColumn TItem="DovizKodu" Property="TCMB" Title="TCMB" />
                    <RadzenDataGridColumn TItem="DovizKodu" Property="Name" Title="Ad" />
                    <RadzenDataGridColumn TItem="DovizKodu" Title="Durum">
                        <Template Context="item">
                            @if (item.DovizKoduAktifPasif == 1)
                            {
                                <RadzenBadge Text="Aktif" BadgeStyle="BadgeStyle.Success" />
                            }
                            else
                            {
                                <RadzenBadge Text="Pasif" BadgeStyle="BadgeStyle.Danger" />
                            }
                        </Template>
                    </RadzenDataGridColumn>

                    @if (canEdit || canDelete)
                    {
                        <RadzenDataGridColumn TItem="DovizKodu" Title="İşlemler" Sortable="false" Filterable="false">
                            <Template Context="item">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                                    @if (canEdit)
                                    {
                                        <RadzenButton Icon="edit"
                                                      Size="ButtonSize.Small"
                                                      Variant="Variant.Flat"
                                                      Title="Düzenle"
                                                      Click="@(() => GoToEditPage(item.TCMB))" />
                                    }

                                    @if (canDelete)
                                    {
                                        <RadzenButton Icon="delete"
                                                      Size="ButtonSize.Small"
                                                      Variant="Variant.Flat"
                                                      ButtonStyle="ButtonStyle.Danger"
                                                      Title="Sil"
                                                      Click="@(() => DeleteDovizKodu(item.TCMB, item.Name))" />
                                    }
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                    }
                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenStack>
}

@code {
    private List<DovizKodu> dovizKodlari = new();
    private List<DovizKodu> filteredDovizKodlari = new();

    private bool canView;
    private bool canAdd;
    private bool canEdit;
    private bool canDelete;

    private bool isLoading = true;

    private string? selectedTcmb;
    private string? selectedName;
    private int? selectedDurum = 1;

    private List<string> tcmbOptions = new();
    private List<string> nameOptions = new();

    private class DurumOption
    {
        public int Value { get; set; }
        public string Text { get; set; } = string.Empty;
    }

    private List<DurumOption> durumOptions = new()
    {
        new() { Text = "Aktif", Value = 1 },
        new() { Text = "Pasif", Value = 0 }
    };

    protected override async Task OnInitializedAsync()
    {
        var yetki = await KullaniciService.GetCurrentUserYetkiAsync();
        var isSeed = await KullaniciService.IsCurrentUserSeedAsync();

        if (isSeed)
        {
            canView = canAdd = canEdit = canDelete = true;
        }
        else if (yetki != null)
        {
            canView   = yetki.DovizKodlari >= YetkiSeviyesi.Giris;
            canAdd    = yetki.DovizKodlari >= YetkiSeviyesi.Giris;
            canEdit   = yetki.DovizKodlari >= YetkiSeviyesi.GirisDuzeltme;
            canDelete = yetki.DovizKodlari == YetkiSeviyesi.TamYetki;
        }

        if (!canView)
        {
            isLoading = false;
            return;
        }

        await LoadAsync();
        isLoading = false;
    }

    private async Task LoadAsync()
    {
        dovizKodlari = await DovizKoduService.GetAllAsync();

        tcmbOptions = dovizKodlari
            .Where(x => !string.IsNullOrWhiteSpace(x.TCMB))
            .Select(x => x.TCMB!)
            .Distinct()
            .OrderBy(x => x)
            .ToList();

        nameOptions = dovizKodlari
            .Where(x => !string.IsNullOrWhiteSpace(x.Name))
            .Select(x => x.Name!)
            .Distinct()
            .OrderBy(x => x)
            .ToList();

        ApplyFilters();
    }

    private void GoToCreatePage()
    {
        NavigationManager.NavigateTo("/currency-codes/add");
    }

    private void GoToEditPage(string tcmb)
    {
        NavigationManager.NavigateTo($"/currency-codes/edit/{Uri.EscapeDataString(tcmb)}");
    }

    private async Task DeleteDovizKodu(string tcmb, string name)
    {
        var confirmed = await DialogService.Confirm(
            $"'{name}' ({tcmb}) kaydını silmek istediğinize emin misiniz?",
            "Silme Onayı",
            new ConfirmOptions
            {
                OkButtonText = "Evet",
                CancelButtonText = "Vazgeç"
            });

        if (confirmed == true)
        {
            try
            {
                var result = await DovizKoduService.DeleteAsync(tcmb);
                if (result)
                {
                    NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Döviz kodu silindi.");
                    await LoadAsync();
                }
                else
                {
                    NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Kayıt bulunamadı.");
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", ex.Message);
            }
        }
    }

    private void ApplyFilters()
    {
        IEnumerable<DovizKodu> query = dovizKodlari;

        if (!string.IsNullOrWhiteSpace(selectedTcmb))
        {
            query = query.Where(x => x.TCMB == selectedTcmb);
        }

        if (!string.IsNullOrWhiteSpace(selectedName))
        {
            query = query.Where(x => x.Name == selectedName);
        }

        if (selectedDurum.HasValue)
        {
            query = query.Where(x => x.DovizKoduAktifPasif == selectedDurum.Value);
        }

        filteredDovizKodlari = query.OrderBy(x => x.Id).ToList();
    }

    private void ClearFilters()
    {
        selectedTcmb = null;
        selectedName = null;
        selectedDurum = 1;
        ApplyFilters();
    }
}
