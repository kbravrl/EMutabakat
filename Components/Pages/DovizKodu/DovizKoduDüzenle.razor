@page "/currency-codes/edit/{tcmb}"

@attribute [Authorize]

@inject IDovizKoduService DovizKoduService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Döviz Kodu Düzenle</PageTitle>

@if (model == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Kayıt bulunamadı.</RadzenAlert>
}
else
{
    <RadzenCard Class="p-4" Style="max-width:700px;margin-left:auto;margin-right:auto;">
        <RadzenStack AlignItems="AlignItems.Center" Gap="8px">
            <RadzenText TextStyle="TextStyle.H4">Döviz Kodu Düzenle</RadzenText>
        </RadzenStack>

        <RadzenDivider />

        <EditForm Model="@model" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />

            <RadzenRow Gap="16px">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="TCMB *" />
                    <RadzenTextBox Name="TCMB" @bind-Value="model.TCMB" Style="width:100%;" />
                    <ValidationMessage For="@(() => model.TCMB)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Ad *" />
                    <RadzenTextBox Name="Name" @bind-Value="model.Name" Style="width:100%;" />
                    <ValidationMessage For="@(() => model.Name)" />
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" JustifyContent="JustifyContent.End" Class="mt-3">
                        <RadzenButton Text="İptal" Icon="close" ButtonStyle="ButtonStyle.Secondary" Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px; font-size:12px;" Click="@Cancel" />
                        <RadzenButton Text="Güncelle" Icon="save" Style="background:#eaf2ff;color:#0b57d0;border:1px solid #d7e6ff;border-radius:8px;padding:8px 14px; font-size:12px;" ButtonType="ButtonType.Submit" />
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </EditForm>
    </RadzenCard>
}

@code {
    [Parameter] public string tcmb { get; set; } = string.Empty;

    private DovizKodu? model;
    private string originalTcmb = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        model = await DovizKoduService.GetByTcmbAsync(tcmb);
        if (model != null)
        {
            originalTcmb = model.TCMB;
        }
    }

    private async Task HandleValidSubmit()
    {
        if (model == null)
            return;

        try
        {
            var result = await DovizKoduService.UpdateAsync(model, originalTcmb);
            if (result == null)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Kayıt bulunamadı.");
                return;
            }

            NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Döviz kodu güncellendi.");
            NavigationManager.NavigateTo("/currency-codes");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", ex.Message);
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/currency-codes");
    }
}