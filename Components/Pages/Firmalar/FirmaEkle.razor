@page "/companies/add"

@attribute [Authorize]

@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Firma Ekle</PageTitle>

<RadzenCard Class="p-4" Style="max-width:900px;margin-left:auto;margin-right:auto;">
    <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="8px">
        <RadzenText TextStyle="TextStyle.H4">Yeni Firma Ekle</RadzenText>
    </RadzenStack>

    <RadzenDivider />

    <EditForm Model="@firma" OnValidSubmit="@HandleValidSubmit">

        <RadzenFieldset Text="Genel Bilgiler" Style="margin-bottom:16px">
            <RadzenRow Gap="16px">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenTextBox @bind-value="firma.FirmaAdi" Placeholder="Firma adı" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenTextBox @bind-value="firma.FirmaUnvan" Placeholder="Unvan" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenTextArea @bind-value="firma.FirmaAdres" Placeholder="Adres" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenTextBox @bind-value="firma.FirmaIlce" Placeholder="İlçe" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenTextBox @bind-value="firma.FirmaIl" Placeholder="İl" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenTextBox @bind-value="firma.FirmaVergiDairesi" Placeholder="Vergi Dairesi" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenTextBox @bind-value="firma.FirmaVergiNumarasi" Placeholder="Vergi No" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenTextBox @bind-value="firma.FirmaMersisNumarasi" Placeholder="Mersis No" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenTextBox @bind-value="firma.FirmaWebAdresi" Placeholder="Web" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenTextBox @bind-value="firma.FirmaYetkiliAdiSoyadi" Placeholder="Yetkili" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenTextBox @bind-value="firma.FirmaMail" Placeholder="E-posta" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenTextBox @bind-value="firma.FirmaTelefon" Placeholder="Telefon" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenTextBox @bind-value="firma.FirmaGsm" Placeholder="GSM" Style="width:100%;" />
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        <RadzenFieldset Text="SMTP Ayarları">
            <RadzenRow Gap="16px">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenTextBox @bind-value="firma.FirmaSmtpHost" Placeholder="SMTP Host" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenNumeric TValue="int" @bind-value="firma.FirmaSmtpPort" Placeholder="Port" Style="width:100%;" />
                </RadzenColumn>


                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenTextBox @bind-value="firma.FirmaSmtpUser" Placeholder="Kullanıcı" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenPassword @bind-value="firma.FirmaSmtpPassword" Placeholder="Şifre" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenTextBox @bind-value="firma.FirmaSmtpSecure" Placeholder="Secure" Style="width:100%;" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center">
                        <RadzenText>Aktif</RadzenText>
                        <RadzenDropDown @bind-value="firma.FirmaAktifPasif"
                                        Data="@durumlar"
                                        Style="width:100%;" />
                    </RadzenStack>
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" JustifyContent="JustifyContent.End" Class="mt-3">
                        <RadzenButton Text="İptal" Icon="close" ButtonStyle="ButtonStyle.Secondary" Click="@Cancel" Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px;" />
                        <RadzenButton Text="Kaydet" Icon="save" ButtonType="ButtonType.Submit" Style="background:#eaf2ff;color:#0b57d0;border:1px solid #d7e6ff;border-radius:8px;padding:8px 14px;" />
                    </RadzenStack>
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

    </EditForm>
</RadzenCard>

@code {
    private Firma firma = new();
    private List<int> durumlar = new() { 1, 0 };
    private bool isActiveBool = true;

    private async Task HandleValidSubmit()
    {
        await FirmaService.AddAsync(firma);

        NotificationService.Notify(
            NotificationSeverity.Success,
            "Başarılı",
            "Firma kaydı eklendi.");

        NavigationManager.NavigateTo("/companies");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/companies");
    }
}