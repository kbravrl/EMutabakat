@page "/companies/detail/{id:int}"

@attribute [Authorize]

@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager

<PageTitle>Firma Detay</PageTitle>

@if (firma == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Kayıt bulunamadı.</RadzenAlert>
}
else
{
    <RadzenCard Class="p-4" Style="max-width:900px;margin-left:auto;margin-right:auto;">
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="8px">
            <RadzenText TextStyle="TextStyle.H4">Firma Detay</RadzenText>
        </RadzenStack>
        <RadzenDivider />
        <RadzenFieldset Text="Genel Bilgiler" Style="margin-bottom:16px">
        <RadzenRow Gap="16px" class="mt-3">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenText TextStyle="TextStyle.H6">Firma Adı</RadzenText>
                <div>@firma.FirmaAdi</div>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenText TextStyle="TextStyle.H6">Unvan</RadzenText>
                <div>@firma.FirmaUnvan</div>
            </RadzenColumn>

            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.H6">Adres</RadzenText>
                <div>@firma.FirmaAdres</div>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="4">
                <RadzenText TextStyle="TextStyle.H6">İlçe</RadzenText>
                <div>@firma.FirmaIlce</div>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="4">
                <RadzenText TextStyle="TextStyle.H6">İl</RadzenText>
                <div>@firma.FirmaIl</div>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="4">
                <RadzenText TextStyle="TextStyle.H6">Vergi Dairesi / No</RadzenText>
                <div>@firma.FirmaVergiDairesi - @firma.FirmaVergiNumarasi</div>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="4">
                <RadzenText TextStyle="TextStyle.H6">Mersis / Web</RadzenText>
                <div>@firma.FirmaMersisNumarasi - @firma.FirmaWebAdresi</div>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="4">
                <RadzenText TextStyle="TextStyle.H6">Yetkili / Mail</RadzenText>
                <div>@firma.FirmaYetkiliAdiSoyadi - @firma.FirmaMail</div>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="4">
                <RadzenText TextStyle="TextStyle.H6">Telefon / GSM</RadzenText>
                <div>@firma.FirmaTelefon - @firma.FirmaGsm</div>
            </RadzenColumn>

                <RadzenColumn Size="12" class="mt-2">
                    <RadzenText TextStyle="TextStyle.H6">Durum</RadzenText>
                    @if (firma.FirmaAktifPasif == 1)
                    {
                        <RadzenBadge Text="Aktif" BadgeStyle="BadgeStyle.Success" />
                    }
                    else
                    {
                        <RadzenBadge Text="Pasif" BadgeStyle="BadgeStyle.Danger" />
                    }
                </RadzenColumn>


        </RadzenRow>
        </RadzenFieldset>
        <RadzenFieldset Text="SMTP Bilgileri" Style="margin-bottom:16px">
        <RadzenRow Gap="16px">
            <RadzenColumn Size="12" SizeMD="4"><b>Host:</b> @firma.FirmaSmtpHost</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4"><b>Port:</b> @firma.FirmaSmtpPort</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4"><b>User:</b> @firma.FirmaSmtpUser</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4"><b>Secure:</b> @firma.FirmaSmtpSecure</RadzenColumn>
        </RadzenRow>
        </RadzenFieldset>

        <RadzenRow Gap="16px">
            <RadzenColumn Size="12" class="mt-3">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" JustifyContent="JustifyContent.End">
                    <RadzenButton Text="Listeye Dön" Icon="arrow_back" ButtonStyle="ButtonStyle.Secondary" Click="@BackToList" Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px;" />
                    <RadzenButton Text="Düzenle" Icon="edit" Click="@(() => NavigationManager.NavigateTo($"/companies/edit/{firma.FirmaId}"))" Style="background:#eaf2ff;color:#0b57d0;border:1px solid #d7e6ff;border-radius:8px;padding:8px 14px;" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>
}

@code {
    [Parameter] public int id { get; set; }

    private Firma? firma;

    protected override async Task OnInitializedAsync()
    {
        firma = await FirmaService.GetByIdAsync(id);
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo("/companies");
    }
}