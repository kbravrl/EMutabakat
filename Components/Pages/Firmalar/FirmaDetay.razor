@page "/companies/datail/{id:int}"

@attribute [Authorize]

@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager

<PageTitle>Firma Detay</PageTitle>

@if (firma == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Kayıt bulunamadı.</RadzenAlert>
}
else
{
    <RadzenCard class="p-4">
        <RadzenText TextStyle="TextStyle.H4" class="mb-4">Firma Detay</RadzenText>

        <RadzenRow Gap="16px">
            <RadzenColumn Size="12" SizeMD="6"><b>Firma Adı:</b> @firma.FirmaAdi</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6"><b>Firma Unvan:</b> @firma.FirmaUnvan</RadzenColumn>

            <RadzenColumn Size="12"><b>Adres:</b> @firma.FirmaAdres</RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6"><b>İlçe:</b> @firma.FirmaIlce</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6"><b>İl:</b> @firma.FirmaIl</RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6"><b>Vergi Dairesi:</b> @firma.FirmaVergiDairesi</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6"><b>Vergi Numarası:</b> @firma.FirmaVergiNumarasi</RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6"><b>Mersis Numarası:</b> @firma.FirmaMersisNumarasi</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6"><b>Web Adresi:</b> @firma.FirmaWebAdresi</RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6"><b>Yetkili:</b> @firma.FirmaYetkiliAdiSoyadi</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6"><b>Mail:</b> @firma.FirmaMail</RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6"><b>Telefon:</b> @firma.FirmaTelefon</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6"><b>GSM:</b> @firma.FirmaGsm</RadzenColumn>

            <RadzenColumn Size="12">
                <RadzenText TextStyle="TextStyle.H6" class="mt-3 mb-2">SMTP Bilgileri</RadzenText>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="4"><b>SMTP Host:</b> @firma.FirmaSmtpHost</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4"><b>SMTP Port:</b> @firma.FirmaSmtpPort</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4"><b>SMTP User:</b> @firma.FirmaSmtpUser</RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6"><b>SMTP Secure:</b> @firma.FirmaSmtpSecure</RadzenColumn>
            <RadzenColumn Size="12" SizeMD="6">
                <b>Durum:</b>
                @(firma.FirmaAktifPasif == 1 ? "Aktif" : "Pasif")
            </RadzenColumn>

            <RadzenColumn Size="12" class="mt-3">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="10px">
                    <RadzenButton Text="Düzenle"
                                  Icon="edit"
                                  Click="@(() => NavigationManager.NavigateTo($"/companies/edit/{firma.FirmaId}"))" />

                    <RadzenButton Text="Listeye Dön"
                                  Icon="arrow_back"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  Click="@BackToList" />
                </RadzenStack>
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>
}

@code {
    [Parameter] public int id { get; set; }

    private Firma? firma;

    protected override async Task OnInitializedAsync()
    {
        firma = await FirmaService.GetByIdAsync(id);
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo("/companies");
    }
}