@page "/companies"

@attribute [Authorize]

@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Firmalar</PageTitle>

<RadzenStack Gap="1rem" class="p-4">
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText TextStyle="TextStyle.H4">Firma Listesi</RadzenText>
        </RadzenColumn>

        <RadzenColumn Size="12" SizeMD="6" class="rz-text-align-end">
            <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End">
                <RadzenButton Text="Yeni Firma Ekle"
                              Icon="add_circle"
                              Click="@GoToCreatePage" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    <RadzenCard>
        <RadzenDataGrid Data="@firmalar"
                        TItem="Firma"
                        AllowPaging="true"
                        AllowSorting="true"
                        AllowFiltering="true"
                        PageSize="10"
                        EmptyText="Kayıt bulunamadı">

            <Columns>
                <RadzenDataGridColumn TItem="Firma" Property="FirmaId" Title="ID" />
                <RadzenDataGridColumn TItem="Firma" Property="FirmaAdi" Title="Firma Adı" />
                <RadzenDataGridColumn TItem="Firma" Property="FirmaUnvan" Title="Unvan" />
                <RadzenDataGridColumn TItem="Firma" Property="FirmaMail" Title="Mail" />
                <RadzenDataGridColumn TItem="Firma" Property="FirmaTelefon" Title="Telefon" />
                <RadzenDataGridColumn TItem="Firma" Property="FirmaYetkiliAdiSoyadi" Title="Yetkili" />
                <RadzenDataGridColumn TItem="Firma" Title="Lokasyon">
                    <Template Context="firma">
                        @firma.FirmaIl / @firma.FirmaIlce
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Firma" Title="Durum">
                    <Template Context="firma">
                        @(firma.FirmaAktifPasif == 1 ? "Aktif" : "Pasif")
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Firma" Title="İşlemler" Sortable="false" Filterable="false" Width="220px">
                    <Template Context="firma">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenButton Icon="edit"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          Click="@(() => GoToEditPage(firma.FirmaId))" />

                            <RadzenButton Icon="visibility"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          ButtonStyle="ButtonStyle.Info"
                                          Click="@(() => GoToDetailsPage(firma.FirmaId))" />

                            <RadzenButton Icon="delete"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          ButtonStyle="ButtonStyle.Danger"
                                          Click="@(() => DeleteFirma(firma.FirmaId, firma.FirmaAdi))" />
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
</RadzenStack>

@code {
    private List<Firma> firmalar = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadFirmalarAsync();
    }

    private async Task LoadFirmalarAsync()
    {
        firmalar = await FirmaService.GetAllAsync();
    }

    private void GoToCreatePage()
    {
        NavigationManager.NavigateTo("/companies/add");
    }

    private void GoToEditPage(int id)
    {
        NavigationManager.NavigateTo($"/companies/edit/{id}");
    }

    private void GoToDetailsPage(int id)
    {
        NavigationManager.NavigateTo($"/companies/detail/{id}");
    }

    private async Task DeleteFirma(int id, string firmaAdi)
    {
        var confirmed = await DialogService.Confirm(
            $"'{firmaAdi}' kaydını silmek istediğinize emin misiniz?",
            "Silme Onayı",
            new ConfirmOptions
            {
                OkButtonText = "Evet",
                CancelButtonText = "Vazgeç"
            });

        if (confirmed == true)
        {
            try
            {
                var result = await FirmaService.DeleteAsync(id);

                if (result)
                {
                    NotificationService.Notify(
                        NotificationSeverity.Success,
                        "Başarılı",
                        "Firma kaydı silindi.");

                    await LoadFirmalarAsync();
                }
                else
                {
                    NotificationService.Notify(
                        NotificationSeverity.Warning,
                        "Uyarı",
                        "Firma kaydı bulunamadı.");
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Uyarı",
                    ex.Message);
            }
        }
    }

}
