@page "/companies"

@attribute [Authorize]

@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Firmalar</PageTitle>

<RadzenStack Gap="1rem" class="p-4">
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText TextStyle="TextStyle.H4">Firma Listesi</RadzenText>
        </RadzenColumn>

        <RadzenColumn Size="12" SizeMD="6" class="rz-text-align-end">
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <RadzenButton Text="Yeni Firma Ekle"
                                  Icon="add_circle"
                                  Size="ButtonSize.Small"
                                  Style="padding:4px 8px; font-size:0.9rem;"
                                  Click="@GoToCreatePage" />
                </Authorized>
            </AuthorizeView>
        </RadzenColumn>
    </RadzenRow>

    <RadzenCard>
        <RadzenRow Gap="12px" class="mb-3">
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenTextBox @bind-Value="searchText"
                               Placeholder="ID/ Firma adı/ Unvan/ Mail ara..."
                               Style="width:100%;"
                               Change="@(_ => ApplyFilters())" />
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="2">
                <RadzenDropDown Data="@durumOptions"
                                TextProperty="Text"
                                ValueProperty="Value"
                                @bind-Value="selectedDurum"
                                Placeholder="Durum"
                                AllowClear="true"
                                Style="width:100%;"
                                Change="@(_ => ApplyFilters())" />
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="1">
                <RadzenButton Text="Temizle"
                              Icon="restart_alt"
                              ButtonStyle="ButtonStyle.Light"
                              Style="width:100%;"
                              Click="ClearFilters" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenDataGrid Data="@filteredFirmalar"
                        TItem="Firma"
                        AllowPaging="true"
                        AllowSorting="true"
                        AllowFiltering="true"
                        PageSize="10"
                        EmptyText="Kayıt bulunamadı">
            <Columns>
                <RadzenDataGridColumn TItem="Firma" Property="FirmaId" Title="ID" Width="90px" />
                <RadzenDataGridColumn TItem="Firma" Property="FirmaAdi" Title="Firma Adı" />
                <RadzenDataGridColumn TItem="Firma" Property="FirmaUnvan" Title="Unvan" />
                <RadzenDataGridColumn TItem="Firma" Property="FirmaMail" Title="Mail" />
                <RadzenDataGridColumn TItem="Firma" Property="FirmaTelefon" Title="Telefon" />
                <RadzenDataGridColumn TItem="Firma" Property="FirmaYetkiliAdiSoyadi" Title="Yetkili" />
                <RadzenDataGridColumn TItem="Firma" Property="FirmaIl" Title="İl" Width="120px" />
                <RadzenDataGridColumn TItem="Firma" Property="FirmaIlce" Title="İlçe" Width="140px" />

                <RadzenDataGridColumn TItem="Firma"
                                      Property="FirmaAktifPasif"
                                      Title="Durum"
                                      FilterOperator="FilterOperator.Equals"
                                      Width="120px">
                    <Template Context="firma">
                        @if (firma.FirmaAktifPasif == 1)
                        {
                            <RadzenBadge Text="Aktif" BadgeStyle="BadgeStyle.Success" />
                        }
                        else
                        {
                            <RadzenBadge Text="Pasif" BadgeStyle="BadgeStyle.Danger" />
                        }
                    </Template>
                </RadzenDataGridColumn>

                <RadzenDataGridColumn TItem="Firma"
                                      Title="İşlemler"
                                      Sortable="false"
                                      Filterable="false"
                                      Width="220px">
                    <Template Context="firma">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenButton Icon="edit"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          Click="@(() => GoToEditPage(firma.FirmaId))" />

                            <RadzenButton Icon="visibility"
                                          Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          ButtonStyle="ButtonStyle.Info"
                                          Click="@(() => GoToDetailsPage(firma.FirmaId))" />

                            <AuthorizeView Roles="Admin">
                                <Authorized>
                                    <RadzenButton Icon="delete"
                                                  Size="ButtonSize.Small"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Danger"
                                                  Click="@(() => DeleteFirma(firma.FirmaId, firma.FirmaAdi))" />
                                </Authorized>
                            </AuthorizeView>
                        </RadzenStack>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </RadzenCard>
</RadzenStack>

@code {
    private List<Firma> firmalar = new();
    private List<Firma> filteredFirmalar = new();

    private string? searchText;
    private string? selectedIl;
    private string? selectedIlce;
    private int? selectedDurum = 1;

    private List<FilterOptionString> ilOptions = new();
    private List<FilterOptionString> ilceOptions = new();
    private List<FilterOptionInt> durumOptions = new()
    {
        new() { Text = "Aktif", Value = 1 },
        new() { Text = "Pasif", Value = 0 }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadFirmalarAsync();
    }

    private async Task LoadFirmalarAsync()
    {
        firmalar = await FirmaService.GetAllAsync();

        ilOptions = firmalar
            .Where(x => !string.IsNullOrWhiteSpace(x.FirmaIl))
            .Select(x => x.FirmaIl!)
            .Distinct()
            .OrderBy(x => x)
            .Select(x => new FilterOptionString
            {
                Value = x,
                Text = x
            })
            .ToList();

        ilceOptions = firmalar
            .Where(x => !string.IsNullOrWhiteSpace(x.FirmaIlce))
            .Select(x => x.FirmaIlce!)
            .Distinct()
            .OrderBy(x => x)
            .Select(x => new FilterOptionString
            {
                Value = x,
                Text = x
            })
            .ToList();

        ApplyFilters();
    }

    private void ApplyFilters()
    {
        IEnumerable<Firma> query = firmalar;

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            var text = searchText.Trim().ToLower();

            query = query.Where(x =>
                x.FirmaId.ToString().Contains(text) ||
                (!string.IsNullOrWhiteSpace(x.FirmaAdi) && x.FirmaAdi.ToLower().Contains(text)) ||
                (!string.IsNullOrWhiteSpace(x.FirmaUnvan) && x.FirmaUnvan.ToLower().Contains(text)) ||
                (!string.IsNullOrWhiteSpace(x.FirmaMail) && x.FirmaMail.ToLower().Contains(text)) ||
                (!string.IsNullOrWhiteSpace(x.FirmaTelefon) && x.FirmaTelefon.ToLower().Contains(text)) ||
                (!string.IsNullOrWhiteSpace(x.FirmaGsm) && x.FirmaGsm.ToLower().Contains(text)) ||
                (!string.IsNullOrWhiteSpace(x.FirmaYetkiliAdiSoyadi) && x.FirmaYetkiliAdiSoyadi.ToLower().Contains(text)) ||
                (!string.IsNullOrWhiteSpace(x.FirmaIl) && x.FirmaIl.ToLower().Contains(text)) ||
                (!string.IsNullOrWhiteSpace(x.FirmaIlce) && x.FirmaIlce.ToLower().Contains(text))
            );
        }

        if (!string.IsNullOrWhiteSpace(selectedIl))
        {
            query = query.Where(x => x.FirmaIl == selectedIl);
        }

        if (!string.IsNullOrWhiteSpace(selectedIlce))
        {
            query = query.Where(x => x.FirmaIlce == selectedIlce);
        }

        if (selectedDurum.HasValue)
        {
            query = query.Where(x => x.FirmaAktifPasif == selectedDurum.Value);
        }

        filteredFirmalar = query
            .OrderBy(x => x.FirmaAdi)
            .ToList();
    }

    private void ClearFilters()
    {
        searchText = null;
        selectedIl = null;
        selectedIlce = null;
        selectedDurum = 1;
        ApplyFilters();
    }

    private void GoToCreatePage()
    {
        NavigationManager.NavigateTo("/companies/add");
    }

    private void GoToEditPage(int id)
    {
        NavigationManager.NavigateTo($"/companies/edit/{id}");
    }

    private void GoToDetailsPage(int id)
    {
        NavigationManager.NavigateTo($"/companies/detail/{id}");
    }

    private async Task DeleteFirma(int id, string firmaAdi)
    {
        var confirmed = await DialogService.Confirm(
            $"'{firmaAdi}' kaydını silmek istediğinize emin misiniz?",
            "Silme Onayı",
            new ConfirmOptions
            {
                OkButtonText = "Evet",
                CancelButtonText = "Vazgeç"
            });

        if (confirmed == true)
        {
            try
            {
                var result = await FirmaService.DeleteAsync(id);

                if (result)
                {
                    NotificationService.Notify(
                        NotificationSeverity.Success,
                        "Başarılı",
                        "Firma kaydı silindi.");

                    await LoadFirmalarAsync();
                }
                else
                {
                    NotificationService.Notify(
                        NotificationSeverity.Warning,
                        "Uyarı",
                        "Firma kaydı bulunamadı.");
                }
            }
            catch (Exception ex)
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Uyarı",
                    ex.Message);
            }
        }
    }

    public class FilterOptionInt
    {
        public int Value { get; set; }
        public string Text { get; set; } = string.Empty;
    }

    public class FilterOptionString
    {
        public string Value { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
    }
}
