@page "/companies/edit/{id:int}"

@attribute [Authorize]

@inject IFirmaService FirmaService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Firma Düzenle</PageTitle>

@if (firma == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Kayıt bulunamadı.</RadzenAlert>
}
else
{
    <RadzenCard class="p-4">
        <RadzenText TextStyle="TextStyle.H4" class="mb-3">Firma Düzenle</RadzenText>

        <EditForm Model="@firma" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <RadzenRow Gap="16px">

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Firma Adı" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaAdi" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Firma Unvan" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaUnvan" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenFormField Text="Adres" Style="width:100%;">
                        <RadzenTextArea @bind-Value="firma.FirmaAdres" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="İlçe" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaIlce" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="İl" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaIl" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Vergi Dairesi" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaVergiDairesi" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Vergi Numarası" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaVergiNumarasi" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Mersis Numarası" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaMersisNumarasi" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Web Adresi" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaWebAdresi" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Yetkili Adı Soyadı" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaYetkiliAdiSoyadi" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Mail" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaMail" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Telefon" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaTelefon" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="GSM" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaGsm" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenText TextStyle="TextStyle.H6" class="mt-3 mb-2">SMTP Bilgileri</RadzenText>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="SMTP Host" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaSmtpHost" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="SMTP Host" Style="width:100%;">
                        <RadzenNumeric @bind-Value="firma.FirmaSmtpPort"
                                       Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="SMTP User" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaSmtpUser" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="SMTP Password" Style="width:100%;">
                        <RadzenPassword @bind-Value="firma.FirmaSmtpPassword" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenFormField Text="SMTP Secure" Style="width:100%;">
                        <RadzenTextBox @bind-Value="firma.FirmaSmtpSecure" Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenFormField Text="Aktif/Pasif" Style="width:100%;">
                        <RadzenDropDown @bind-Value="firma.FirmaAktifPasif"
                                        Data="@durumlar"
                                        Style="width:100%;" />
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" class="mt-3">
                        <RadzenButton Text="Güncelle" Icon="save" ButtonType="ButtonType.Submit" />
                        <RadzenButton Text="İptal" Icon="close" ButtonStyle="ButtonStyle.Secondary" Click="@Cancel" />
                    </RadzenStack>
                </RadzenColumn>

            </RadzenRow>
        </EditForm>
    </RadzenCard>
}

@code {
    [Parameter] public int id { get; set; }

    private Firma? firma;
    private List<int> durumlar = new() { 1, 0 };

    protected override async Task OnInitializedAsync()
    {
        firma = await FirmaService.GetByIdAsync(id);
    }

    private async Task HandleValidSubmit()
    {
        if (firma == null)
            return;

        var result = await FirmaService.UpdateAsync(firma);

        if (result != null)
        {
            NotificationService.Notify(
                NotificationSeverity.Success,
                "Başarılı",
                "Firma kaydı güncellendi.");

            NavigationManager.NavigateTo("/companies");
        }
        else
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Hata",
                "Firma kaydı güncellenemedi.");
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/companies");
    }
}