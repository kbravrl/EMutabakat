@inject IMutabakatService MutabakatService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<div class="p-2">
    <RadzenText TextStyle="TextStyle.H6">Excel Dosyası Seç</RadzenText>

    <div class="my-4">
        <InputFile OnChange="HandleSelected" Accept=".xls,.xlsx" />
    </div>

    <div class="my-4">
        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true">
            Örnek Excel dosyasını aşağıdan indirip kullanabilirsiniz.
        </RadzenAlert>
    </div>

    <div class="rz-text-align-right">
        <RadzenButton Text="Örnek Excel Dosyası"
                      Icon="download"
                      ButtonStyle="ButtonStyle.Success"
                      Click="DownloadTemplate" />

        <RadzenButton Text="Kaydet"
                      Icon="save"
                      ButtonStyle="ButtonStyle.Primary"
                      Click="@(() => Upload(false))"
                      Disabled="@isUploading" />

        <RadzenButton Text="Kaydet ve Mail Gönder"
                      Icon="mail"
                      ButtonStyle="ButtonStyle.Info"
                      Click="@(() => Upload(true))"
                      Disabled="@isUploading" />

        <RadzenButton Text="İptal"
                      Icon="close"
                      Click="Cancel"
                      ButtonStyle="ButtonStyle.Secondary" />
    </div>
</div>

@code {
    private IBrowserFile? selectedFile;
    private bool isUploading = false;

    private void HandleSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private void DownloadTemplate()
    {
        NavigationManager.NavigateTo("/templates/MutabakatTemplate.xlsx", forceLoad: true);
    }

    private async Task Upload(bool sendMail)
    {
        if (isUploading) return;

        if (selectedFile == null)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Lütfen bir dosya seçin.");
            return;
        }

        isUploading = true;

        try
        {
            await using var ms = new MemoryStream();
            await selectedFile.OpenReadStream(50 * 1024 * 1024).CopyToAsync(ms);
            ms.Position = 0;

            var (createdCount, mailSentCount, errors) =
                await MutabakatService.ImportFromExcelAsync(ms, selectedFile.Name, sendMail);

            string msg = sendMail
                ? $"Oluşturulan Kayıt: {createdCount}, Gönderilen mail: {mailSentCount}"
                : $"Oluşturulan Kayıt: {createdCount}";

            if (errors != null && errors.Count > 0)
            {
                var parameters = new Dictionary<string, object?> { ["Errors"] = errors };
                await DialogService.OpenAsync(
                    string.Empty,
                    typeof(ImportErrors),
                    parameters,
                    new DialogOptions { Width = "700px", Height = "400px" });
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Success, "Tamamlandı", msg);
            }

            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", ex.Message);
        }
        finally
        {
            isUploading = false;
        }
    }

    private void Cancel()
    {
        DialogService.Close(false);
    }
}