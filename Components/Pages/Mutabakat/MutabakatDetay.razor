@page "/reconciliations/detail/{id}"

@attribute [Authorize]

@inject IMutabakatService MutabakatService
@inject NavigationManager NavigationManager

<PageTitle>Mutabakat Detay</PageTitle>

@if (mutabakat == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">Kayıt bulunamadı.</RadzenAlert>
}
else
{
    <RadzenCard Class="p-4" Style="max-width:900px;margin-left:auto;margin-right:auto;">
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="8px">
            <RadzenText TextStyle="TextStyle.H4">Mutabakat Detay</RadzenText>
        </RadzenStack>

        <RadzenDivider />

        <RadzenFieldset Text="Genel Bilgiler" Style="margin-bottom:16px">
            <RadzenRow Gap="16px">

                <RadzenColumn Size="12" SizeMD="6">
                    <b>Tarih:</b> @mutabakat.MutabakatTarihi.ToString("dd.MM.yyyy")
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <b>Firma:</b> @(string.IsNullOrWhiteSpace(mutabakat.Firma?.FirmaAdi) ? "-" : mutabakat.Firma.FirmaAdi)
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <b>Cari:</b> @(string.IsNullOrWhiteSpace(mutabakat.Cari?.CariAdi) ? "-" : mutabakat.Cari.CariAdi)
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <b>Döviz:</b> @(mutabakat.DovizKodu?.Name ?? mutabakat.MutabakatDovizKodu)
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <b>Bakiye:</b> @mutabakat.MutabakatBakiye.ToString("N2")
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <b>Bakiye Tipi:</b> @GetBakiyeTipiText(mutabakat.MutabakatBakiyeTipi)
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <b>Açıklama:</b> @(string.IsNullOrWhiteSpace(mutabakat.MutabakatAciklama) ? "-" : mutabakat.MutabakatAciklama)
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <b>Durum:</b> @GetStatusText(mutabakat.Status)
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <b>Gönderim Tarihi:</b>
                    @(mutabakat.MutabakatGonderimTarihSaat.HasValue
                        ? mutabakat.MutabakatGonderimTarihSaat.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        : "-")
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <b>Cevap Tarihi:</b>
                    @(mutabakat.MutabakatCevapTarihSaat?.ToLocalTime().ToString("dd.MM.yyyy HH:mm") ?? "-")
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <b>Cevap Mail:</b> @(string.IsNullOrWhiteSpace(mutabakat.MutabakatCevapMail) ? "-" : mutabakat.MutabakatCevapMail)
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <b>Cevap Ad Soyad:</b> @(string.IsNullOrWhiteSpace(mutabakat.MutabakatCevapAdSoyad) ? "-" : mutabakat.MutabakatCevapAdSoyad)
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <b>Cevap GSM:</b> @(string.IsNullOrWhiteSpace(mutabakat.MutabakatCevapGsm) ? "-" : mutabakat.MutabakatCevapGsm)
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <b>Cevap Açıklama:</b> @(string.IsNullOrWhiteSpace(mutabakat.MutabakatCevapAciklama) ? "-" : mutabakat.MutabakatCevapAciklama)
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <b>Token:</b> @(string.IsNullOrWhiteSpace(mutabakat.MutabakatToken) ? "-" : mutabakat.MutabakatToken)
                </RadzenColumn>

                <RadzenColumn Size="12">
                    @if (string.IsNullOrWhiteSpace(mutabakat.MutabakatReceiveStoragePath))
                    {
                        <b>Red Dosyası:</b>
                        <span>-</span>
                    }
                    else
                    {
                        <RadzenButton Text="Red Dosyasını İndir"
                                      Icon="download"
                                      ButtonStyle="ButtonStyle.Info"
                                      Click="@(() => NavigationManager.NavigateTo(mutabakat.MutabakatReceiveStoragePath!, true))" />
                    }
                </RadzenColumn>

                <RadzenColumn Size="12" class="mt-3">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="10px" JustifyContent="JustifyContent.End">
                        <RadzenButton Text="Listeye Dön"
                                      Icon="arrow_back"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      Click="@BackToList"
                                      Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px;" />
                    </RadzenStack>
                </RadzenColumn>

            </RadzenRow>
        </RadzenFieldset>
    </RadzenCard>
}

@code {
    [Parameter] public string id { get; set; } = string.Empty;

    private Mutabakat? mutabakat;

    protected override async Task OnInitializedAsync()
    {
        mutabakat = await MutabakatService.GetByIdAsync(id);
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo("/reconciliations");
    }

    private string GetBakiyeTipiText(string bakiyeTipi)
    {
        return bakiyeTipi switch
        {
            "B" => "Borç",
            "A" => "Alacak",
            _ => "-"
        };
    }

    private string GetStatusText(Mutabakat.MutabakatStatus status)
    {
        return status switch
        {
            Mutabakat.MutabakatStatus.Kaydedildi => "Kaydedildi",
            Mutabakat.MutabakatStatus.Gonderildi => "Gönderildi",
            Mutabakat.MutabakatStatus.Hatirlatma => "Hatırlatma",
            Mutabakat.MutabakatStatus.Mutabik => "Mutabık",
            Mutabakat.MutabakatStatus.MutabikDegil => "Mutabık Değil",
            _ => "Tanımsız"
        };
    }
}