@page "/reconciliations/response/{token}"

@inject IMutabakatClientService MutabakatClientService
@inject NavigationManager NavigationManager
@using System.ComponentModel.DataAnnotations

<PageTitle>Mutabakat Cevabı</PageTitle>

<RadzenRow JustifyContent="JustifyContent.Center" class="mt-5">
    <RadzenColumn Size="12" SizeMD="8" SizeLG="6">

        <RadzenCard class="p-4 shadow-2" Style="border-radius:16px;">

            @if (isLoading)
            {
                <RadzenStack AlignItems="AlignItems.Center" Gap="1rem">
                    <RadzenProgressBarCircular Mode="ProgressBarMode.Indeterminate" />
                    <RadzenText TextStyle="TextStyle.H5">İşleniyor...</RadzenText>
                </RadzenStack>
            }
            else if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Variant="Variant.Flat">
                    @successMessage
                </RadzenAlert>
            }
            else if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat">
                    @errorMessage
                </RadzenAlert>
            }
            else if (showRejectUpload && mutabakat is not null)
            {
                <RadzenStack Gap="1rem">
                    <RadzenText TextStyle="TextStyle.H4">Mutabakat Cevabı</RadzenText>

                    <RadzenAlert AlertStyle="AlertStyle.Light" ShowIcon="true" Variant="Variant.Flat">
                        Mutabık değilseniz lütfen dosya yükleyiniz. Maksimum dosya boyutu 10 MB olabilir.
                    </RadzenAlert>

                    <InputFile OnChange="OnFileSelected" />

                    <RadzenTextBox Style="width:100%" Placeholder="Cevap e-posta (opsiyonel)" @bind-Value="responseMail" />
                    <RadzenTextBox Style="width:100%" Placeholder="Cevap Ad Soyad (opsiyonel)" @bind-Value="responseName" />
                    <RadzenTextBox Style="width:100%" Placeholder="Cevap GSM (opsiyonel)" @bind-Value="responseGsm" />
                    <RadzenTextArea Style="width:100%" Placeholder="Cevap Açıklama (opsiyonel)" @bind-Value="responseAciklama" />

                    @if (!string.IsNullOrWhiteSpace(fileName))
                    {
                        <RadzenText TextStyle="TextStyle.Body2">
                            Seçilen dosya: <b>@fileName</b>
                        </RadzenText>
                    }

                    @if (!string.IsNullOrWhiteSpace(fileError))
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat">
                            @fileError
                        </RadzenAlert>
                    }

                    <RadzenButton Text="Dosyayı Gönder"
                                  Icon="upload"
                                  ButtonStyle="ButtonStyle.Success"
                                  Click="SubmitRejectAsync"
                                  Disabled="@isSubmitting" />
                </RadzenStack>
            }

        </RadzenCard>

    </RadzenColumn>
</RadzenRow>

@code {
    [Parameter] public string token { get; set; } = string.Empty;

    private Mutabakat? mutabakat;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private bool showRejectUpload = false;

    private string? successMessage;
    private string? errorMessage;
    private string? durum;
    private string? fileError;
    private string? fileName;
    private IBrowserFile? selectedFile;
    private string? responseMail;
    private string? responseName;
    private string? responseGsm;
    private string? responseAciklama;

    private const long MaxFileSize = 10 * 1024 * 1024; // 10 MB

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(token))
        {
            errorMessage = "Geçersiz link.";
            isLoading = false;
            return;
        }

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("durum", out var durumValue))
        {
            durum = durumValue.ToString().Trim().ToLowerInvariant();
        }

        mutabakat = await MutabakatClientService.GetByTokenAsync(token);

        if (mutabakat == null)
        {
            errorMessage = "Mutabakat bulunamadı.";
            isLoading = false;
            return;
        }

        if (mutabakat.MutabakatDurum == 1)
        {
            if (durum == "approve")
                successMessage = "Cevabınız başarı ile kaydedildi.";
            else
                errorMessage = "Bu mutabakata cevap önceden verildi.";

            isLoading = false;
            return;
        }

        if (mutabakat.MutabakatDurum == 2)
        {
            if (durum == "reject")
                successMessage = "Dosya gönderildi.";
            else
                errorMessage = "Bu mutabakata cevap önceden verildi.";

            isLoading = false;
            return;
        }

        if (durum == "approve")
        {
            var ok = await MutabakatClientService.ApproveAsync(token);

            if (ok)
                successMessage = "Cevabınız başarı ile kaydedildi.";
            else
                errorMessage = "Bu mutabakata cevap önceden verildi.";

            isLoading = false;
            return;
        }

        if (durum == "reject")
        {
            showRejectUpload = true;
            isLoading = false;
            return;
        }

        errorMessage = "Geçersiz işlem.";
        isLoading = false;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        fileError = null;
        fileName = null;
        selectedFile = null;

        var file = e.File;
        if (file == null)
            return;

        if (file.Size > MaxFileSize)
        {
            fileError = "Dosya boyutu en fazla 10 MB olabilir.";
            return;
        }

        selectedFile = file;
        fileName = file.Name;
    }

    private async Task SubmitRejectAsync()
    {
        if (isSubmitting)
            return;

        fileError = null;
        errorMessage = null;

        if (selectedFile == null)
        {
            fileError = "Lütfen bir dosya seçiniz.";
            return;
        }

        if (selectedFile.Size > MaxFileSize)
        {
            fileError = "Dosya boyutu en fazla 10 MB olabilir.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(responseMail))
        {
            var validator = new EmailAddressAttribute();
            if (!validator.IsValid(responseMail))
            {
                fileError = "Geçerli bir e-posta adresi giriniz.";
                return;
            }
        }

        isSubmitting = true;

        try
        {
            await using var stream = selectedFile.OpenReadStream(MaxFileSize);

            var ok = await MutabakatClientService.RejectAsync(
                token,
                responseMail,
                responseName,
                responseGsm,
                responseAciklama,
                stream,
                selectedFile.Name);

            if (ok)
            {
                showRejectUpload = false;
                successMessage = "Dosya gönderildi.";
            }
            else
            {
                errorMessage = "Bu mutabakata cevap önceden verildi.";
            }
        }
        catch
        {
            fileError = "Dosya yüklenirken hata oluştu.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}