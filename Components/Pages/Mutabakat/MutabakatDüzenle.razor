@page "/reconciliations/edit/{id}"
@attribute [Authorize]

@inject IMutabakatService MutabakatService
@inject ICariService CariService
@inject IFirmaService FirmaService
@inject IDovizKoduService DovizKoduService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Mutabakat Düzenle</PageTitle>

@if (isLoading)
{
    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="height:6px;" />
}
else if (mutabakat == null)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">
        Kayıt bulunamadı.
    </RadzenAlert>
}
else
{
    <EditForm EditContext="@editContext">
        <DataAnnotationsValidator />

        <RadzenCard Class="p-4" Style="max-width:900px;margin:auto;">
            <RadzenText TextStyle="TextStyle.H5">Mutabakat Düzenle</RadzenText>
            <RadzenDivider />

            <RadzenRow Gap="16px">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Mutabakat ID" />
                    <RadzenTextBox @bind-Value="mutabakat.MutabakatId"
                                   Name="MutabakatId"
                                   Style="width:100%" />
                    <ValidationMessage For="@(() => mutabakat.MutabakatId)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Firma" />
                    <RadzenDropDown TValue="int?"
                                    Data="@firmalar"
                                    TextProperty="FirmaAdi"
                                    ValueProperty="FirmaId"
                                    @bind-Value="selectedFirmaId"
                                    Name="FirmaId"
                                    Style="width:100%"
                                    AllowFiltering="true"
                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                    Change="@OnFirmaChanged" />
                    <ValidationMessage For="@(() => mutabakat.FirmaId)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Cari" />
                    <RadzenDropDown TValue="string"
                                    Data="@filteredCariler"
                                    TextProperty="CariDisplayText"
                                    ValueProperty="CariId"
                                    @bind-Value="mutabakat.CariId"
                                    Name="CariId"
                                    Style="width:100%"
                                    AllowFiltering="true"
                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                    Disabled="@(selectedFirmaId == null)"
                                    Change="@OnCariChanged" />
                    <ValidationMessage For="@(() => mutabakat.CariId)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Cari Mail" />
                    <RadzenTextBox @bind-Value="cariMail"
                                   Name="CariMail"
                                   Style="width:100%" />
                    <ValidationMessage For="@(() => mutabakat.Cari.CariYetkiliMail)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Mutabakat Tarihi" />
                    <RadzenDatePicker @bind-Value="mutabakatTarihiTemp"
                                      DateFormat="dd.MM.yyyy"
                                      Style="width:100%"
                                      Change="@OnDateChanged" />
                    <ValidationMessage For="@(() => mutabakat.MutabakatTarihi)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Döviz Kodu" />
                    <RadzenDropDown Data="@dovizKodlari"
                                    TextProperty="Name"
                                    ValueProperty="TCMB"
                                    @bind-Value="mutabakat.MutabakatDovizKodu"
                                    Name="MutabakatDovizKodu"
                                    Style="width:100%" />
                    <ValidationMessage For="@(() => mutabakat.MutabakatDovizKodu)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Bakiye" />
                    <RadzenNumeric @bind-Value="mutabakat.MutabakatBakiye"
                                   Name="MutabakatBakiye"
                                   TValue="decimal"
                                   Style="width:100%;" />
                    <ValidationMessage For="@(() => mutabakat.MutabakatBakiye)" />
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenLabel Text="Bakiye Tipi" />
                    <RadzenDropDown Data="@bakiyeTipleri"
                                    TextProperty="Text"
                                    ValueProperty="Value"
                                    @bind-Value="mutabakat.MutabakatBakiyeTipi"
                                    Name="MutabakatBakiyeTipi"
                                    Style="width:100%" />
                    <ValidationMessage For="@(() => mutabakat.MutabakatBakiyeTipi)" />
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenLabel Text="Açıklama" />
                    <RadzenTextArea @bind-Value="mutabakat.MutabakatAciklama"
                                    Name="MutabakatAciklama"
                                    Style="width:100%"
                                    Rows="4" />
                </RadzenColumn>
            </RadzenRow>

            <RadzenDivider />

            <RadzenStack Orientation="Orientation.Horizontal"
                         Gap="10px"
                         JustifyContent="JustifyContent.End">
                <RadzenButton Text="Kaydet"
                              Icon="save"
                              Style="font-size:12px;"
                              ButtonStyle="ButtonStyle.Success"
                              Click="@UpdateOnly"
                              Disabled="@isSubmitting" />

                <RadzenButton Text="Kaydet ve Mail Gönder"
                              Icon="mail"
                              Style="font-size:12px;"
                              ButtonStyle="ButtonStyle.Primary"
                              Click="@UpdateAndSendMail"
                              Disabled="@isSubmitting" />

                <RadzenButton Text="İptal"
                              Icon="close"
                              Style="font-size:12px;"
                              ButtonStyle="ButtonStyle.Secondary"
                              Click="@BackToList"
                              Disabled="@isSubmitting" />
            </RadzenStack>
        </RadzenCard>
    </EditForm>
}

@code {
    [Parameter] public string id { get; set; } = string.Empty;

    private Mutabakat? mutabakat;
    private EditContext? editContext;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private DateTime mutabakatTarihiTemp;
    private string? cariMail;
    private int? selectedFirmaId;

    private List<CariLookupItem> allCariler = new();
    private List<CariLookupItem> filteredCariler = new();
    private List<FirmaLookupItem> firmalar = new();
    private List<DovizKodu> dovizKodlari = new();

    private List<BakiyeTipItem> bakiyeTipleri = new()
    {
        new() { Text = "Borç", Value = "B" },
        new() { Text = "Alacak", Value = "A" }
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            mutabakat = await MutabakatService.GetByIdAsync(id);

            if (mutabakat != null)
            {
                mutabakat.OriginalMutabakatId = mutabakat.MutabakatId;

                var firmaList = await FirmaService.GetAllAsync();
                firmalar = firmaList
                    .OrderBy(x => x.FirmaAdi)
                    .Select(x => new FirmaLookupItem
                    {
                        FirmaId = x.FirmaId,
                        FirmaAdi = x.FirmaAdi ?? string.Empty
                    })
                    .ToList();

                var cariList = await CariService.GetAllAsync();
                allCariler = cariList
                    .OrderBy(x => x.CariAdi)
                    .Select(x => new CariLookupItem
                    {
                        CariId = x.CariId,
                        FirmaId = x.FirmaId,
                        CariAdi = x.CariAdi ?? string.Empty,
                        CariDovizKodu = x.CariDovizKodu,
                        CariYetkiliMail = x.CariYetkiliMail
                    })
                    .ToList();

                selectedFirmaId = mutabakat.FirmaId;

                filteredCariler = allCariler
                    .Where(x => x.FirmaId == mutabakat.FirmaId)
                    .OrderBy(x => x.CariAdi)
                    .ToList();

                dovizKodlari = await DovizKoduService.GetAllAsync();

                mutabakatTarihiTemp = mutabakat.MutabakatTarihi;
                editContext = new EditContext(mutabakat);

                var selectedCari = filteredCariler.FirstOrDefault(x =>
                    x.CariId == mutabakat.CariId && x.FirmaId == mutabakat.FirmaId);

                cariMail = selectedCari?.CariYetkiliMail;
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnFirmaChanged(object value)
    {
        if (mutabakat == null)
            return;

        selectedFirmaId = value as int? ?? ConvertToNullableInt(value);

        mutabakat.FirmaId = selectedFirmaId ?? 0;
        mutabakat.CariId = string.Empty;
        cariMail = null;

        filteredCariler = selectedFirmaId.HasValue
            ? allCariler
                .Where(x => x.FirmaId == selectedFirmaId.Value)
                .OrderBy(x => x.CariAdi)
                .ToList()
            : new List<CariLookupItem>();
    }

    private void OnCariChanged(object value)
    {
        if (mutabakat == null || !selectedFirmaId.HasValue)
            return;

        var cariId = value?.ToString();
        if (string.IsNullOrWhiteSpace(cariId))
            return;

        var selectedCari = filteredCariler.FirstOrDefault(x =>
            x.CariId == cariId && x.FirmaId == selectedFirmaId.Value);

        if (selectedCari == null)
            return;

        mutabakat.FirmaId = selectedCari.FirmaId;
        cariMail = selectedCari.CariYetkiliMail;

        if (!string.IsNullOrWhiteSpace(selectedCari.CariDovizKodu))
        {
            mutabakat.MutabakatDovizKodu = selectedCari.CariDovizKodu;
        }
    }

    private void OnDateChanged(DateTime? value)
    {
        if (mutabakat == null || value == null) return;
        mutabakat.MutabakatTarihi = value.Value.Date;
    }

    private async Task UpdateOnly()
    {
        if (isSubmitting || editContext == null || mutabakat == null) return;
        if (!editContext.Validate()) return;

        if (!selectedFirmaId.HasValue)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Lütfen firma seçiniz.");
            return;
        }

        if (string.IsNullOrWhiteSpace(mutabakat.CariId))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Lütfen cari seçiniz.");
            return;
        }

        if (!ValidateCariMail())
            return;

        isSubmitting = true;

        try
        {
            mutabakat.FirmaId = selectedFirmaId.Value;

            var updated = await MutabakatService.UpdateAsync(mutabakat, cariMail);

            if (updated == null)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Hata", "Kayıt bulunamadı.");
                return;
            }

            NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Mutabakat güncellendi.");
            NavigationManager.NavigateTo("/reconciliations");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task UpdateAndSendMail()
    {
        if (isSubmitting || editContext == null || mutabakat == null) return;
        if (!editContext.Validate()) return;

        if (!selectedFirmaId.HasValue)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Lütfen firma seçiniz.");
            return;
        }

        if (string.IsNullOrWhiteSpace(mutabakat.CariId))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Lütfen cari seçiniz.");
            return;
        }

        if (!ValidateCariMail())
            return;

        isSubmitting = true;

        try
        {
            mutabakat.FirmaId = selectedFirmaId.Value;

            var updated = await MutabakatService.UpdateAsync(mutabakat, cariMail);

            if (updated == null)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Hata", "Kayıt bulunamadı.");
                return;
            }

            var sent = await MutabakatService.SendMailAsync(updated.MutabakatId);

            if (!sent)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Kayıt güncellendi fakat mail gönderilemedi.");
                return;
            }

            NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Mutabakat güncellendi ve mail gönderildi.");
            NavigationManager.NavigateTo("/reconciliations");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void BackToList()
    {
        NavigationManager.NavigateTo("/reconciliations");
    }

    private bool ValidateCariMail()
    {
        if (string.IsNullOrWhiteSpace(cariMail))
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", "Cari mail adresi boş olamaz.");
            return false;
        }

        try
        {
            var _ = new System.Net.Mail.MailAddress(cariMail!);
            return true;
        }
        catch
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", "Lütfen geçerli bir mail adresi giriniz.");
            return false;
        }
    }

    private static int? ConvertToNullableInt(object? value)
    {
        if (value == null)
            return null;

        if (value is int intValue)
            return intValue;

        return int.TryParse(value.ToString(), out var parsed) ? parsed : null;
    }

    public class BakiyeTipItem
    {
        public string Text { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private sealed class CariLookupItem
    {
        public string CariId { get; set; } = string.Empty;
        public int FirmaId { get; set; }
        public string CariAdi { get; set; } = string.Empty;
        public string? CariDovizKodu { get; set; }
        public string? CariYetkiliMail { get; set; }

        public string CariDisplayText => $"{CariId} - {CariAdi}";
    }

    private sealed class FirmaLookupItem
    {
        public int FirmaId { get; set; }
        public string FirmaAdi { get; set; } = string.Empty;
    }
}