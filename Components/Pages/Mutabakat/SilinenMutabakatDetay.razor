@page "/reconciliations/deleted/{Id:int}"

@inject IMutabakatService MutabakatService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Silinen Mutabakat Detayı</PageTitle>

<RadzenCard Style="padding:20px;">
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween"
                 Style="margin-bottom:20px;">
        <RadzenText TextStyle="TextStyle.H4">Silinen Mutabakat Detayı</RadzenText>

        <RadzenButton Text="Listeye Dön"
                      Icon="arrow_back"
                      Style="font-size:12px;"
                      ButtonStyle="ButtonStyle.Secondary"
                      Click="@GoBack" />
    </RadzenStack>

    @if (loading)
    {
        <RadzenText>Yükleniyor...</RadzenText>
    }
    else if (item == null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning">
            Kayıt bulunamadı.
        </RadzenAlert>
    }
    else
    {
        <RadzenRow Gap="20px">
            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFieldset Text="Temel Bilgiler">
                    <div class="mb-3"><b>Mutabakat ID:</b> @item.MutabakatId</div>
                    <div class="mb-3"><b>Firma:</b> @item.Firma?.FirmaAdi</div>
                    <div class="mb-3"><b>Cari:</b> @item.Cari?.CariAdi</div>
                    <div class="mb-3"><b>Tarih:</b> @item.MutabakatTarihi.ToString("dd.MM.yyyy")</div>
                    <div class="mb-3"><b>Döviz:</b> @(item.DovizKodu?.Name ?? item.MutabakatDovizKodu)</div>
                    <div class="mb-3"><b>Bakiye:</b> @item.MutabakatBakiye.ToString("N2")</div>
                    <div class="mb-3"><b>Bakiye Tipi:</b> @GetBakiyeTipiText(item.MutabakatBakiyeTipi)</div>
                    <div class="mb-3">
                        <b>Durum:</b>
                        <RadzenBadge Text="@GetStatusText(item.Status)"
                                     BadgeStyle="@GetStatusBadgeStyle(item.Status)"
                                     Style="margin-left:8px;" />
                    </div>
                    <div class="mb-3"><b>Açıklama:</b> @(string.IsNullOrWhiteSpace(item.MutabakatAciklama) ? "-" : item.MutabakatAciklama)</div>
                </RadzenFieldset>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="6">
                <RadzenFieldset Text="Gönderim / Cevap Bilgileri">
                    <div class="mb-3">
                        <b>Gönderim Tarihi:</b>
                        @(item.MutabakatGonderimTarihSaat.HasValue
                            ? item.MutabakatGonderimTarihSaat.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            : "-")
                    </div>
                    <div class="mb-3">
                        <b>Cevap Tarihi:</b>
                        @(item.MutabakatCevapTarihSaat.HasValue
                            ? item.MutabakatCevapTarihSaat.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            : "-")
                    </div>
                    <div class="mb-3"><b>Cevap Mail:</b> @(string.IsNullOrWhiteSpace(item.MutabakatCevapMail) ? "-" : item.MutabakatCevapMail)</div>
                    <div class="mb-3"><b>Cevap Ad Soyad:</b> @(string.IsNullOrWhiteSpace(item.MutabakatCevapAdSoyad) ? "-" : item.MutabakatCevapAdSoyad)</div>
                    <div class="mb-3"><b>Cevap GSM:</b> @(string.IsNullOrWhiteSpace(item.MutabakatCevapGsm) ? "-" : item.MutabakatCevapGsm)</div>
                    <div class="mb-3"><b>Cevap Açıklama:</b> @(string.IsNullOrWhiteSpace(item.MutabakatCevapAciklama) ? "-" : item.MutabakatCevapAciklama)</div>
                    <div class="mb-3"><b>Token:</b> @(string.IsNullOrWhiteSpace(item.MutabakatToken) ? "-" : item.MutabakatToken)</div>
                    <div class="mb-3"><b>Red Dosya Yolu:</b> @(string.IsNullOrWhiteSpace(item.MutabakatReceiveStoragePath) ? "-" : item.MutabakatReceiveStoragePath)</div>
                </RadzenFieldset>
            </RadzenColumn>
        </RadzenRow>
    }
</RadzenCard>

@code {
    [Parameter]
    public int Id { get; set; }

    private SilinenMutabakat? item;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            item = await MutabakatService.GetDeletedByIdAsync(Id);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", ex.Message);
        }
        finally
        {
            loading = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/reconciliations/deleted");
    }

    private string GetBakiyeTipiText(string bakiyeTipi)
    {
        return bakiyeTipi switch
        {
            "B" => "Borç",
            "A" => "Alacak",
            _ => "-"
        };
    }

    private string GetStatusText(Mutabakat.MutabakatStatus status)
    {
        return status switch
        {
            Mutabakat.MutabakatStatus.Kaydedildi => "Kaydedildi",
            Mutabakat.MutabakatStatus.Gonderildi => "Gönderildi",
            Mutabakat.MutabakatStatus.Hatirlatma => "Hatırlatma",
            Mutabakat.MutabakatStatus.Mutabik => "Mutabık",
            Mutabakat.MutabakatStatus.MutabikDegil => "Mutabık Değil",
            _ => "Tanımsız"
        };
    }

    private BadgeStyle GetStatusBadgeStyle(Mutabakat.MutabakatStatus status)
    {
        return status switch
        {
            Mutabakat.MutabakatStatus.Kaydedildi => BadgeStyle.Secondary,
            Mutabakat.MutabakatStatus.Gonderildi => BadgeStyle.Info,
            Mutabakat.MutabakatStatus.Hatirlatma => BadgeStyle.Warning,
            Mutabakat.MutabakatStatus.Mutabik => BadgeStyle.Success,
            Mutabakat.MutabakatStatus.MutabikDegil => BadgeStyle.Danger,
            _ => BadgeStyle.Light
        };
    }
}