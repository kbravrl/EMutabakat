                "Hata",
                ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void OnPageChanged(PagerEventArgs args)
    {
        currentPageIndex = args.PageIndex;
    }

    private async Task RestoreCurrentPageAsync()
    {
        if (mutabakatGrid == null)
        {
            return;
        }

        await mutabakatGrid.GoToPage(currentPageIndex);
    }

