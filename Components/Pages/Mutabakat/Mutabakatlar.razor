@page "/reconciliations"

@attribute [Authorize]

@inject IMutabakatService MutabakatService
@inject IKullaniciService KullaniciService
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject NotificationService NotificationService

@inject IJSRuntime JS

<PageTitle>Mutabakatlar</PageTitle>

@if (!canView && !isLoading)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" class="m-4">Bu sayfaya giriş izniniz bulunmamaktadır.</RadzenAlert>
}
else
{
    <RadzenStack Gap="1rem" class="p-4">
        <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="mb-3">
            <RadzenColumn Size="12" SizeMD="4">
                <RadzenText TextStyle="TextStyle.H4">Mutabakat Listesi</RadzenText>
            </RadzenColumn>

            <RadzenColumn Size="12" SizeMD="8" class="rz-text-align-end">
                <div style="display:flex; align-items:center; gap:15px; justify-content:flex-end; width:100%;">

                    @if (canExport)
                    {
                        <img src="/images/excel-export.png"
                             title="Excel Dışa Aktar"
                             @onclick="ExportExcel"
                             style="width:48px; height:48px; cursor:pointer;" />
                    }

                    @if (canImport)
                    {
                        <img src="/images/excel-import.png"
                             title="Excel İçe Aktar"
                             @onclick="OpenImportDialog"
                             style="width:48px; height:48px; cursor:pointer;" />
                    }

                    @if (canEdit && canSendMail)
                    {
                        <RadzenButton Text="Toplu gönder"
                                      Icon="send"
                                      Style="font-size:15px;"
                                      ButtonStyle="ButtonStyle.Success"
                                      Click="@ConfirmSendPendingMails"
                                      Disabled="@(isSubmitting || !(selectedStatus == (int)Mutabakat.MutabakatStatus.Kaydedildi || selectedStatus == (int)Mutabakat.MutabakatStatus.Hatirlatma))" />

                        <RadzenButton Text="Seçilenleri gönder"
                                      Icon="mark_email_read"
                                      Style="font-size:15px;"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      Click="@ConfirmSendSelectedMails"
                                      Disabled="@(isSubmitting || !(selectedStatus == (int)Mutabakat.MutabakatStatus.Kaydedildi || selectedStatus == (int)Mutabakat.MutabakatStatus.Hatirlatma))" />
                    }

                    @if (canDelete)
                    {
                        <RadzenButton Text="Silinenler"
                                      Icon="history"
                                      Style="font-size:15px;"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Click="@GoToDeletedPage" />

                    <RadzenButton Text="Hepsini sil"
                                  Icon="delete_sweep"
                                  Style="font-size:15px;"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Click="@DeleteAllMutabakatlar"
                                  Disabled="@isSubmitting" />
                    }

                    @if (canAdd)
                    {
                        <RadzenButton Text="Yeni mutabakat ekle"
                                      Icon="add_circle"
                                      Style="font-size:15px;"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Click="@GoToCreatePage" />
                    }
                </div>
            </RadzenColumn>
        </RadzenRow>

        <RadzenCard>
            <div style="display:flex; align-items:center; gap:8px; flex-wrap:nowrap; width:100%; margin-bottom:1rem;">

                <RadzenTextBox Style="width:340px; "
                               Placeholder="ID / Cari / Firma ara"
                               @bind-Value="searchText" />

                <RadzenDropDown TValue="string"
                                Style="width:170px;"
                                Placeholder="Cari Grup"
                                Data="@cariGrupOptions"
                                TextProperty="Text"
                                ValueProperty="Value"
                                @bind-Value="selectedCariGrupId"
                                AllowClear="true" />

                <RadzenDropDown TValue="string"
                                Style="width:170px;"
                                Placeholder="Döviz"
                                Data="@dovizOptions"
                                TextProperty="Text"
                                ValueProperty="Value"
                                @bind-Value="selectedDovizKodu"
                                AllowClear="true" />

                <RadzenDropDown TValue="string"
                                Style="width:170px;"
                                Placeholder="Bakiye Tipi"
                                Data="@bakiyeTipiOptions"
                                TextProperty="Text"
                                ValueProperty="Value"
                                @bind-Value="selectedBakiyeTipi"
                                AllowClear="true" />

                <RadzenDropDown TValue="int?"
                                Style="width:170px;"
                                Placeholder="Durum"
                                Data="@statusOptions"
                                TextProperty="Text"
                                ValueProperty="Value"
                                @bind-Value="selectedStatus"
                                AllowClear="true" />

                <RadzenDropDown TValue="string"
                                Style="width:170px;"
                                Placeholder="Dönem"
                                Data="@periodOptions"
                                TextProperty="Text"
                                ValueProperty="Value"
                                @bind-Value="selectedPeriod"
                                AllowClear="true" />

                <RadzenButton Text="Temizle"
                              Icon="restart_alt"
                              ButtonStyle="ButtonStyle.Light"
                              Style="height:36px; white-space:nowrap; font-size:15px;"
                              Click="@ClearFilters" />

                <RadzenButton Icon="refresh"
                              ButtonStyle="ButtonStyle.Primary"
                              Style="height:36px; width:42px; font-size:15px;"
                              Click="@RefreshData"
                              IsBusy="@isLoading"
                              Disabled="@isLoading"
                              Title="Yenile" />

            </div>

            <RadzenDataGrid Data="@filteredMutabakatlar"
                            TItem="Mutabakat"
                            @ref="mutabakatGrid"
                            SelectionMode="DataGridSelectionMode.Multiple"
                            @bind-Value="@selectedMutabakatlar"
                            AllowRowSelectOnRowClick="false"
                            AllowPaging="true"
                            AllowSorting="true"
                            AllowFiltering="false"
                            PageSize="10"
                            PageChanged="@OnPageChanged"
                            EmptyText="Kayıt bulunamadı.">

                <Columns>
                    <RadzenDataGridColumn TItem="Mutabakat" Property="MutabakatId" Title="ID" Width="80px" OrderIndex="0" />

                    <RadzenDataGridColumn TItem="Mutabakat" Title="Firma" OrderIndex="1">
                        <Template Context="item">
                            @item.Firma?.FirmaAdi
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Mutabakat" Title="Cari" OrderIndex="2">
                        <Template Context="item">
                            @item.Cari?.CariAdi
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Mutabakat" Title="Cari Grup" OrderIndex="3">
                        <Template Context="item">
                            @(item.Cari?.CariGrup?.CariGrupAdi ?? "-")
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Mutabakat" Title="Döviz" OrderIndex="4">
                        <Template Context="item">
                            @(item.DovizKodu?.TCMB ?? item.MutabakatDovizKodu)
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Mutabakat" Title="Bakiye" OrderIndex="5">
                        <Template Context="item">
                            @item.MutabakatBakiye.ToString("N2")
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Mutabakat" Title="Bakiye Tipi" OrderIndex="6">
                        <Template Context="item">
                            @GetBakiyeTipiText(item.MutabakatBakiyeTipi)
                        </Template>
                    </RadzenDataGridColumn>

                    
                    <RadzenDataGridColumn TItem="Mutabakat" Title="Mutabakat">
                        <Template Context="item">
                            @item.MutabakatTarihi.ToString("dd.MM.yyyy")
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Mutabakat" Width="120px" Title="Gönderim" OrderIndex="8">
                        <Template Context="item">
                            @(item.MutabakatGonderimTarihSaat?.ToString("dd.MM.yyyy"))
                        </Template>
                    </RadzenDataGridColumn>

                    <RadzenDataGridColumn TItem="Mutabakat"
                                          Width="120px"
                                          Property="MutabakatCevapTarihSaat"
                                          Title="Cevap"
                                          OrderIndex="9">
                        <Template Context="item">
                            @(item.MutabakatCevapTarihSaat?.ToString("dd.MM.yyyy"))
                        </Template>
                    </RadzenDataGridColumn>

                    @if (canEdit && canSendMail && IsSelectableStatusFilter())
                    {
                        <RadzenDataGridColumn TItem="Mutabakat" Title="Seçim" Width="70px" Sortable="false" Filterable="false" OrderIndex="10">
                            <Template Context="item">
                                <RadzenCheckBox TValue="bool"
                                                Value="@(selectedMutabakatlar.Any(x => x.MutabakatId == item.MutabakatId))"
                                                Change="@(checkedValue => OnRowSelectionChanged(item, checkedValue))"
                                                Disabled="@(!CanSelectMutabakat(item))" />
                            </Template>
                        </RadzenDataGridColumn>
                    }

                    @if (canEdit || canDelete)
                    {
                        <RadzenDataGridColumn TItem="Mutabakat" Title="İşlemler" Sortable="false" Filterable="false" Width="170px" OrderIndex="11">
                            <Template Context="item">
                                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">

                @if (canEdit && canSendMail && item.Status == Mutabakat.MutabakatStatus.Kaydedildi)
                                {
                                    <RadzenButton Icon="mail"
                                                  Size="ButtonSize.Small"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Primary"
                                                  Title="Gönder"
                                                  Click="@(() => SendMail(item.MutabakatId, item.FirmaId))"
                                                  Disabled="@isSubmitting" />
                                }

                @if (canEdit && canSendMail && (item.Status == Mutabakat.MutabakatStatus.Gonderildi ||
                                                item.Status == Mutabakat.MutabakatStatus.Hatirlatma))
                                {
                                    <RadzenButton Icon="refresh"
                                                  Size="ButtonSize.Small"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Warning"
                                                  Title="Hatırlatma Gönder"
                                                  Click="@(() => SendReminder(item.MutabakatId, item.FirmaId))"
                                                  Disabled="@isSubmitting" />
                                }

                                @if (canEdit &&
                                    item.Status != Mutabakat.MutabakatStatus.Mutabik &&
                                    item.Status != Mutabakat.MutabakatStatus.MutabikDegil &&
                                    item.Status != Mutabakat.MutabakatStatus.Gonderildi)
                                {
                                    <RadzenButton Icon="edit"
                                                  Size="ButtonSize.Small"
                                                  ButtonStyle="ButtonStyle.Warning"
                                                  Title="Düzenle"
                                                  Click="@(() => EditMutabakat(item.MutabakatId))" />
                                }

                                <RadzenButton Icon="visibility"
                                              Size="ButtonSize.Small"
                                              Variant="Variant.Flat"
                                              ButtonStyle="ButtonStyle.Info"
                                              Title="Detay"
                                              Click="@(() => GoToDetailsPage(item.MutabakatId))" />

                                @if (canDelete)
                                {
                                    <RadzenButton Icon="delete"
                                                  Size="ButtonSize.Small"
                                                  Variant="Variant.Flat"
                                                  ButtonStyle="ButtonStyle.Danger"
                                                  Title="Sil"
                                                  Click="@(() => DeleteMutabakat(item.MutabakatId))"
                                                  Disabled="@isSubmitting" />
                                }
                                </RadzenStack>
                            </Template>
                        </RadzenDataGridColumn>
                    }

                    <RadzenDataGridColumn TItem="Mutabakat" Title="Durum" OrderIndex="7">
                        <Template Context="item">
                            <RadzenBadge Text="@GetStatusText(item.Status)"
                                         BadgeStyle="@GetStatusBadgeStyle(item.Status)" />
                        </Template>
                    </RadzenDataGridColumn>

                </Columns>
            </RadzenDataGrid>
        </RadzenCard>
    </RadzenStack>
}
@code {
    private RadzenDataGrid<Mutabakat>? mutabakatGrid;
    private int currentPageIndex;
    private List<Mutabakat> mutabakatlar = new();
    private IList<Mutabakat> selectedMutabakatlar = new List<Mutabakat>();
    private bool isSubmitting = false;
    private bool canView;
    private bool canAdd;
    private bool canEdit;
    private bool canDelete;
    private bool canImport;
    private bool canExport;
    private bool canSendMail;

    private string? searchText;
    private int? selectedStatus;
    private string? selectedBakiyeTipi;
    private string? selectedPeriod;
    private string? selectedCariGrupId;
    private string? selectedDovizKodu;
    private bool isLoading = true;

    private List<FilterOption<string>> cariGrupOptions = new();
    private List<FilterOption<string>> dovizOptions = new();
    private List<FilterOption<string>> periodOptions = new();


    private List<FilterOption<int?>> statusOptions = new()
    {
        new() { Text = ("Kaydedildi"), Value = (int)Mutabakat.MutabakatStatus.Kaydedildi },
        new() { Text = ("Gönderildi"), Value = (int)Mutabakat.MutabakatStatus.Gonderildi },
        new() { Text = ("Hatırlatma"), Value = (int)Mutabakat.MutabakatStatus.Hatirlatma },
        new() { Text = ("Mutabık"), Value = (int)Mutabakat.MutabakatStatus.Mutabik },
        new() { Text = ("Mutabık Değil"), Value = (int)Mutabakat.MutabakatStatus.MutabikDegil }
    };

    private List<FilterOption<string>> bakiyeTipiOptions = new()
    {
        new() { Text = "Borç", Value = "B" },
        new() { Text = "Alacak", Value = "A" }
    };

    private List<Mutabakat> filteredMutabakatlar
    {
        get
        {
            IEnumerable<Mutabakat> query = mutabakatlar;

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(x =>
                    (x.MutabakatId?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (x.Cari?.CariAdi?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (x.Firma?.FirmaAdi?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (x.Cari?.CariGrup?.CariGrupAdi?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (x.DovizKodu?.Name?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (x.MutabakatDovizKodu?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false)
                );
            }

            if (selectedStatus.HasValue)
            {
                query = query.Where(x => (int)x.Status == selectedStatus.Value);
            }

            if (!string.IsNullOrWhiteSpace(selectedBakiyeTipi))
            {
                query = query.Where(x => x.MutabakatBakiyeTipi == selectedBakiyeTipi);
            }

            if (!string.IsNullOrWhiteSpace(selectedCariGrupId))
            {
                query = query.Where(x => x.Cari?.CariGrupId == selectedCariGrupId);
            }

            if (!string.IsNullOrWhiteSpace(selectedDovizKodu))
            {
                query = query.Where(x => x.MutabakatDovizKodu == selectedDovizKodu);
            }

            if (!string.IsNullOrWhiteSpace(selectedPeriod))
            {
                var parts = selectedPeriod.Split('.');

                if (parts.Length == 2 &&
                    int.TryParse(parts[0], out var mm) &&
                    int.TryParse(parts[1], out var yyyy))
                {
                    query = query.Where(x =>
                        x.MutabakatTarihi.Month == mm &&
                        x.MutabakatTarihi.Year == yyyy);
                }
            }

   
            return query
                .OrderBy(x => GetMutabakatSortValue(x.MutabakatId))
                .ThenBy(x => x.MutabakatGonderimTarihSaat ?? DateTime.MinValue)
                .ThenBy(x => x.MutabakatCevapTarihSaat ?? DateTime.MinValue)
                .ThenBy(x => (int)x.Status)
                .ThenBy(x => x.MutabakatId)
                .ToList();
        }
    }

    private async Task ConfirmSendPendingMails()
    {
        var confirmed = await DialogService.Confirm(
            "Seçili filtreye göre kayıtların toplu gönderimi yapılacak. Onaylıyor musunuz?",
            "Toplu Gönderim Onayı",
            new ConfirmOptions
            {
                OkButtonText = "Evet",
                CancelButtonText = "Vazgeç"
            });

        if (confirmed == true)
        {
            if (selectedMutabakatlar != null && selectedMutabakatlar.Any())
            {
                await SendSelectedMails();
            }
            else
            {
                await SendPendingMails();
            }
        }
    }

    private int GetMutabakatSortValue(string? mutabakatId)
    {
        var id = mutabakatId ?? "";

        if (int.TryParse(id, out var n))
            return n;

        var match = System.Text.RegularExpressions.Regex.Match(id, @"\d+");

        if (int.TryParse(match.Value, out var m))
            return m;

        return int.MaxValue;
    }

    protected override async Task OnInitializedAsync()
    {
        var yetki = await KullaniciService.GetCurrentUserYetkiAsync();
        var isSeed = await KullaniciService.IsCurrentUserSeedAsync();

        if (isSeed)
        {
            canView = canAdd = canEdit = canDelete = canImport = canExport = canSendMail = true;
        }
        else if (yetki != null)
        {
            canView = yetki.Mutabakatlar >= YetkiSeviyesi.Giris;
            canAdd = yetki.Mutabakatlar >= YetkiSeviyesi.Giris;
            canEdit = yetki.Mutabakatlar >= YetkiSeviyesi.GirisDuzeltme;
            canDelete = yetki.Mutabakatlar == YetkiSeviyesi.TamYetki;
            canImport = yetki.ImportYetki;
            canExport = yetki.ExportYetki;
            canSendMail = yetki.MutabakatMailYetki;
        }

        if (!canView)
        {
            isLoading = false;
            return;
        }

        await LoadMutabakatlarAsync();

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("period", out var p))
            selectedPeriod = p;

        if (query.TryGetValue("bakiyeTipi", out var b))
            selectedBakiyeTipi = b;

        if (query.TryGetValue("cariGrup", out var c))
            selectedCariGrupId = c;

        isLoading = false;
    }

    private async Task OpenImportDialog()
    {
        var result = await DialogService.OpenAsync<MutabakatImportDialog>(
            "Mutabakat Excel Yükleme",
            null,
            new DialogOptions
            {
                Width = "830px",
                Height = "350px",
                Resizable = true,
                Draggable = true
            });

        if (result is bool ok && ok)
        {
            await LoadMutabakatlarAsync();
            StateHasChanged();
        }
    }

    private async Task LoadMutabakatlarAsync()
    {
        mutabakatlar = await MutabakatService.GetAllAsync();

        selectedMutabakatlar = selectedMutabakatlar
            .Where(selected => mutabakatlar.Any(x => x.MutabakatId == selected.MutabakatId))
            .ToList();

        periodOptions = mutabakatlar
            .Select(x => new { Month = x.MutabakatTarihi.Month, Year = x.MutabakatTarihi.Year })
            .Distinct()
            .OrderByDescending(a => new DateTime(a.Year, a.Month, 1))
            .Select(a => new FilterOption<string>
            {
                Value = $"{a.Month:00}.{a.Year}",
                Text = $"{a.Month:00}.{a.Year}"
            })
            .ToList();

        cariGrupOptions = mutabakatlar
           .Where(x => x.Cari?.CariGrup != null)
           .Select(x => new FilterOption<string>
           {
               Value = x.Cari!.CariGrupId!,
               Text = x.Cari.CariGrup!.CariGrupAdi
           })
           .DistinctBy(x => x.Value)
           .OrderBy(x => x.Text)
           .ToList();

        dovizOptions = mutabakatlar
            .Where(x => !string.IsNullOrWhiteSpace(x.MutabakatDovizKodu))
            .Where(x => x.DovizKodu?.DovizKoduAktifPasif != 0)
            .Select(x => new FilterOption<string>
            {
                Value = x.MutabakatDovizKodu,
                Text = x.DovizKodu?.Name ?? x.MutabakatDovizKodu
            })
            .DistinctBy(x => x.Value)
            .OrderBy(x => x.Text)
            .ToList();
    }

    private void ClearFilters()
    {
        searchText = null;
        selectedStatus = null;
        selectedBakiyeTipi = null;
        selectedPeriod = null;
        selectedCariGrupId = null;
        selectedDovizKodu = null;
    }

    private void GoToCreatePage()
    {
        NavigationManager.NavigateTo("/reconciliations/add");
    }

    private void GoToDetailsPage(string id)
    {
        NavigationManager.NavigateTo($"/reconciliations/detail/{id}");
    }

    private void EditMutabakat(string id)
    {
        NavigationManager.NavigateTo($"/reconciliations/edit/{id}");
    }

    private void GoToDeletedPage()
    {
        NavigationManager.NavigateTo("/reconciliations/deleted");
    }

    private bool IsSelectableStatusFilter()
    {
        return selectedStatus == (int)Mutabakat.MutabakatStatus.Kaydedildi ||
               selectedStatus == (int)Mutabakat.MutabakatStatus.Hatirlatma;
    }

    private bool CanSelectMutabakat(Mutabakat item)
    {
        return IsSelectableStatusFilter() &&
               (item.Status == Mutabakat.MutabakatStatus.Kaydedildi ||
                item.Status == Mutabakat.MutabakatStatus.Hatirlatma);
    }

    private void OnRowSelectionChanged(Mutabakat item, object checkedValue)
    {
        if (!CanSelectMutabakat(item))
            return;

        var isChecked = checkedValue is bool b && b;

        if (isChecked)
        {
            if (!selectedMutabakatlar.Any(x => x.MutabakatId == item.MutabakatId))
            {
                selectedMutabakatlar.Add(item);
            }
        }
        else
        {
            var selectedItem = selectedMutabakatlar.FirstOrDefault(x => x.MutabakatId == item.MutabakatId);
            if (selectedItem != null)
            {
                selectedMutabakatlar.Remove(selectedItem);
            }
        }
    }

    private async Task ExportExcel()
    {
        try
        {
            var bytes = await MutabakatService.ExportToExcelAsync();

            if (bytes == null || bytes.Length == 0)
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Uyarı",
                    "Export edilecek mutabakat kaydı bulunamadı.");
                return;
            }

            var base64 = Convert.ToBase64String(bytes);

            await JS.InvokeVoidAsync(
                "downloadFileFromBase64",
                "Mutabakatlar_Listesi.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                base64);

            NotificationService.Notify(
                NotificationSeverity.Success,
                "Başarılı",
                "Mutabakatlar Excel olarak indirildi.");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Hata",
                ex.Message);
        }
    }

    private async Task SendMail(string id, int firmaId)
    {
        if (isSubmitting) return;
        isSubmitting = true;

        try
        {
            var result = await MutabakatService.SendMailAsync(id, firmaId);

            if (result)
            {
                NotificationService.Notify(
                    NotificationSeverity.Success,
                    "Başarılı",
                    "Mutabakat maili gönderildi.");
            }
            else
            {
                NotificationService.Notify(
                    NotificationSeverity.Error,
                    "Hata",
                    "Mutabakat maili gönderilemedi.");
            }

            await LoadMutabakatlarAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Hata",
                ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    
    private async Task ConfirmSendSelectedMails()
    {
        var confirmed = await DialogService.Confirm(
            "Seçili filtreye göre seçili kayıtların gönderimi yapılacak. Onaylıyor musunuz?",
            "Seçilenleri Gönder Onayı",
            new ConfirmOptions
            {
                OkButtonText = "Evet",
                CancelButtonText = "Vazgeç"
            });

        if (confirmed == true)
        {
            await SendSelectedMails();
        }
    }

    private async Task SendReminder(string id, int firmaId)
    {
        if (isSubmitting) return;
        isSubmitting = true;

        try
        {
            var result = await MutabakatService.SendReminderAsync(id, firmaId);

            if (result)
            {
                NotificationService.Notify(
                    NotificationSeverity.Success,
                    "Başarılı",
                    "Hatırlatma maili gönderildi.");
            }
            else
            {
                NotificationService.Notify(
                    NotificationSeverity.Error,
                    "Hata",
                    "Hatırlatma maili gönderilemedi.");
            }

            await LoadMutabakatlarAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Hata",
                ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteMutabakat(string id)
    {
        var confirmed = await DialogService.Confirm(
            "Bu mutabakat kaydını silmek istediğinize emin misiniz?",
            "Silme Onayı",
            new ConfirmOptions
            {
                OkButtonText = "Evet",
                CancelButtonText = "Vazgeç"
            });

        if (confirmed == true)
        {
            if (isSubmitting) return;
            isSubmitting = true;

            try
            {
                var result = await MutabakatService.DeleteAsync(id);

                if (result)
                {
                    NotificationService.Notify(
                        NotificationSeverity.Success,
                        "Başarılı",
                        "Mutabakat kaydı silindi.");
                }
                else
                {
                    NotificationService.Notify(
                        NotificationSeverity.Error,
                        "Hata",
                        "Mutabakat kaydı silinemedi.");
                }

                await LoadMutabakatlarAsync();
                selectedMutabakatlar = selectedMutabakatlar
                    .Where(x => x.MutabakatId != id)
                    .ToList();
            }
            catch (Exception ex)
            {
                NotificationService.Notify(
                    NotificationSeverity.Error,
                    "Hata",
                    ex.Message);
            }
            finally
            {
                isSubmitting = false;
            }
        }
    }

    private async Task SendPendingMails()
    {
        if (isSubmitting) return;
        isSubmitting = true;

        try
        {
            (int successCount, int failCount, List<string> errors) result;

            if (selectedStatus == (int)Mutabakat.MutabakatStatus.Kaydedildi || selectedStatus == (int)Mutabakat.MutabakatStatus.Hatirlatma)
            {
                var ids = filteredMutabakatlar
                    .Where(x => (int)x.Status == selectedStatus.Value)
                    .Select(x => (x.MutabakatId, x.FirmaId))
                    .Distinct()
                    .ToList();

                if (!ids.Any())
                {
                    NotificationService.Notify(
                        NotificationSeverity.Warning,
                        "Uyarı",
                        "Gönderilecek uygun mutabakat kaydı bulunamadı.");
                    return;
                }

                result = await MutabakatService.SendSelectedMailsAsync(ids);
            }
            else
            {
                result = await MutabakatService.SendPendingMailsAsync();
            }

            if (result.failCount == 0)
            {
                NotificationService.Notify(
                    NotificationSeverity.Success,
                    "Başarılı",
                    $"{result.successCount} adet mutabakat maili gönderildi.");
            }
            else
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Uyarı",
                    $"{result.successCount} adet gönderildi, {result.failCount} adet hata oluştu.");
            }

            await LoadMutabakatlarAsync();
            selectedMutabakatlar.Clear();
            await RestoreCurrentPageAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Hata",
                ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task SendSelectedMails()
    {
        if (isSubmitting) return;

        var ids = selectedMutabakatlar
            .Where(x => x.Status == Mutabakat.MutabakatStatus.Kaydedildi || x.Status == Mutabakat.MutabakatStatus.Hatirlatma)
            .Select(x => (x.MutabakatId, x.FirmaId))
            .Distinct()
            .ToList();

        if (!ids.Any())
        {
            NotificationService.Notify(
                NotificationSeverity.Warning,
                "Uyarı",
                "Gönderilecek herhangi bir kayıt seçilmedi.");
            return;
        }

        isSubmitting = true;

        try
        {
            var result = await MutabakatService.SendSelectedMailsAsync(ids);

            if (result.failCount == 0)
            {
                NotificationService.Notify(
                    NotificationSeverity.Success,
                    "Başarılı",
                    $"{result.successCount} adet seçili mutabakat maili gönderildi.");
            }
            else
            {
                NotificationService.Notify(
                    NotificationSeverity.Warning,
                    "Uyarı",
                    $"{result.successCount} adet gönderildi, {result.failCount} adet hata oluştu.");
            }

            await LoadMutabakatlarAsync();
            selectedMutabakatlar.Clear();
            await RestoreCurrentPageAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(
                NotificationSeverity.Error,
                "Hata",
                ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task RefreshData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            ClearFilters();
            await LoadMutabakatlarAsync();
            await RestoreCurrentPageAsync();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private string GetBakiyeTipiText(string bakiyeTipi)
    {
        return bakiyeTipi switch
        {
            "B" => "Borç",
            "A" => "Alacak",
            _ => "-"
        };
    }

    private string GetStatusText(Mutabakat.MutabakatStatus status)
    {
        string text = status switch
        {
            Mutabakat.MutabakatStatus.Kaydedildi => "Kaydedildi",
            Mutabakat.MutabakatStatus.Gonderildi => "Gönderildi",
            Mutabakat.MutabakatStatus.Hatirlatma => "Hatırlatma",
            Mutabakat.MutabakatStatus.Mutabik => "Mutabık",
            Mutabakat.MutabakatStatus.MutabikDegil => "Mutabık Değil",
            _ => "Tanımsız"
        };

        return Capitalize(text);
    }

    private static string Capitalize(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var s = value.Trim().ToLowerInvariant();
        return char.ToUpperInvariant(s[0]) + (s.Length > 1 ? s.Substring(1) : string.Empty);
    }

    private BadgeStyle GetStatusBadgeStyle(Mutabakat.MutabakatStatus status)
    {
        return status switch
        {
            Mutabakat.MutabakatStatus.Kaydedildi => BadgeStyle.Secondary,
            Mutabakat.MutabakatStatus.Gonderildi => BadgeStyle.Info,
            Mutabakat.MutabakatStatus.Hatirlatma => BadgeStyle.Warning,
            Mutabakat.MutabakatStatus.Mutabik => BadgeStyle.Success,
            Mutabakat.MutabakatStatus.MutabikDegil => BadgeStyle.Danger,
            _ => BadgeStyle.Light
        };
    }

