            "Tüm mutabakat kayıtları silinecek. Onaylıyor musunuz?",
            "Toplu Silme Onayı",
            new ConfirmOptions
            {
                OkButtonText = "Evet",
                CancelButtonText = "Vazgeç"
            });

        if (confirmed != true)
            return;

        if (isSubmitting) return;
