@page "/reconciliations/deleted"

@attribute [Authorize]

@inject IMutabakatService MutabakatService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService
@inject DialogService DialogService

<PageTitle>Silinen Mutabakatlar</PageTitle>

<RadzenCard Style="padding:20px;">
    <RadzenStack Orientation="Orientation.Horizontal"
                 AlignItems="AlignItems.Center"
                 JustifyContent="JustifyContent.SpaceBetween"
                 Style="margin-bottom:20px;">
        <RadzenText TextStyle="TextStyle.H4">Silinen Mutabakatlar</RadzenText>

        <RadzenButton Text="Aktif Listeye Dön"
                      Icon="arrow_back"
                      ButtonStyle="ButtonStyle.Secondary"
                      Click="@(() => NavigationManager.NavigateTo("/reconciliations"))" />
    </RadzenStack>

    <RadzenDataGrid Data="@items"
                    TItem="SilinenMutabakat"
                    AllowPaging="true"
                    AllowSorting="true"
                    AllowFiltering="true"
                    PageSize="10"
                    EmptyText="Kayıt bulunamadı">

        <Columns>
            <RadzenDataGridColumn TItem="SilinenMutabakat" Property="MutabakatId" Title="ID" />

            <RadzenDataGridColumn TItem="SilinenMutabakat" Title="Tarih">
                <Template Context="item">
                    @item.MutabakatTarihi.ToString("dd.MM.yyyy")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SilinenMutabakat" Title="Firma">
                <Template Context="item">
                    @item.Firma?.FirmaAdi
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SilinenMutabakat" Title="Cari">
                <Template Context="item">
                    @item.Cari?.CariAdi
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SilinenMutabakat" Title="Döviz">
                <Template Context="item">
                    @(item.DovizKodu?.Name ?? item.MutabakatDovizKodu)
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SilinenMutabakat" Title="Bakiye">
                <Template Context="item">
                    @item.MutabakatBakiye.ToString("N2")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SilinenMutabakat" Title="Bakiye Tipi">
                <Template Context="item">
                    @GetBakiyeTipiText(item.MutabakatBakiyeTipi)
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SilinenMutabakat" Title="Durum">
                <Template Context="item">
                    <RadzenBadge Text="@GetStatusText(item.Status)"
                                 BadgeStyle="@GetStatusBadgeStyle(item.Status)" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SilinenMutabakat" Title="Silinme Tarihi">
                <Template Context="item">
                    @item.SilinmeTarihi.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="SilinenMutabakat" Title="İşlem" Sortable="false" Filterable="false" Width="120px">
                <Template Context="item">
                    <RadzenStack Orientation="Orientation.Horizontal" Gap="8px">
                        <RadzenButton Text=""
                                      Icon="visibility"
                                      Size="ButtonSize.Small"
                                      Click="@(() => GoDetail(item.Id))" />

                        <RadzenButton Text=""
                                      Icon="delete"
                                      Size="ButtonSize.Small"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Click="@(() => DeleteRecord(item))" />
                    </RadzenStack>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenCard>

@code {
    private List<SilinenMutabakat> items = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            items = await MutabakatService.GetAllDeletedAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", ex.Message);
        }
    }

    private void GoDetail(int id)
    {
        NavigationManager.NavigateTo($"/reconciliations/deleted/{id}");
    }

    private async Task DeleteRecord(SilinenMutabakat item)
    {
        var result = await DialogService.Confirm(
            "Bu kayıt kalıcı olarak silinecek. Devam etmek istiyor musunuz?",
            "Silme Onayı",
            new ConfirmOptions
            {
                OkButtonText = "Evet",
                CancelButtonText = "Vazgeç"
            });

        if (result != true)
            return;

        try
        {
            var deleted = await MutabakatService.DeleteDeletedAsync(item.Id);

            if (!deleted)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Kayıt bulunamadı.");
                return;
            }

            items = await MutabakatService.GetAllDeletedAsync();

            NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Kayıt başarıyla silindi.");

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", ex.Message);
        }
    }

    private string GetBakiyeTipiText(string bakiyeTipi)
    {
        return bakiyeTipi switch
        {
            "B" => "Borç",
            "A" => "Alacak",
            _ => "-"
        };
    }

    private string GetStatusText(Mutabakat.MutabakatStatus status)
    {
        return status switch
        {
            Mutabakat.MutabakatStatus.Kaydedildi => "Kaydedildi",
            Mutabakat.MutabakatStatus.Gonderildi => "Gönderildi",
            Mutabakat.MutabakatStatus.Hatirlatma => "Hatırlatma",
            Mutabakat.MutabakatStatus.Mutabik => "Mutabık",
            Mutabakat.MutabakatStatus.MutabikDegil => "Mutabık Değil",
            _ => "Tanımsız"
        };
    }

    private BadgeStyle GetStatusBadgeStyle(Mutabakat.MutabakatStatus status)
    {
        return status switch
        {
            Mutabakat.MutabakatStatus.Kaydedildi => BadgeStyle.Secondary,
            Mutabakat.MutabakatStatus.Gonderildi => BadgeStyle.Info,
            Mutabakat.MutabakatStatus.Hatirlatma => BadgeStyle.Warning,
            Mutabakat.MutabakatStatus.Mutabik => BadgeStyle.Success,
            Mutabakat.MutabakatStatus.MutabikDegil => BadgeStyle.Danger,
            _ => BadgeStyle.Light
        };
    }
}