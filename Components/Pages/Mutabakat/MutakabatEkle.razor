@page "/reconciliations/add"

@attribute [Authorize]

@inject IMutabakatService MutabakatService
@inject ICariService CariService
@inject IFirmaService FirmaService
@inject IDovizKoduService DovizKoduService
@inject IKullaniciService KullaniciService
@inject NavigationManager NavigationManager
@inject NotificationService NotificationService

<PageTitle>Yeni Mutabakat Ekle</PageTitle>

@if (!canAdd)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">Bu sayfaya erişim yetkiniz bulunmamaktadır.</RadzenAlert>
}
else
{
    <RadzenCard Style="max-width:900px; margin: 24px auto; padding:24px;">
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Gap="8px">
            <RadzenText TextStyle="TextStyle.H4">Yeni Mutabakat Ekle</RadzenText>
        </RadzenStack>
        <RadzenText TextStyle="TextStyle.H4" class="mb-3"></RadzenText>

        <EditForm Model="@mutabakat" OnValidSubmit="@HandleValidSubmit">
            <DataAnnotationsValidator />

            <RadzenRow Gap="16px">

                <RadzenColumn Size="12" SizeMD="6">
                    <ValidationMessage For="@(() => mutabakat.MutabakatId)" />
                    <RadzenFormField Text="Mutabakat ID" Style="width:100%;">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="mutabakat.MutabakatId"
                                           Name="MutabakatId"
                                           Style="width:100%;" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <ValidationMessage For="@(() => mutabakat.FirmaId)" />
                    <RadzenFormField Text="Firma" Style="width:100%;">
                        <ChildContent>
                            <RadzenDropDown TValue="int?"
                                            Name="FirmaId"
                                            Data="@firmalar"
                                            TextProperty="FirmaAdi"
                                            ValueProperty="FirmaId"
                                            @bind-Value="selectedFirmaId"
                                            Placeholder="Firma seçiniz"
                                            Style="width:100%;"
                                            AllowFiltering="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Change="@OnFirmaChanged" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <ValidationMessage For="@(() => mutabakat.CariId)" />
                    <RadzenFormField Text="Cari" Style="width:100%;">
                        <ChildContent>
                            <RadzenDropDown TValue="string"
                                            Name="CariId"
                                            Data="@filteredCariler"
                                            TextProperty="CariDisplayText"
                                            ValueProperty="CariId"
                                            @bind-Value="mutabakat.CariId"
                                            Placeholder="Cari seçiniz"
                                            Style="width:100%;"
                                            AllowFiltering="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                            Change="@OnCariChanged" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <ValidationMessage For="@(() => cariMail)" />
                    <RadzenFormField Text="Cari Mail" Style="width:100%;">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="cariMail"
                                           Name="CariMail"
                                           Placeholder="Cari yetkili mail"
                                           Style="width:100%;" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <ValidationMessage For="@(() => mutabakat.MutabakatTarihi)" />
                    <RadzenFormField Text="Mutabakat Tarihi" Style="width:100%;">
                        <ChildContent>
                            <RadzenDatePicker @bind-Value="mutabakat.MutabakatTarihi"
                                              Name="MutabakatTarihi"
                                              DateFormat="dd.MM.yyyy"
                                              Style="width:100%;" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <ValidationMessage For="@(() => mutabakat.MutabakatDovizKodu)" />
                    <RadzenFormField Text="Döviz Kodu" Style="width:100%;">
                        <ChildContent>
                            <RadzenDropDown TValue="string"
                                            Name="MutabakatDovizKodu"
                                            Data="@dovizKodlari"
                                            TextProperty="Name"
                                            ValueProperty="TCMB"
                                            @bind-Value="mutabakat.MutabakatDovizKodu"
                                            Placeholder="Döviz seçiniz"
                                            Style="width:100%;"
                                            AllowFiltering="true"
                                            FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" 
                                            Disabled/>
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <ValidationMessage For="@(() => mutabakat.MutabakatBakiye)" />
                    <RadzenFormField Text="Bakiye" Style="width:100%;">
                        <ChildContent>
                            <RadzenNumeric @bind-Value="mutabakat.MutabakatBakiye"
                                           Name="MutabakatBakiye"
                                           TValue="decimal"
                                           Style="width:100%;" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12" SizeMD="6">
                    <ValidationMessage For="@(() => mutabakat.MutabakatBakiyeTipi)" />
                    <RadzenFormField Text="Bakiye Tipi" Style="width:100%;">
                        <ChildContent>
                            <RadzenDropDown TValue="string"
                                            Name="MutabakatBakiyeTipi"
                                            Data="@bakiyeTipleri"
                                            TextProperty="Text"
                                            ValueProperty="Value"
                                            @bind-Value="mutabakat.MutabakatBakiyeTipi"
                                            Placeholder="Bakiye tipi seçiniz"
                                            Style="width:100%;" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenFormField Text="Açıklama" Style="width:100%;">
                        <ChildContent>
                            <RadzenTextArea @bind-Value="mutabakat.MutabakatAciklama"
                                            Name="MutabakatAciklama"
                                            Style="width:100%;"
                                            Rows="4" />
                        </ChildContent>
                    </RadzenFormField>
                </RadzenColumn>

                <RadzenColumn Size="12">
                    <RadzenStack Orientation="Orientation.Horizontal"
                                 Gap="10px"
                                 JustifyContent="JustifyContent.End"
                                 class="mt-3">
                        <RadzenButton Text="İptal"
                                      Icon="close"
                                      Style="background:#f5f5f5;color:#333;border:1px solid #e8e8e8;border-radius:8px;padding:8px 14px; font-size:12px;"
                                      ButtonStyle="ButtonStyle.Light"
                                      Click="@GoBack"
                                      Disabled="@isSubmitting" />
                        <RadzenButton Text="Kaydet"
                                      Icon="save"
                                      Style="background:#eaf2ff;color:#0b57d0;border:1px solid #d7e6ff;border-radius:8px;padding:8px 14px; font-size:12px;"
                                      ButtonStyle="ButtonStyle.Primary"
                                      ButtonType="ButtonType.Submit"
                                      Disabled="@isSubmitting" />

                    </RadzenStack>
                </RadzenColumn>

            </RadzenRow>
        </EditForm>
    </RadzenCard>
}

@code {
    private Mutabakat mutabakat = new();
    private List<CariLookupItem> allCariler = new();
    private List<CariLookupItem> filteredCariler = new();
    private List<FirmaLookupItem> firmalar = new();
    private List<DovizKodu> dovizKodlari = new();

    private bool isSubmitting = false;
    private bool canAdd;
    private string? cariMail;
    private int? selectedFirmaId;

    private readonly List<SelectItem> bakiyeTipleri =
    [
        new SelectItem { Text = "Borç", Value = "B" },
        new SelectItem { Text = "Alacak", Value = "A" }
    ];

    protected override async Task OnInitializedAsync()
    {
        var yetki = await KullaniciService.GetCurrentUserYetkiAsync();
        var isSeed = await KullaniciService.IsCurrentUserSeedAsync();

        canAdd = isSeed || (yetki != null && yetki.Mutabakatlar >= YetkiSeviyesi.Giris);

        if (!canAdd)
            return;

        await LoadInitialDataAsync();
    }

    private async Task LoadInitialDataAsync()
    {
        mutabakat = new Mutabakat
        {
            MutabakatTarihi = DateTime.Today,
            MutabakatBakiyeTipi = "B"
        };

        mutabakat.MutabakatId = await MutabakatService.GenerateNextMutabakatIdAsync();

        var firmaList = await FirmaService.GetAllAsync();
        firmalar = firmaList
            .OrderBy(x => x.FirmaAdi)
            .Select(x => new FirmaLookupItem
            {
                FirmaId = x.FirmaId,
                FirmaAdi = x.FirmaAdi ?? string.Empty
            })
            .ToList();

        var cariList = await CariService.GetAllAsync();
        allCariler = cariList
            .OrderBy(x => x.CariAdi)
            .Select(x => new CariLookupItem
            {
                CariId = x.CariId,
                FirmaId = x.FirmaId,
                CariAdi = x.CariAdi ?? string.Empty,
                CariDovizKodu = x.CariDovizKodu,
                CariYetkiliMail = x.CariYetkiliMail
            })
            .ToList();

        filteredCariler = new List<CariLookupItem>();

        dovizKodlari = await DovizKoduService.GetActiveAsync();

        if (string.IsNullOrWhiteSpace(mutabakat.MutabakatDovizKodu))
        {
            mutabakat.MutabakatDovizKodu = "TL";
        }
    }

    private void OnFirmaChanged(object value)
    {
        selectedFirmaId = value as int? ?? ConvertToNullableInt(value);

        mutabakat.FirmaId = selectedFirmaId ?? 0;
        mutabakat.CariId = string.Empty;
        cariMail = null;

        filteredCariler = selectedFirmaId.HasValue
            ? allCariler
                .Where(x => x.FirmaId == selectedFirmaId.Value)
                .OrderBy(x => x.CariAdi)
                .ToList()
            : new List<CariLookupItem>();
    }

    private void OnCariChanged(object value)
    {
        var cariId = value?.ToString();

        if (string.IsNullOrWhiteSpace(cariId) || !selectedFirmaId.HasValue)
            return;

        var selectedCari = filteredCariler.FirstOrDefault(x =>
            x.CariId == cariId && x.FirmaId == selectedFirmaId.Value);

        if (selectedCari is null)
            return;

        mutabakat.FirmaId = selectedCari.FirmaId;
        cariMail = selectedCari.CariYetkiliMail;

        mutabakat.MutabakatDovizKodu = !string.IsNullOrWhiteSpace(selectedCari.CariDovizKodu)
            ? selectedCari.CariDovizKodu!
            : mutabakat.MutabakatDovizKodu;

        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        if (isSubmitting)
            return;

        if (!selectedFirmaId.HasValue)
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Lütfen firma seçiniz.");
            return;
        }

        if (string.IsNullOrWhiteSpace(mutabakat.CariId))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Uyarı", "Lütfen cari seçiniz.");
            return;
        }

        if (!ValidateCariMail())
            return;

        isSubmitting = true;

        try
        {
            mutabakat.FirmaId = selectedFirmaId.Value;

            var result = await MutabakatService.AddAsync(mutabakat, cariMail);

            if (result == null)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Hata", "Kayıt oluşturulamadı.");
                return;
            }

            NotificationService.Notify(NotificationSeverity.Success, "Başarılı", "Mutabakat başarıyla oluşturuldu.");
            NavigationManager.NavigateTo("/reconciliations");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/reconciliations");
    }

    private bool ValidateCariMail()
    {
        if (string.IsNullOrWhiteSpace(cariMail))
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", "Cari mail adresi boş olamaz.");
            return false;
        }

        try
        {
            var _ = new System.Net.Mail.MailAddress(cariMail);
            return true;
        }
        catch
        {
            NotificationService.Notify(NotificationSeverity.Error, "Hata", "Lütfen geçerli bir mail adresi giriniz.");
            return false;
        }
    }

    private static int? ConvertToNullableInt(object? value)
    {
        if (value == null)
            return null;

        if (value is int intValue)
            return intValue;

        return int.TryParse(value.ToString(), out var parsed) ? parsed : null;
    }

    private sealed class CariLookupItem
    {
        public string CariId { get; set; } = string.Empty;
        public int FirmaId { get; set; }
        public string CariAdi { get; set; } = string.Empty;
        public string? CariDovizKodu { get; set; }
        public string? CariYetkiliMail { get; set; }

        public string CariDisplayText => $"{CariId} - {CariAdi}";
    }

    private sealed class FirmaLookupItem
    {
        public int FirmaId { get; set; }
        public string FirmaAdi { get; set; } = string.Empty;
    }

    private sealed class SelectItem
    {
        public string Text { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }
}