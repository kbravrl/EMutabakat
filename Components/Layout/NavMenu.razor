@inject IKullaniciService KullaniciService

<div class="radzen-nav">
    <RadzenPanelMenu Style="background:transparent; border:0;">
        <AuthorizeView>
            <Authorized>
                <RadzenPanelMenuItem Text="Kontrol Paneli" Path="/" Icon="home" />
                <RadzenPanelMenuItem Text="Cariler" Path="/currents" Icon="account_circle" />
                <RadzenPanelMenuItem Text="Cari Gruplar" Path="/current-groups" Icon="group_work" />
                <RadzenPanelMenuItem Text="Döviz Kodları" Path="/currency-codes" Icon="currency_exchange" />
                <RadzenPanelMenuItem Text="Mutabakatlar" Path="/reconciliations" Icon="description" />
                <RadzenPanelMenuItem Text="Firmalar" Path="/companies" Icon="business" />

                <RadzenPanelMenuItem Text="Kullanıcılar" Path="/users" Icon="people" />
                
                @if (canViewLogs)
                {
                    <RadzenPanelMenuItem Text="Loglar" Path="/auth/logs" Icon="receipt_long" />
                }
                
                <RadzenPanelMenuItem Text="Çıkış Yap" Path="/logout" Icon="logout" />
            </Authorized>

            <NotAuthorized>
                <RadzenPanelMenuItem Text="Giriş Yap" Path="/login" Icon="login" />
            </NotAuthorized>
        </AuthorizeView>
    </RadzenPanelMenu>
</div>

@code {
    private bool canViewLogs;

    protected override async Task OnInitializedAsync()
    {
        var yetki = await KullaniciService.GetCurrentUserYetkiAsync();
        var isSeed = await KullaniciService.IsCurrentUserSeedAsync();

        canViewLogs = isSeed || (yetki?.LogYetki ?? false);
    }
}